{
  "name": "@cawalch/porchlight",
  "version": "0.9.0",
  "description": "A no-dependency, native-CSS framework for building accessible, themeable web applications.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://cawalch.github.io/porchlight",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cawalch/porchlight.git",
    "directory": "packages/porchlight"
  },
  "bugs": {
    "url": "https://github.com/cawalch/porchlight/issues"
  },
  "author": "cawalch",
  "keywords": [
    "css",
    "css-framework",
    "design-system",
    "component-library",
    "oklch",
    "light-dark",
    "css-layer",
    "accessible",
    "wcag",
    "dark-mode",
    "no-dependencies",
    "native-css"
  ],
  "style": "dist/porchlight.css",
  "bin": {
    "porchlight": "bin/porchlight.mjs"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./dist/porchlight.css",
    "./min.css": "./dist/porchlight.min.css",
    "./compat.css": "./dist/compat.css",
    "./core.css": "./dist/core.css",
    "./layout.css": "./dist/layout.css",
    "./components.css": "./dist/components.css",
    "./components/*.css": "./dist/components/*.css",
    "./utilities.css": "./dist/utilities.css",
    "./enhancements.css": "./dist/enhancements.css",
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "default": "./dist/tokens.js"
    },
    "./tokens.json": "./dist/tokens.json",
    "./manifest.json": "./dist/porchlight.manifest.json",
    "./src/*": "./src/*"
  },
  "files": [
    "bin",
    "porchlight.css",
    "src",
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test:package": "pnpm build && node scripts/smoke-package.mjs",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "lightningcss": "^1.32.0"
  }
}
