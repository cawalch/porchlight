{
  "name": "porchlight",
  "private": true,
  "version": "0.0.0",
  "description": "A no-dependency, native-CSS framework.",
  "license": "MIT",
  "homepage": "https://cawalch.github.io/porchlight",
  "repository": {
    "type": "git",
    "url": "https://github.com/cawalch/porchlight.git"
  },
  "bugs": {
    "url": "https://github.com/cawalch/porchlight/issues"
  },
  "author": "cawalch",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter ./docs dev",
    "build": "pnpm --filter @cawalch/porchlight build && pnpm --filter ./docs build",
    "test": "pnpm --filter ./docs test",
    "lint": "stylelint \"**/*.css\" --allow-empty-input",
    "lint:js": "biome lint .",
    "lint:all": "pnpm lint && pnpm lint:js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "prettier": "^3.4.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-plugin-defensive-css": "^2.9.3",
    "stylelint-use-logical": "^2.1.3"
  }
}
