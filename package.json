{
  "name": "porchlight",
  "private": true,
  "version": "0.0.0",
  "description": "A no-dependency, native-CSS design substrate for enterprise SaaS.",
  "license": "MIT",
  "homepage": "https://cawalch.github.io/porchlight",
  "repository": {
    "type": "git",
    "url": "https://github.com/cawalch/porchlight.git"
  },
  "bugs": {
    "url": "https://github.com/cawalch/porchlight/issues"
  },
  "author": "cawalch",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter ./docs dev",
    "build": "pnpm --filter ./docs build",
    "test": "pnpm --filter ./docs test",
    "lint": "stylelint \"**/*.css\" --allow-empty-input",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
