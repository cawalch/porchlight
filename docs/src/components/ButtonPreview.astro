---
// Live, interactive button demo embedded in the component doc page.
---
<div class="l-cluster demo">
  <button type="button" class="c-button">default</button>
  <button type="button" class="c-button" data-variant="primary">primary</button>
  <button type="button" class="c-button" data-variant="secondary">secondary</button>
  <button type="button" class="c-button" data-variant="ghost">ghost</button>
  <button type="button" class="c-button" data-variant="primary" aria-pressed="true">pressed</button>
  <button type="button" class="c-button" data-variant="primary" disabled>disabled</button>
</div>

<style>
  .demo {
    padding: var(--pl-space-5);
    margin-block: var(--pl-space-4);
    background: var(--pl-color-surface);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
  }
</style>
