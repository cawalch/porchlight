---
// Live field demo embedded in the component doc page.
---
<div class="demo l-stack">
  <label class="c-field">
    <span class="c-field__label">
      Workspace name
      <span class="c-field__required" aria-hidden="true">*</span>
    </span>
    <input class="c-field__control" required placeholder="Acme Ops" aria-describedby="preview-name-help" />
    <span class="c-field__hint" id="preview-name-help">Use a name your team recognizes.</span>
  </label>
  <label class="c-field">
    <span class="c-field__label">Storage limit</span>
    <input class="c-field__control" type="number" value="92" aria-describedby="preview-storage-warning" />
    <span class="c-field__hint" id="preview-storage-warning" data-tone="warning">Approaching the plan limit.</span>
  </label>
  <label class="c-field">
    <span class="c-field__label">Workspace URL</span>
    <input class="c-field__control" required value="acme ops" aria-invalid="true" aria-describedby="preview-slug-help preview-slug-error" />
    <span class="c-field__messages">
      <span class="c-field__hint" id="preview-slug-help">Use lowercase letters, numbers, and hyphens.</span>
      <span class="c-field__hint" id="preview-slug-error" data-tone="danger" role="alert">Spaces are not allowed.</span>
    </span>
  </label>
  <label class="c-field">
    <span class="c-field__label">Invite status</span>
    <input class="c-field__control" type="email" value="ops@example.com" aria-describedby="preview-invite-success" />
    <span class="c-field__hint" id="preview-invite-success" data-tone="success">Ready to invite.</span>
  </label>
  <label class="c-field">
    <span class="c-field__label">Notes</span>
    <textarea class="c-field__control" rows="3" placeholder="Add context..."></textarea>
    <span class="c-field__hint">Textarea uses the same field surface.</span>
  </label>
  <label class="c-field c-field--inline">
    <span class="c-field__label">Region</span>
    <select class="c-field__control">
      <option>US Central</option>
      <option>EU West</option>
    </select>
    <span class="c-field__hint">Inline labels stack on narrow screens.</span>
  </label>
  <div class="c-field">
    <label class="c-field__label" for="preview-slug">Workspace URL</label>
    <div class="c-input-group">
      <input id="preview-slug" class="c-field__control" required placeholder="acme-ops" />
      <span class="c-input-group__addon">.porchlight.app</span>
    </div>
    <span class="c-field__hint">Input groups preserve native input behavior.</span>
  </div>
</div>

<style>
  .demo {
    padding: var(--pl-space-5);
    margin-block: var(--pl-space-4);
    background: var(--pl-color-surface);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
    gap: var(--pl-space-4);
  }
</style>
