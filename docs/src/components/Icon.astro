---
/**
 * <Icon> — tiny inline SVG icon, 1em to inherit the button's text size/color.
 * Names are deliberately minimal; this is a docs helper, not a framework
 * icon system (Porchlight ships no icon library). currentColor fill so it
 * follows --pl-c-button-fg automatically.
 */
interface Props {
  name:
    | 'book'
    | 'code'
    | 'download'
    | 'eye'
    | 'file'
    | 'gear'
    | 'grid'
    | 'plus'
    | 'search';
}
const { name } = Astro.props;
const paths: Record<Props['name'], string> = {
  book: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15Z',
  code: 'm16 18 6-6-6-6M8 6l-6 6 6 6',
  download: 'M12 3v12m0 0 4-4m-4 4-4-4M5 21h14',
  eye: 'M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Zm10 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z',
  file: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Zm0 0v6h6',
  plus: 'M12 5v14M5 12h14',
  gear: 'M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm0-7 1.5 2.6 3-.7.7 3-2.6 1.5L19 12l2.6 1.5-3 .7-.7 3L15.5 19 12 21l-3.5-2-3 .7-.7-3L2.4 13.5 5 12 2.4 10.5l3-.7.7-3L8.5 5 12 2Z',
  grid: 'M3 3h7v7H3Zm11 0h7v7h-7ZM3 14h7v7H3Zm11 0h7v7h-7Z',
  search: 'm21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z',
};
---
<svg
  class="icon"
  width="1em"
  height="1em"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
><path d={paths[name]} /></svg>

<style>
  .icon {
    flex-shrink: 0;
  }
</style>
