---
/**
 * BaseLayout — the HTML shell for every docs page.
 *
 * Styling lives in src/styles/global.css. The docs chrome now consumes the
 * Porchlight --pl-* token layer directly; only docs-specific layout geometry
 * remains under --doc-* custom properties.
 */
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Porchlight',
  description = 'A no-dependency, native-CSS framework.',
} = Astro.props;

// Resolve internal links against the build-time base path so the site works
// both at the Pages root (/porchlight/) and under PR previews (/porchlight/pr/<n>/).
const b = import.meta.env.BASE_URL;
const link = (path: string) => `${b}${path.replace(/^\//, '')}`;

const nav = [
  { href: link('guides/getting-started'), label: 'Start', external: false },
  { href: link('components/button'), label: 'Components', external: false },
  { href: link('tokens'), label: 'Tokens', external: false },
  { href: link('preview'), label: 'Preview', external: false },
  { href: 'https://github.com/cawalch/porchlight', label: 'GitHub', external: true },
];

const here = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => {
  if (href.startsWith('http')) return false;
  const clean = href.replace(/\/$/, '');
  // Exact match, or prefix match for nav sections.
  if (here === clean) return true;
  if (clean.endsWith('getting-started') && here.includes('/guides/')) return true;
  if (clean.endsWith('components/button') && here.includes('/components/')) return true;
  if (clean.endsWith('tokens') && here.includes('/tokens')) return true;
  if (clean.endsWith('preview') && here.includes('/preview/')) return true;
  return false;
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${b}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="site-header__brand" href={b} aria-label="Porchlight docs home">
        <span class="site-header__mark" aria-hidden="true">P</span>
        <span class="site-header__brand-copy">
          <strong>Porchlight</strong>
          <small>CSS workbench</small>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <ul>
          {nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={item.external ? undefined : (isActive(item.href) ? 'page' : undefined)}
                rel={item.external ? 'noopener noreferrer' : undefined}
              >{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>Porchlight · <a href="https://github.com/cawalch/porchlight">GitHub</a> · MIT</p>
    </footer>
  </body>
</html>
