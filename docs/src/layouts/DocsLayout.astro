---
/**
 * DocsLayout - the workbench shell for guide, token, and component docs.
 *
 * The docs pages are no longer treated as static article pages with helper
 * links. They present Porchlight as a living CSS system: a command/search
 * surface, source atlas, document canvas, and preview/style inspector.
 */
import { getCollection } from 'astro:content';
import Icon from '../components/Icon.astro';
import BaseLayout from './BaseLayout.astro';
import '../styles/global.css';

type ActionIcon = 'book' | 'code' | 'eye' | 'file' | 'grid';

interface Props {
  title?: string;
  description?: string;
  sectionLabel?: string;
  status?: string;
  since?: string;
  previewHref?: string;
  sourceHref?: string;
  styleHref?: string;
}

const {
  title,
  description,
  sectionLabel = 'Docs',
  status,
  since,
  previewHref,
  sourceHref,
  styleHref,
} = Astro.props;

const b = import.meta.env.BASE_URL;
const repo = 'https://github.com/cawalch/porchlight';
const pageName = title?.replace(/\s+·\s+Porchlight$/, '') ?? sectionLabel;

const documentedEntries = (await getCollection('components')).sort((a, z) =>
  a.data.title.localeCompare(z.data.title),
);
const components = documentedEntries.filter((entry) => entry.data.kind === 'component');
const patterns = documentedEntries.filter((entry) => entry.data.kind === 'pattern');
const guides = (await getCollection('guides')).sort((a, z) =>
  (a.data.order ?? 0) - (z.data.order ?? 0),
);
const foundationGuideIds = [
  'architecture',
  'layout',
  'composition-recipes',
  'utilities',
  'enhancements',
];
const gettingStartedGuides = guides.filter((guide) => !foundationGuideIds.includes(guide.id));
const foundationGuides = guides.filter((guide) => foundationGuideIds.includes(guide.id));

const stableCount = components.filter((component) => component.data.status === 'stable').length;
const experimentalCount = components.filter((component) => component.data.status === 'experimental').length;

const here = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => {
  const clean = href.replace(/^\//, '');
  return here.endsWith(clean) || here === clean.replace(/\/$/, '');
};

const actionLinks = [
  previewHref && { href: previewHref, label: 'Live preview', icon: 'eye', tone: 'primary' },
  sourceHref && { href: sourceHref, label: 'Content source', icon: 'file' },
  styleHref && { href: styleHref, label: 'Style source', icon: 'code' },
].filter(Boolean) as { href: string; label: string; icon: ActionIcon; tone?: string }[];

const surfaceLinks = [
  { href: `${b}tokens`, label: 'Token reference', detail: 'Color, type, spacing', icon: 'grid' },
  { href: `${b}preview/tokens`, label: 'Token preview', detail: 'Rendered scales', icon: 'eye' },
  { href: `${repo}/tree/main/packages/porchlight/src`, label: 'CSS source', detail: 'Layered framework files', icon: 'code' },
] as { href: string; label: string; detail: string; icon: ActionIcon }[];

const screenLinks = [
  { href: `${b}preview/dashboard`, label: 'Dashboard', meta: 'Preview', search: 'Dashboard preview example' },
  { href: `${b}preview/settings`, label: 'Settings', meta: 'Preview', search: 'Settings preview example' },
  { href: `${b}preview/app-dashboard`, label: 'SaaS Portal', meta: 'App', search: 'SaaS Portal app dashboard preview example' },
  { href: `${b}preview/app-siem`, label: 'Security SIEM', meta: 'App', search: 'Security SIEM preview example' },
  { href: `${b}preview/app-cases`, label: 'Case Review', meta: 'App', search: 'Case Review preview example' },
  { href: `${b}preview/app-inbox`, label: 'Inbox', meta: 'App', search: 'Inbox preview example' },
  { href: `${b}preview/app-marketing`, label: 'Marketing Page', meta: 'Page', search: 'Marketing Page preview example' },
  { href: `${b}preview/app-shell`, label: 'App Shell', meta: 'Layout', search: 'App Shell preview example' },
];

const commandSections = [
  {
    title: 'Getting Started',
    links: gettingStartedGuides.map((guide) => ({
      href: `${b}guides/${guide.id}`,
      label: guide.data.title,
      meta: 'Guide',
      search: `${guide.data.title} ${guide.data.description ?? ''} guide getting started`,
      current: isActive(`/guides/${guide.id}`),
    })),
  },
  {
    title: 'Foundations',
    links: [
      ...foundationGuides.map((guide) => ({
        href: `${b}guides/${guide.id}`,
        label: guide.data.title,
        meta: 'Guide',
        search: `${guide.data.title} ${guide.data.description ?? ''} foundation layout css utilities`,
        current: isActive(`/guides/${guide.id}`),
      })),
      {
        href: `${b}tokens`,
        label: 'Token reference',
        meta: 'Styles',
        search: 'Token reference color spacing typography styles css',
        current: isActive('/tokens'),
      },
    ],
  },
  {
    title: 'Components',
    links: components.map((component) => ({
      href: `${b}components/${component.id}`,
      label: component.data.title,
      meta: component.data.status,
      search: `${component.data.title} ${component.data.description ?? ''} ${component.data.status} component preview style`,
      current: isActive(`/components/${component.id}`),
    })),
  },
  {
    title: 'Patterns',
    links: patterns.map((pattern) => ({
      href: `${b}components/${pattern.id}`,
      label: pattern.data.title,
      meta: pattern.data.status,
      search: `${pattern.data.title} ${pattern.data.description ?? ''} ${pattern.data.status} pattern application recipe preview`,
      current: isActive(`/components/${pattern.id}`),
    })),
  },
  {
    title: 'Screens',
    links: screenLinks.map((link) => ({
      ...link,
      current: isActive(link.href),
    })),
  },
];
---
<BaseLayout title={title} description={description}>
  <div class="docs-workbench" data-pl-density="compact">
    <section class="docs-studio" aria-label="Documentation workbench">
      <div class="docs-stage">
        <div class="docs-stage__copy">
          <p class="docs-stage__eyebrow">
            <span>{sectionLabel}</span>
            <span>Porchlight CSS</span>
          </p>
          <p class="docs-stage__title">{pageName}</p>
          {description && <p class="docs-stage__description">{description}</p>}
        </div>

        <div class="docs-stage__command">
          <button
            class="docs-command-trigger"
            type="button"
            aria-haspopup="dialog"
            aria-controls="docs-command-dialog"
            data-docs-command-open
          >
            <Icon name="search" />
            <span>Search docs, components, styles</span>
            <kbd>Cmd K</kbd>
          </button>

          <p class="docs-command-bar__meta" aria-label="Workbench coverage">
            <span>{components.length} components</span>
            <span>{patterns.length} patterns</span>
            <span>{stableCount} stable</span>
            <span>{experimentalCount} experimental</span>
          </p>
        </div>

        {(status || since || actionLinks.length > 0) && (
          <div class="docs-stage__dock">
            {(status || since) && (
              <dl class="docs-page-meta" aria-label="Page metadata">
                {status && (
                  <div>
                    <dt>Status</dt>
                    <dd>{status}</dd>
                  </div>
                )}
                {since && (
                  <div>
                    <dt>Since</dt>
                    <dd>{since}</dd>
                  </div>
                )}
              </dl>
            )}

            {actionLinks.length > 0 && (
              <div class="docs-page-actions" aria-label="Page actions">
                {actionLinks.map((action) => (
                  <a
                    class:list={['docs-action', action.tone === 'primary' && 'docs-action--primary']}
                    href={action.href}
                  ><Icon name={action.icon} /> {action.label}</a>
                ))}
              </div>
            )}
          </div>
        )}
      </div>

      <nav class="docs-atlas" aria-label="Documentation atlas">
        {commandSections.map((section) => (
          <section
            class="docs-atlas__section"
            data-atlas-section={section.title.toLowerCase().replace(/\s+/g, '-')}
          >
            <h2>{section.title}</h2>
            <ul>
              {[...section.links].sort((a, z) => Number(z.current) - Number(a.current)).map((link) => (
                <li>
                  <a href={link.href} aria-current={link.current ? 'page' : undefined}>
                    <span>{link.label}</span>
                    <small>{link.meta}</small>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </nav>
    </section>

    <dialog
      id="docs-command-dialog"
      class="docs-command-dialog"
      aria-labelledby="docs-command-title"
      data-docs-command-dialog
    >
      <div class="docs-command-dialog__panel">
        <header class="docs-command-dialog__header">
          <div>
            <p>Command</p>
            <h2 id="docs-command-title">Search Porchlight</h2>
          </div>
          <button class="docs-command-dialog__close" type="button" data-docs-command-close>
            Close
          </button>
        </header>

        <label class="docs-command-dialog__search" for="docs-command-filter">
          <span><Icon name="search" /> Search docs</span>
          <input
            id="docs-command-filter"
            class="pl-c-field__control"
            type="search"
            placeholder="Filter docs, components, styles..."
            data-docs-command-filter
          />
        </label>

        <nav class="docs-command-dialog__quick" aria-label="Command shortcuts">
          <a href={`${b}components/button`}><Icon name="book" /> Components</a>
          <a href={`${b}tokens`}><Icon name="grid" /> Tokens</a>
          <a href={`${b}preview`}><Icon name="eye" /> Previews</a>
        </nav>

        <div class="docs-command-dialog__results">
          <nav class="docs-command-results" aria-label="Search results">
            {commandSections.map((section) => (
              <section class="docs-command-results__section" data-docs-command-section>
                <h3>{section.title}</h3>
                <ul>
                  {section.links.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        aria-current={link.current ? 'page' : undefined}
                        data-docs-command-link
                        data-docs-search={link.search}
                      >
                        <span>{link.label}</span>
                        <small>{link.meta}</small>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </nav>
          <p class="docs-search-empty" data-docs-command-empty hidden>No docs pages match that search.</p>
        </div>
      </div>
    </dialog>

    <div class="docs-shell">
      <div class="docs-content" data-docs-content>
        <div class="docs-article-surface">
          <slot />
        </div>
      </div>

      <aside class="docs-rail" aria-label="Live preview and page tools">
        <section class="docs-preview-panel">
          <header>
            <p>Inspector</p>
            <h2>{previewHref ? 'Preview viewport' : 'Reference map'}</h2>
          </header>
          {previewHref ? (
            <>
              <a class="docs-preview-panel__open" href={previewHref}><Icon name="eye" /> Open full preview</a>
              <div class="docs-preview-panel__frame" aria-label={`${pageName} live preview`}>
                <iframe src={previewHref} title={`${pageName} live preview`} loading="lazy"></iframe>
              </div>
            </>
          ) : (
            <p class="docs-preview-panel__empty">
              This page has no dedicated fixture. Use the style links below to inspect the rendered token layer.
            </p>
          )}
        </section>

        <section class="docs-rail-card">
          <h2>Source paths</h2>
          {actionLinks.length > 0 ? (
            <div class="docs-rail-actions">
              {actionLinks.map((action) => (
                <a
                  class:list={['docs-action', action.tone === 'primary' && 'docs-action--primary']}
                  href={action.href}
                ><Icon name={action.icon} /> {action.label}</a>
              ))}
            </div>
          ) : (
            <p>Use the style map to move between token references, preview fixtures, and source files.</p>
          )}
        </section>

        <section class="docs-rail-card">
          <h2>Styles</h2>
          <ul class="docs-surface-list">
            {surfaceLinks.map((link) => (
              <li>
                <a href={link.href}>
                  <Icon name={link.icon} />
                  <span>
                    <strong>{link.label}</strong>
                    <small>{link.detail}</small>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <section class="docs-rail-card" data-docs-toc-card hidden>
          <h2>On this page</h2>
          <ol class="docs-toc" data-docs-toc></ol>
        </section>
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
  const getCommandElements = () => ({
    commandDialog: document.querySelector<HTMLDialogElement>('[data-docs-command-dialog]'),
    commandInput: document.querySelector<HTMLInputElement>('[data-docs-command-filter]'),
    commandLinks: Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-docs-command-link]')),
    commandSections: Array.from(document.querySelectorAll<HTMLElement>('[data-docs-command-section]')),
    commandEmpty: document.querySelector<HTMLElement>('[data-docs-command-empty]'),
  });

  const applyCommandFilter = () => {
    const { commandInput, commandLinks, commandSections, commandEmpty } = getCommandElements();
    const query = commandInput?.value.trim().toLowerCase() ?? '';
    let visibleCount = 0;

    for (const link of commandLinks) {
      const haystack = `${link.textContent ?? ''} ${link.dataset.docsSearch ?? ''}`.toLowerCase();
      const visible = query.length === 0 || haystack.includes(query);
      const item = link.closest('li');
      if (item instanceof HTMLElement) item.hidden = !visible;
      if (visible) visibleCount += 1;
    }

    for (const section of commandSections) {
      section.hidden = !section.querySelector('li:not([hidden])');
    }

    if (commandEmpty) commandEmpty.hidden = visibleCount !== 0;
  };

  const openCommandDialog = () => {
    const { commandDialog, commandInput } = getCommandElements();
    if (!commandDialog) return;
    if (!commandDialog.open) commandDialog.showModal();
    if (commandInput) {
      commandInput.value = '';
      applyCommandFilter();
      window.requestAnimationFrame(() => commandInput.focus({ preventScroll: true }));
    }
  };

  const bindCommandDialog = () => {
    const { commandDialog, commandInput, commandLinks } = getCommandElements();

    document.querySelectorAll<HTMLElement>('[data-docs-command-open]').forEach((button) => {
      if (button.dataset.docsCommandOpenBound === 'true') return;
      button.dataset.docsCommandOpenBound = 'true';
      button.addEventListener('click', openCommandDialog);
    });

    document.querySelectorAll<HTMLElement>('[data-docs-command-close]').forEach((button) => {
      if (button.dataset.docsCommandCloseBound === 'true') return;
      button.dataset.docsCommandCloseBound = 'true';
      button.addEventListener('click', () => getCommandElements().commandDialog?.close());
    });

    if (commandInput && commandInput.dataset.docsCommandFilterBound !== 'true') {
      commandInput.dataset.docsCommandFilterBound = 'true';
      commandInput.addEventListener('input', applyCommandFilter);
    }

    commandLinks.forEach((link) => {
      if (link.dataset.docsCommandLinkBound === 'true') return;
      link.dataset.docsCommandLinkBound = 'true';
      link.addEventListener('click', () => getCommandElements().commandDialog?.close());
    });

    if (commandDialog && commandDialog.dataset.docsCommandDialogBound !== 'true') {
      commandDialog.dataset.docsCommandDialogBound = 'true';
      commandDialog.addEventListener('click', (event) => {
        const rect = commandDialog.getBoundingClientRect();
        const clickedInside =
          event.clientX >= rect.left &&
          event.clientX <= rect.right &&
          event.clientY >= rect.top &&
          event.clientY <= rect.bottom;

        if (!clickedInside) commandDialog.close();
      });
    }
  };

  bindCommandDialog();

  if (document.documentElement.dataset.docsCommandGlobalBound !== 'true') {
    document.documentElement.dataset.docsCommandGlobalBound = 'true';
    document.addEventListener('astro:page-load', bindCommandDialog);

    document.addEventListener('keydown', (event) => {
      const { commandDialog } = getCommandElements();

      if (event.key === 'Escape' && commandDialog?.open) {
        commandDialog.close();
        return;
      }

      if (!(event.metaKey || event.ctrlKey) || event.key.toLowerCase() !== 'k') return;
      event.preventDefault();
      openCommandDialog();
    });
  }

  const content = document.querySelector<HTMLElement>('[data-docs-content]');
  const toc = document.querySelector<HTMLOListElement>('[data-docs-toc]');
  const tocCard = document.querySelector<HTMLElement>('[data-docs-toc-card]');
  const headings = Array.from(content?.querySelectorAll<HTMLHeadingElement>('.prose h2[id], .prose h3[id]') ?? []);

  if (toc && tocCard && headings.length > 0) {
    for (const heading of headings.slice(0, 12)) {
      const item = document.createElement('li');
      const link = document.createElement('a');
      link.href = `#${heading.id}`;
      link.textContent = heading.textContent ?? '';
      if (heading.tagName === 'H3') item.dataset.depth = '3';
      item.append(link);
      toc.append(item);
    }
    tocCard.hidden = false;
  }

  const proseTables = Array.from(document.querySelectorAll<HTMLTableElement>('.prose table'));
  for (const table of proseTables) {
    if (table.scrollWidth <= table.clientWidth) continue;
    table.tabIndex = 0;
    table.setAttribute('aria-label', table.caption?.textContent?.trim() || 'Scrollable table');
  }
</script>

<style>
  :global(body:has(.docs-workbench)) {
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--pl-color-surface-2), transparent 28%) 0,
        var(--pl-color-bg) 24rem
      );
  }

  .docs-workbench {
    --docs-panel-bg: color-mix(in oklab, var(--pl-color-surface), transparent 6%);
    --docs-panel-strong: color-mix(in oklab, var(--pl-color-surface), var(--pl-color-accent) 3%);
    --docs-line: color-mix(in oklab, var(--pl-color-border), transparent 20%);
    --docs-line-strong: color-mix(in oklab, var(--pl-color-accent), transparent 58%);
    --docs-ink-soft: color-mix(in oklab, var(--pl-color-text-muted), var(--pl-color-text) 20%);

    inline-size: 100%;
    padding-inline: var(--doc-pad);
  }

  .docs-studio {
    max-inline-size: 112rem;
    margin-inline: auto;
    padding-block-start: var(--pl-space-3);
  }

  .docs-stage {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(19rem, 32rem) minmax(15rem, 23rem);
    gap: var(--pl-space-6);
    align-items: end;
    padding-block: var(--pl-space-6);
    border-block: 1px solid var(--docs-line);
    background:
      linear-gradient(
        90deg,
        color-mix(in oklab, var(--pl-color-accent), transparent 90%),
        transparent 32%
      );
  }

  .docs-stage::before {
    content: "";
    position: absolute;
    inset-block: var(--pl-space-6);
    inset-inline-start: 0;
    inline-size: 3px;
    border-radius: var(--pl-radius-pill);
    background: var(--pl-color-accent);
  }

  .docs-stage__copy {
    min-inline-size: 0;
    padding-inline-start: var(--pl-space-5);
  }

  .docs-stage__eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-2);
    margin-block: 0 var(--pl-space-2);
    color: var(--pl-color-accent);
    font-size: var(--pl-text-xs);
    font-weight: var(--pl-font-weight-bold);
    text-transform: uppercase;
  }

  .docs-stage__eyebrow span + span {
    color: var(--pl-color-text-muted);
  }

  .docs-stage__title {
    max-inline-size: 15ch;
    margin: 0;
    color: var(--pl-color-text);
    font-size: 4rem;
    font-weight: var(--pl-font-weight-black);
    letter-spacing: 0;
    line-height: 0.9;
  }

  .docs-stage__description {
    max-inline-size: 58ch;
    margin: var(--pl-space-4) 0 0;
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-lg);
    line-height: var(--pl-leading-normal);
  }

  .docs-stage__command,
  .docs-stage__dock {
    display: grid;
    gap: var(--pl-space-3);
    min-inline-size: 0;
  }

  .docs-command-trigger {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: var(--pl-space-3);
    align-items: center;
    inline-size: 100%;
    min-block-size: 2.75rem;
    padding-inline: var(--pl-space-3);
    border: 1px solid var(--docs-line);
    border-radius: var(--pl-radius-lg);
    background:
      linear-gradient(135deg, var(--docs-panel-strong), var(--docs-panel-bg)),
      var(--pl-color-surface);
    color: var(--pl-color-text-muted);
    box-shadow: var(--pl-shadow-1);
    cursor: pointer;
  }

  .docs-command-trigger:hover,
  .docs-command-trigger:focus-visible {
    border-color: var(--docs-line-strong);
    color: var(--pl-color-text);
  }

  .docs-command-trigger span {
    min-inline-size: 0;
    overflow: hidden;
    font-size: var(--pl-text-sm);
    font-weight: var(--pl-font-weight-semibold);
    text-align: start;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .docs-command-trigger kbd {
    min-inline-size: 3.25rem;
    padding: var(--pl-space-1) var(--pl-space-2);
    border: 1px solid var(--docs-line);
    border-radius: var(--pl-radius-sm);
    background: var(--pl-color-surface);
    color: var(--pl-color-text-muted);
    font-family: var(--pl-font-sans);
    font-size: var(--pl-text-xs);
    font-weight: var(--pl-font-weight-bold);
    text-align: center;
  }

  .docs-command-bar__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-2);
    justify-content: flex-end;
    margin: 0;
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-xs);
    font-weight: var(--pl-font-weight-semibold);
  }

  .docs-command-bar__meta span + span::before {
    content: "/";
    margin-inline-end: var(--pl-space-2);
    color: color-mix(in oklab, var(--pl-color-text-muted), transparent 45%);
  }

  .docs-atlas {
    display: grid;
    grid-template-columns:
      minmax(0, 0.9fr)
      minmax(0, 1.15fr)
      minmax(0, 2fr)
      minmax(0, 1.15fr)
      minmax(0, 0.95fr);
    gap: var(--pl-space-3);
    align-items: start;
    padding-block: var(--pl-space-4);
    border-block-end: 1px solid var(--docs-line);
  }

  .docs-atlas__section {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: var(--pl-space-3);
    box-sizing: border-box;
    block-size: 18rem;
    min-inline-size: 0;
    overflow: hidden;
    padding: var(--pl-space-3);
    border: 1px solid var(--docs-line);
    border-radius: var(--pl-radius-md);
    background:
      linear-gradient(180deg, var(--docs-panel-strong), transparent 78%),
      var(--docs-panel-bg);
  }

  .docs-atlas h2 {
    margin: 0;
    color: var(--pl-color-accent);
    font-size: var(--pl-text-xs);
    font-weight: var(--pl-font-weight-black);
    text-transform: uppercase;
  }

  .docs-atlas ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 8.5rem), 1fr));
    gap: var(--pl-space-2);
    margin: 0;
    padding: 0;
    overflow: visible;
    list-style: none;
  }

  .docs-atlas__section ul {
    min-block-size: 0;
    padding-inline-end: var(--pl-space-1);
    overflow-x: hidden;
    overflow-y: auto;
    scrollbar-gutter: stable;
    scrollbar-width: thin;
  }

  .docs-atlas__section[data-atlas-section='components'] ul {
