---
import BaseLayout from '../../layouts/BaseLayout.astro';

const rows = [
  { name: 'Acme Ops', plan: 'Enterprise', status: 'Active', mrr: '$2,400', seats: 48, created: '2024-03-15' },
  { name: 'Northwind', plan: 'Pro', status: 'Trialing', mrr: '$980', seats: 12, created: '2024-08-02' },
  { name: 'Globex', plan: 'Pro', status: 'Active', mrr: '$980', seats: 8, created: '2024-01-22' },
  { name: 'Initech', plan: 'Team', status: 'Past due', mrr: '$420', seats: 5, created: '2024-11-10' },
  { name: 'Umbrella', plan: 'Enterprise', status: 'Active', mrr: '$2,400', seats: 60, created: '2023-06-01' },
];

const toneFor = (s: string) =>
  ({ Active: 'success', Trialing: 'accent', 'Past due': 'danger' }[s] ?? 'accent');
---
<BaseLayout title="Data table · Porchlight">
  <h1>Data table</h1>
  <p>
    Enterprise data table with sortable headers, row selection checkboxes,
    expandable detail rows, sticky first column, density modes, and loading
    state. All features are additive CSS on the existing component.
  </p>

  <h2>Full-featured table</h2>
  <div class="pl-c-toolbar table-selection-toolbar" role="region" aria-label="Selected account actions">
    <div class="pl-c-toolbar__group">
      <strong aria-live="polite">1 account selected</strong>
      <button class="pl-c-button" data-variant="ghost" type="button">Clear selection</button>
    </div>
    <div class="pl-c-toolbar__group">
      <button class="pl-c-button" data-variant="secondary" type="button">Export selected</button>
      <button class="pl-c-button" data-variant="primary" type="button">Assign owner</button>
    </div>
  </div>
  <div class="pl-c-table-wrap" data-pl-density="comfortable">
    <table class="pl-c-table">
      <thead>
        <tr>
          <th class="pl-c-table__check">
            <input type="checkbox" aria-label="Select all" />
          </th>
          <th class="pl-c-table__sticky-col" data-sort="asc">
            Account <span class="pl-c-table__sort-icon"></span>
          </th>
          <th data-sort="desc">
            Created <span class="pl-c-table__sort-icon"></span>
          </th>
          <th>Plan</th>
          <th>Status</th>
          <th data-align="end" data-sort>
            Seats <span class="pl-c-table__sort-icon"></span>
          </th>
          <th data-align="end" data-sort>
            MRR <span class="pl-c-table__sort-icon"></span>
          </th>
          <th data-align="center"></th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r, i) => (
          <>
            <tr aria-selected={i === 0 ? 'true' : undefined}>
              <td class="pl-c-table__check">
                <input type="checkbox" checked={i === 0} aria-label={`Select ${r.name}`} />
              </td>
              <td class="pl-c-table__sticky-col">{r.name}</td>
              <td>{r.created}</td>
              <td>{r.plan}</td>
              <td>
                <span class="pl-c-badge" data-tone={toneFor(r.status)}>{r.status}</span>
              </td>
              <td data-align="end">{r.seats}</td>
              <td data-align="end">{r.mrr}</td>
              <td data-align="center">
                <button
                  class="pl-c-table__expand"
                  aria-expanded={i === 0 ? 'true' : 'false'}
                  aria-label={`Expand ${r.name}`}
                  data-expand={i}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
              </td>
            </tr>
            <tr class="pl-c-table__detail" data-open={i === 0 ? '' : undefined} data-detail={i}>
              <td colspan="99">
                <div class="pl-c-table__detail-inner">
                  <div class="pl-c-table__detail-content">
                    <div class="pl-l-grid table-detail-grid">
                      <div>
                        <p class="pl-u-muted table-detail-label">Account ID</p>
                        <p>acct_{1000 + i}</p>
                      </div>
                      <div>
                        <p class="pl-u-muted table-detail-label">Owner</p>
                        <p>{r.name.split(' ').map(w => w[0]).join('')} Admin</p>
                      </div>
                      <div>
                        <p class="pl-u-muted table-detail-label">Region</p>
                        <p>us-east-1</p>
                      </div>
                      <div>
                        <p class="pl-u-muted table-detail-label">API calls (30d)</p>
                        <p>{(r.seats * 1247).toLocaleString()}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          </>
        ))}
      </tbody>
    </table>
  </div>

  <h2>Inline edit composition</h2>
  <p>
    A read view and a real form share one app-owned state boundary. This is a
    composition recipe, not a JavaScript dependency or new field variant.
  </p>
  <section class="pl-c-card table-inline-edit" data-surface="app" aria-labelledby="inline-edit-title">
    <div class="pl-c-card__body" data-inline-edit>
      <div class="table-inline-edit__read" data-inline-edit-read>
        <div>
          <span class="pl-u-muted-sm">Workspace name</span>
          <strong id="inline-edit-title" data-inline-edit-value>Acme Operations</strong>
        </div>
        <button
          class="pl-c-button"
          data-variant="ghost"
          type="button"
          aria-controls="workspace-name-form"
          data-inline-edit-open
        >
          Edit
        </button>
      </div>
      <form id="workspace-name-form" class="pl-c-form" data-inline-edit-form hidden>
        <label class="pl-c-field">
          <span class="pl-c-field__label">Workspace name</span>
          <input class="pl-c-field__control" name="workspace" value="Acme Operations" />
        </label>
        <div class="pl-c-form__actions">
          <button class="pl-c-button" data-variant="ghost" type="button" data-inline-edit-cancel>Cancel</button>
          <button class="pl-c-button" data-variant="primary" type="submit">Save</button>
        </div>
      </form>
      <span class="pl-u-sr-only" role="status" data-inline-edit-status></span>
    </div>
  </section>

  <h2>Compact density</h2>
  <p>Same data with <code>data-pl-density="compact"</code> for tighter rows.</p>
  <div class="pl-c-table-wrap" data-pl-density="compact">
    <table class="pl-c-table table-demo-narrow">
      <thead>
        <tr>
          <th class="pl-c-table__sticky-col" data-sort="asc">
            Name <span class="pl-c-table__sort-icon"></span>
          </th>
          <th>Plan</th>
          <th data-align="end" data-sort="desc">
            Seats <span class="pl-c-table__sort-icon"></span>
          </th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <td class="pl-c-table__sticky-col">{r.name}</td>
            <td>{r.plan}</td>
            <td data-align="end">{r.seats}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>Loading state</h2>
  <p>Skeleton rows while data is fetching.</p>
  <div class="pl-c-table-wrap">
    <table class="pl-c-table table-demo-narrow">
      <thead>
        <tr>
          <th class="pl-c-table__sticky-col">Account</th>
          <th>Plan</th>
          <th data-align="end">MRR</th>
        </tr>
      </thead>
      <tbody data-loading>
        {[1, 2, 3].map(() => (
          <tr>
            <td class="pl-c-table__sticky-col"><span class="pl-c-skeleton table-skeleton-account" data-shape="text"></span></td>
            <td><span class="pl-c-skeleton table-skeleton-plan" data-shape="text"></span></td>
            <td data-align="end"><span class="pl-c-skeleton table-skeleton-mrr" data-shape="text"></span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</BaseLayout>

<script>
  // Docs-only: expand/collapse detail rows.
  document.querySelectorAll('[data-expand]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = btn.getAttribute('data-expand');
      const detail = document.querySelector(`[data-detail="${idx}"]`);
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      if (expanded) {
        detail?.removeAttribute('data-open');
      } else {
        detail?.setAttribute('data-open', '');
      }
    });
  });

  const inlineEdit = document.querySelector('[data-inline-edit]');
  if (inlineEdit instanceof HTMLElement) {
    const read = inlineEdit.querySelector('[data-inline-edit-read]');
    const form = inlineEdit.querySelector('[data-inline-edit-form]');
    const open = inlineEdit.querySelector('[data-inline-edit-open]');
    const cancel = inlineEdit.querySelector('[data-inline-edit-cancel]');
    const input = form?.querySelector('input');
    const value = inlineEdit.querySelector('[data-inline-edit-value]');
    const status = inlineEdit.querySelector('[data-inline-edit-status]');
    const originalValue = input instanceof HTMLInputElement ? input.value : '';

    const showRead = () => {
      if (read instanceof HTMLElement) read.hidden = false;
      if (form instanceof HTMLFormElement) form.hidden = true;
      if (open instanceof HTMLButtonElement) open.focus();
    };

    open?.addEventListener('click', () => {
      if (read instanceof HTMLElement) read.hidden = true;
      if (form instanceof HTMLFormElement) form.hidden = false;
      if (input instanceof HTMLInputElement) input.focus();
    });

    cancel?.addEventListener('click', () => {
      if (input instanceof HTMLInputElement) input.value = originalValue;
      showRead();
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (input instanceof HTMLInputElement && value instanceof HTMLElement) {
        value.textContent = input.value;
      }
      if (status instanceof HTMLElement) status.textContent = 'Workspace name saved.';
      showRead();
    });
  }
</script>

<style>
  .table-selection-toolbar {
    margin-block-end: var(--pl-space-3);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
  }

  .table-inline-edit {
    max-inline-size: 36rem;
  }

  .table-inline-edit__read {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--pl-space-4);
  }

  .table-inline-edit__read > div {
    display: grid;
    gap: var(--pl-space-1);
  }

  .table-detail-grid {
    --pl-l-grid-min: 12rem;
  }

  .table-detail-label {
    font-size: var(--pl-text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .table-demo-narrow {
    --pl-c-table-min: 36rem;
  }

  .table-skeleton-account {
    inline-size: 8rem;
  }

  .table-skeleton-plan {
    inline-size: 5rem;
  }

  .table-skeleton-mrr {
    inline-size: 4rem;
  }
</style>
