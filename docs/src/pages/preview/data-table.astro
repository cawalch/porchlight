---
import BaseLayout from '../../layouts/BaseLayout.astro';

const rows = [
  { name: 'Acme Ops', plan: 'Enterprise', status: 'Active', mrr: '$2,400', seats: 48, created: '2024-03-15' },
  { name: 'Northwind', plan: 'Pro', status: 'Trialing', mrr: '$980', seats: 12, created: '2024-08-02' },
  { name: 'Globex', plan: 'Pro', status: 'Active', mrr: '$980', seats: 8, created: '2024-01-22' },
  { name: 'Initech', plan: 'Team', status: 'Past due', mrr: '$420', seats: 5, created: '2024-11-10' },
  { name: 'Umbrella', plan: 'Enterprise', status: 'Active', mrr: '$2,400', seats: 60, created: '2023-06-01' },
];

const toneFor = (s: string) =>
  ({ Active: 'success', Trialing: 'accent', 'Past due': 'danger' }[s] ?? 'accent');
---
<BaseLayout title="Data table · Porchlight">
  <h1>Data table</h1>
  <p>
    Enterprise data table with sortable headers, row selection checkboxes,
    expandable detail rows, sticky first column, density modes, and loading
    state. All features are additive CSS on the existing component.
  </p>

  <h2>Full-featured table</h2>
  <div class="c-table-wrap" data-density="comfortable">
    <table class="c-table">
      <thead>
        <tr>
          <th class="c-table__check">
            <input type="checkbox" aria-label="Select all" />
          </th>
          <th class="c-table__sticky-col" data-sort="asc">
            Account <span class="c-table__sort-icon"></span>
          </th>
          <th data-sort="desc">
            Created <span class="c-table__sort-icon"></span>
          </th>
          <th>Plan</th>
          <th>Status</th>
          <th data-align="end" data-sort>
            Seats <span class="c-table__sort-icon"></span>
          </th>
          <th data-align="end" data-sort>
            MRR <span class="c-table__sort-icon"></span>
          </th>
          <th data-align="center"></th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r, i) => (
          <>
            <tr aria-selected={i === 0 ? 'true' : undefined}>
              <td class="c-table__check">
                <input type="checkbox" checked={i === 0} aria-label={`Select ${r.name}`} />
              </td>
              <td class="c-table__sticky-col">{r.name}</td>
              <td>{r.created}</td>
              <td>{r.plan}</td>
              <td>
                <span class="c-badge" data-tone={toneFor(r.status)}>{r.status}</span>
              </td>
              <td data-align="end">{r.seats}</td>
              <td data-align="end">{r.mrr}</td>
              <td data-align="center">
                <button
                  class="c-table__expand"
                  aria-expanded={i === 0 ? 'true' : 'false'}
                  aria-label={`Expand ${r.name}`}
                  data-expand={i}
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
              </td>
            </tr>
            <tr class="c-table__detail" data-open={i === 0 ? '' : undefined} data-detail={i}>
              <td colspan="99">
                <div class="c-table__detail-inner">
                  <div class="c-table__detail-content">
                    <div class="l-grid table-detail-grid">
                      <div>
                        <p class="u-muted table-detail-label">Account ID</p>
                        <p>acct_{1000 + i}</p>
                      </div>
                      <div>
                        <p class="u-muted table-detail-label">Owner</p>
                        <p>{r.name.split(' ').map(w => w[0]).join('')} Admin</p>
                      </div>
                      <div>
                        <p class="u-muted table-detail-label">Region</p>
                        <p>us-east-1</p>
                      </div>
                      <div>
                        <p class="u-muted table-detail-label">API calls (30d)</p>
                        <p>{(r.seats * 1247).toLocaleString()}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </td>
            </tr>
          </>
        ))}
      </tbody>
    </table>
  </div>

  <h2>Compact density</h2>
  <p>Same data with <code>data-density="compact"</code> for tighter rows.</p>
  <div class="c-table-wrap" data-density="compact">
    <table class="c-table table-demo-narrow">
      <thead>
        <tr>
          <th class="c-table__sticky-col" data-sort="asc">
            Name <span class="c-table__sort-icon"></span>
          </th>
          <th>Plan</th>
          <th data-align="end" data-sort="desc">
            Seats <span class="c-table__sort-icon"></span>
          </th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <td class="c-table__sticky-col">{r.name}</td>
            <td>{r.plan}</td>
            <td data-align="end">{r.seats}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>Loading state</h2>
  <p>Skeleton rows while data is fetching.</p>
  <div class="c-table-wrap">
    <table class="c-table table-demo-narrow">
      <thead>
        <tr>
          <th class="c-table__sticky-col">Account</th>
          <th>Plan</th>
          <th data-align="end">MRR</th>
        </tr>
      </thead>
      <tbody data-loading>
        {[1, 2, 3].map(() => (
          <tr>
            <td class="c-table__sticky-col"><span class="c-skeleton table-skeleton-account" data-shape="text"></span></td>
            <td><span class="c-skeleton table-skeleton-plan" data-shape="text"></span></td>
            <td data-align="end"><span class="c-skeleton table-skeleton-mrr" data-shape="text"></span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</BaseLayout>

<script>
  // Docs-only: expand/collapse detail rows.
  document.querySelectorAll('[data-expand]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = btn.getAttribute('data-expand');
      const detail = document.querySelector(`[data-detail="${idx}"]`);
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      if (expanded) {
        detail?.removeAttribute('data-open');
      } else {
        detail?.setAttribute('data-open', '');
      }
    });
  });
</script>

<style>
  .table-detail-grid {
    --l-grid-min: 12rem;
  }

  .table-detail-label {
    font-size: var(--pl-text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .table-demo-narrow {
    --c-table-min: 36rem;
  }

  .table-skeleton-account {
    inline-size: 8rem;
  }

  .table-skeleton-plan {
    inline-size: 5rem;
  }

  .table-skeleton-mrr {
    inline-size: 4rem;
  }
</style>
