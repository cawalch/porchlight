---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sections = [
  ['General', true],
  ['Team', false],
  ['Billing', false],
  ['Integrations', false],
  ['Security', false],
  ['Audit log', false],
] as const;
---
<BaseLayout title="Settings · Porchlight">
  <h1>Settings</h1>
  <p>
    A SaaS settings page composing sidebar navigation, tabs, form fields,
    alerts, and progress — the other canonical enterprise layout (after the
    dashboard). Demonstrates the master-detail pattern and form density.
  </p>

  <div class="settings-layout">
    <!-- Sidebar nav -->
    <nav class="settings-nav" aria-label="Settings sections">
      {sections.map(([label, active]) => (
        <a href="#" class="settings-nav__item" aria-current={active ? 'page' : undefined}>{label}</a>
      ))}
    </nav>

    <!-- Main settings area -->
    <div class="settings-main">
      <!-- Alert banner -->
      <div class="pl-c-alert" data-tone="warning">
        <div class="pl-c-alert__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" stroke-linejoin="round" /></svg>
        </div>
        <div class="pl-c-alert__content">
          <div class="pl-c-alert__title">Plan changes pending</div>
          <div class="pl-c-alert__body">Your plan upgrade to Enterprise takes effect on the next billing cycle.</div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="pl-c-tabs">
        <div class="pl-c-tabs__list" role="tablist" aria-label="Workspace settings">
          <button type="button" class="pl-c-tabs__tab" role="tab" aria-selected="true">Profile</button>
          <button type="button" class="pl-c-tabs__tab" role="tab" aria-selected="false" tabindex="-1">Preferences</button>
          <button type="button" class="pl-c-tabs__tab" role="tab" aria-selected="false" tabindex="-1">Danger zone</button>
        </div>

        <!-- Profile tab -->
        <div class="pl-c-tabs__panel" role="tabpanel">
          <div class="pl-c-card">
            <div class="pl-c-card__header">
              <h2 class="pl-c-card__title">Workspace profile</h2>
            </div>
            <div class="pl-c-card__body">
              <div class="pl-l-stack">
                <div class="form-row">
                  <div class="pl-c-avatar" data-size="lg">AO</div>
                  <div class="pl-l-cluster">
                    <button class="pl-c-button" data-variant="secondary">Upload logo</button>
                    <button class="pl-c-button" data-variant="ghost">Remove</button>
                  </div>
                </div>

                <label class="pl-c-field">
                  <span class="pl-c-field__label">Workspace name</span>
                  <input class="pl-c-field__control" value="Acme Ops" />
                  <span class="pl-c-field__hint">Visible to all team members.</span>
                </label>

                <label class="pl-c-field">
                  <span class="pl-c-field__label">Workspace URL</span>
                  <input class="pl-c-field__control" type="url" value="https://acme-ops.porchlight.app" />
                </label>

                <label class="pl-c-field">
                  <span class="pl-c-field__label">Default timezone</span>
                  <select class="pl-c-field__control">
                    <option>America/New_York (UTC-5)</option>
                    <option>Europe/London (UTC+0)</option>
                    <option>Asia/Tokyo (UTC+9)</option>
                  </select>
                </label>
              </div>
            </div>
            <div class="pl-c-card__footer">
              <button class="pl-c-button" data-variant="ghost">Cancel</button>
              <button class="pl-c-button" data-variant="primary">Save changes</button>
            </div>
          </div>

          <!-- Storage usage card -->
          <div class="pl-c-card" style="margin-block-start: var(--pl-space-4);">
            <div class="pl-c-card__header">
              <h2 class="pl-c-card__title">Storage</h2>
              <span class="pl-c-badge" data-tone="warning">64% used</span>
            </div>
            <div class="pl-c-card__body">
              <div class="pl-l-stack">
                <div class="pl-c-progress" data-tone="warning">
                  <div class="pl-c-progress__bar" style="inline-size: 64%;"></div>
                </div>
                <p class="pl-u-muted">128 GB of 200 GB used. <a href="#">Upgrade plan</a> for more storage.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Docs-only tab switching.
  document.querySelectorAll('.settings-main .pl-c-tabs').forEach((group) => {
    const tabs = group.querySelectorAll('.pl-c-tabs__tab');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => {
          const selected = t === tab;
          t.setAttribute('aria-selected', String(selected));
          t.setAttribute('tabindex', selected ? '0' : '-1');
        });
      });
    });
  });
</script>

<style>
  .settings-layout {
    display: grid;
    grid-template-columns: minmax(0, 12rem) minmax(0, 1fr);
    gap: var(--pl-space-5);
    align-items: start;
  }
  .settings-nav {
    display: flex;
    flex-direction: column;
    gap: var(--pl-space-1);
    position: sticky;
    inset-block-start: var(--pl-space-4);
  }
  .settings-nav__item {
    padding: var(--pl-space-2) var(--pl-space-3);
    border-radius: var(--pl-radius-md);
    color: var(--pl-color-text-muted);
    text-decoration: none;
    font-size: var(--pl-text-sm);
    font-weight: 500;
  }
  .settings-nav__item:hover {
    background: var(--pl-color-surface-2);
    color: var(--pl-color-text);
  }
  .settings-nav__item[aria-current='page'] {
    background: var(--pl-color-surface-2);
    color: var(--pl-color-accent);
    font-weight: 600;
  }
  .form-row {
    display: flex;
    align-items: center;
    gap: var(--pl-space-3);
  }
  @media (width < 40rem) {
    .settings-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
