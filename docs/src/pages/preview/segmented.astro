---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Segmented · Porchlight">
  <h1>Segmented control</h1>
  <p>
    A compact inline switcher for binary/ternary toggles. Built on native radio
    inputs: CSS-only, keyboard accessible. Active segment gets accent styling
    via <code>:has(:checked)</code>.
  </p>

  <h2>View mode</h2>
  <div class="c-segmented" role="radiogroup" aria-label="View mode">
    <label class="c-segmented__item">
      <input type="radio" name="view" checked />
      <span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="inline-size: 0.875rem; block-size: 0.875rem;"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke-linecap="round" /></svg>
        List
      </span>
    </label>
    <label class="c-segmented__item">
      <input type="radio" name="view" />
      <span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="inline-size: 0.875rem; block-size: 0.875rem;"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
        Grid
      </span>
    </label>
    <label class="c-segmented__item">
      <input type="radio" name="view" />
      <span>Table</span>
    </label>
  </div>

  <h2>Time range</h2>
  <div class="c-segmented" role="radiogroup" aria-label="Time range">
    <label class="c-segmented__item"><input type="radio" name="range" /><span>Day</span></label>
    <label class="c-segmented__item"><input type="radio" name="range" checked /><span>Week</span></label>
    <label class="c-segmented__item"><input type="radio" name="range" /><span>Month</span></label>
    <label class="c-segmented__item"><input type="radio" name="range" /><span>Year</span></label>
  </div>

  <h2>Disabled option</h2>
  <div class="c-segmented" role="radiogroup" aria-label="Status">
    <label class="c-segmented__item"><input type="radio" name="status" checked /><span>All</span></label>
    <label class="c-segmented__item"><input type="radio" name="status" /><span>Active</span></label>
    <label class="c-segmented__item"><input type="radio" name="status" disabled /><span>Archived</span></label>
  </div>
</BaseLayout>
