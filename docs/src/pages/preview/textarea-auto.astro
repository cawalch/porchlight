---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Auto-Growing Textarea · Porchlight">
  <h1>Auto-Growing Textarea</h1>
  <p>
    A textarea that grows to fit its content automatically using
    <code>field-sizing: content</code>. No JavaScript auto-resize needed.
    Falls back to a fixed <code>rows</code> height without support.
  </p>

  <h2>Basic</h2>
  <label class="pl-c-field">
    <span class="pl-c-field__label">Comment</span>
    <textarea class="pl-c-textarea-auto" rows="2" placeholder="Type here... the textarea grows as you type."></textarea>
    <span class="pl-c-field__hint">Grows automatically with content (Chrome 123+).</span>
  </label>

  <h2>With max height</h2>
  <label class="pl-c-field">
    <span class="pl-c-field__label">Description</span>
    <textarea class="pl-c-textarea-auto" rows="3" style="--pl-c-textarea-max-block: 8rem;" placeholder="Grows up to 8rem, then scrolls."></textarea>
  </label>

  <h2>Disabled</h2>
  <label class="pl-c-field">
    <span class="pl-c-field__label">Read-only notes</span>
    <textarea class="pl-c-textarea-auto" rows="2" disabled>This textarea is disabled.</textarea>
  </label>
</BaseLayout>
