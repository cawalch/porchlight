---
import BaseLayout from '../../layouts/BaseLayout.astro';

const requests = [
  {
    id: 'REQ-2418',
    title: 'Vendor onboarding',
    owner: 'Maya Singh',
    team: 'Procurement',
    status: 'Review',
    tone: 'warning',
    priority: 'High',
    due: 'Today',
    age: '42m',
    summary: 'Security review is waiting on the SOC 2 packet before finance can approve the vendor.',
    next: 'Request missing security packet',
  },
  {
    id: 'REQ-2411',
    title: 'Access exception',
    owner: 'Owen Reed',
    team: 'IT Ops',
    status: 'Blocked',
    tone: 'danger',
    priority: 'Critical',
    due: 'Today',
    age: '1h',
    summary: 'Admin access is blocked until the manager attestation and ticket evidence match.',
    next: 'Escalate to identity owner',
  },
  {
    id: 'REQ-2406',
    title: 'Renewal approval',
    owner: 'Nora Park',
    team: 'Finance',
    status: 'Active',
    tone: 'accent',
    priority: 'Normal',
    due: 'Tomorrow',
    age: '3h',
    summary: 'Contract value changed after legal redlines; finance review is in progress.',
    next: 'Confirm updated spend cap',
  },
  {
    id: 'REQ-2399',
    title: 'Policy exception',
    owner: 'Eli Torres',
    team: 'Legal',
    status: 'Approved',
    tone: 'success',
    priority: 'Normal',
    due: 'Fri',
    age: '1d',
    summary: 'The exception was approved with a quarterly recertification requirement.',
    next: 'Send approval summary',
  },
];

const selected = requests[0];
---

<BaseLayout title="List/detail workspace · Porchlight">
  <div class="l-app-shell list-detail-shell">
    <header class="l-app-shell__topbar c-toolbar" data-surface="panel">
      <div class="c-toolbar__group">
        <button class="c-button" data-variant="ghost" data-size="sm" type="button" aria-label="Toggle navigation">
          <svg class="list-detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"></path>
          </svg>
        </button>
        <strong>Porchlight Ops</strong>
        <span class="c-badge" data-tone="success">Live</span>
      </div>
      <div class="c-toolbar__group">
        <button class="c-button" data-variant="ghost" data-size="sm" type="button" popovertarget="workspace-command" aria-label="Open command palette">
          <svg class="list-detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
          <span class="u-muted">Cmd+K</span>
        </button>
        <div class="c-avatar" data-size="sm">MS</div>
      </div>
    </header>

    <aside class="l-app-shell__sidebar">
      <nav class="c-nav" aria-label="Primary">
        <div class="c-nav__group">
          <span class="c-nav__group-label">Operations</span>
          <a href="#" class="c-nav__item" aria-current="page">
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M8 6h13"></path>
              <path d="M8 12h13"></path>
              <path d="M8 18h13"></path>
              <path d="M3 6h.01"></path>
              <path d="M3 12h.01"></path>
              <path d="M3 18h.01"></path>
            </svg>
            <span class="c-nav__label">Queue</span>
            <span class="c-badge c-nav__badge" data-tone="accent">18</span>
          </a>
          <a href="#" class="c-nav__item">
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 3v18h18"></path>
              <path d="m7 14 4-4 4 4 5-6"></path>
            </svg>
            <span class="c-nav__label">Reports</span>
          </a>
          <a href="#" class="c-nav__item">
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 20h9"></path>
              <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
            </svg>
            <span class="c-nav__label">Drafts</span>
          </a>
        </div>
        <hr class="c-nav__divider" />
        <div class="c-nav__footer">
          <div class="c-nav__meta">
            <span class="c-nav__meta-icon">PL</span>
            <span class="c-nav__meta-body">
              <span class="c-nav__meta-label">porchlight-ops@example.test</span>
              <span class="c-nav__meta-description">Admin workspace</span>
            </span>
          </div>
        </div>
      </nav>
    </aside>

    <main class="l-app-shell__main">
      <div class="l-container l-stack list-detail-workspace">
        <div class="c-page-header">
          <div class="c-page-header__heading">
            <h1 class="c-page-header__title">Operator queue</h1>
            <span class="c-page-header__subtitle">Triage active requests without leaving the list.</span>
          </div>
          <div class="c-page-header__actions">
            <button class="c-button" data-variant="secondary" type="button" popovertarget="queue-filters">Filters</button>
            <button class="c-button" data-variant="primary" type="button">Assign next</button>
          </div>
        </div>

        <section
          class="c-split-pane list-detail-split"
          data-orientation="horizontal"
          data-collapse="stack"
          aria-label="Request list and selected detail"
        >
          <section class="c-split-pane__pane c-split-pane__pane--start" aria-label="Request queue">
            <header class="c-split-pane__header">
              <div>
                <h2 class="c-split-pane__title">Requests</h2>
                <p class="c-split-pane__description" data-result-count>{requests.length} open requests</p>
              </div>
              <span class="c-badge" data-tone="warning">3 SLA risks</span>
            </header>

            <div class="c-split-pane__pane-inner list-detail-list-body">
              <div class="c-toolbar" data-surface="flush">
                <div class="c-toolbar__group">
                  <label class="c-field">
                    <span class="u-sr-only">Search requests</span>
                    <input class="c-field__control" type="search" placeholder="Search requests" data-request-search />
                  </label>
                  <select class="c-field__control" aria-label="Priority filter">
                    <option>All priorities</option>
                    <option>Critical</option>
                    <option>High</option>
                    <option>Normal</option>
                  </select>
                </div>
                <div class="c-toolbar__group">
                  <div class="c-toolbar__divider"></div>
                  <button class="c-button" data-variant="ghost" data-size="sm" type="button">Export</button>
                  <button class="c-button" data-variant="secondary" data-size="sm" type="button">Bulk edit</button>
                </div>
              </div>

              <div class="c-table-wrap list-detail-table" data-density="compact" data-overflow="truncate">
                <table class="c-table">
                  <thead>
                    <tr>
                      <th class="c-table__check">
                        <input type="checkbox" aria-label="Select all requests" />
                      </th>
                      <th class="c-table__sticky-col" data-sort="asc">Request <span class="c-table__sort-icon"></span></th>
                      <th>Owner</th>
                      <th>Status</th>
                      <th>Priority</th>
                      <th data-align="end" data-sort>Due <span class="c-table__sort-icon"></span></th>
                    </tr>
                  </thead>
                  <tbody data-request-rows>
                    {requests.map((request, index) => (
                      <tr
                        aria-selected={index === 0 ? 'true' : undefined}
                        data-request-row
                        data-request-id={request.id}
                        data-request-title={request.title}
                        data-request-owner={request.owner}
                        data-request-team={request.team}
                        data-request-status={request.status}
                        data-request-tone={request.tone}
                        data-request-priority={request.priority}
                        data-request-due={request.due}
                        data-request-age={request.age}
                        data-request-summary={request.summary}
                        data-request-next={request.next}
                      >
                        <td class="c-table__check">
                          <input type="checkbox" checked={index === 0} aria-label={`Select ${request.id}`} />
                        </td>
                        <td class="c-table__sticky-col">
                          <button class="c-button" data-variant="ghost" data-size="sm" type="button" data-select-request>
                            {request.id}
                          </button>
                          <span class="u-muted-sm u-truncate">{request.title}</span>
                        </td>
                        <td>{request.owner}</td>
                        <td><span class="c-badge" data-tone={request.tone}>{request.status}</span></td>
                        <td>{request.priority}</td>
                        <td data-align="end">{request.due}</td>
                      </tr>
                    ))}
                    <tr data-empty-row hidden>
                      <td colspan="6">
                        <div class="c-empty">
                          <h3 class="c-empty__title">No matching requests</h3>
                          <p class="c-empty__description">Clear search or adjust filters to bring the queue back.</p>
                        </div>
                      </td>
                    </tr>
                    <tr data-loading>
                      <td class="c-table__check"><span class="c-skeleton list-detail-skeleton-check" data-shape="circle"></span></td>
                      <td class="c-table__sticky-col"><span class="c-skeleton list-detail-skeleton-request" data-shape="text"></span></td>
                      <td><span class="c-skeleton list-detail-skeleton-owner" data-shape="text"></span></td>
                      <td><span class="c-skeleton list-detail-skeleton-status" data-shape="text"></span></td>
                      <td><span class="c-skeleton list-detail-skeleton-priority" data-shape="text"></span></td>
                      <td data-align="end"><span class="c-skeleton list-detail-skeleton-due" data-shape="text"></span></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <div
            class="c-split-pane__separator"
            role="separator"
            aria-orientation="vertical"
            aria-valuemin="42"
            aria-valuemax="72"
            aria-valuenow="62"
            aria-label="Resize request detail pane"
            tabindex="0"
          ></div>

          <aside class="c-split-pane__pane c-split-pane__pane--end" aria-label="Selected request detail" tabindex="0">
            <header class="c-split-pane__header">
              <div>
                <h2 class="c-split-pane__title" data-detail-title>{selected.id}</h2>
                <p class="c-split-pane__description" data-detail-subtitle>{selected.title}</p>
              </div>
              <span class="c-badge" data-tone={selected.tone} data-detail-status>{selected.status}</span>
            </header>

            <div class="c-split-pane__pane-inner l-stack list-detail-content-stack" data-detail-content>
              <section class="c-card" data-surface="app">
                <div class="c-card__header">
                  <h3 class="c-card__title">Summary</h3>
                  <span class="c-badge" data-detail-priority>{selected.priority}</span>
                </div>
                <div class="c-card__body">
                  <p class="u-marginless" data-detail-summary>{selected.summary}</p>
                </div>
              </section>

              <dl class="c-description" data-layout="stacked" data-dividers>
                <div class="c-description__row">
                  <dt class="c-description__term">Owner</dt>
                  <dd class="c-description__detail" data-detail-owner>{selected.owner}</dd>
                </div>
                <div class="c-description__row">
                  <dt class="c-description__term">Team</dt>
                  <dd class="c-description__detail" data-detail-team>{selected.team}</dd>
                </div>
                <div class="c-description__row">
                  <dt class="c-description__term">Due</dt>
                  <dd class="c-description__detail" data-detail-due>{selected.due}</dd>
                </div>
                <div class="c-description__row">
                  <dt class="c-description__term">Age</dt>
                  <dd class="c-description__detail" data-detail-age>{selected.age}</dd>
                </div>
              </dl>

              <section class="c-card" data-surface="app">
                <div class="c-card__header">
                  <h3 class="c-card__title">Next step</h3>
                  <span class="c-badge" data-tone="accent">Suggested</span>
                </div>
                <div class="c-card__body">
                  <p class="u-marginless" data-detail-next>{selected.next}</p>
                </div>
                <div class="c-card__footer">
                  <button class="c-button" data-variant="ghost" type="button">Snooze</button>
                  <button class="c-button" data-variant="primary" type="button">Assign</button>
                </div>
              </section>

              <section class="c-card" data-surface="app" aria-label="Enrichment loading">
                <div class="c-card__header">
                  <h3 class="c-card__title">Evidence sync</h3>
                  <span class="c-badge">Loading</span>
                </div>
                <div class="c-card__body c-skeleton-group" data-lines="3">
                  <span class="c-skeleton" data-shape="text"></span>
                  <span class="c-skeleton" data-shape="text"></span>
                  <span class="c-skeleton" data-shape="text"></span>
                </div>
              </section>
            </div>

            <div class="c-split-pane__pane-inner" data-detail-empty hidden>
              <div class="c-empty">
                <div class="c-empty__media" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M8 6h13"></path>
                    <path d="M8 12h13"></path>
                    <path d="M8 18h13"></path>
                    <path d="M3 6h.01"></path>
                    <path d="M3 12h.01"></path>
                    <path d="M3 18h.01"></path>
                  </svg>
                </div>
                <h3 class="c-empty__title">Select a request</h3>
                <p class="c-empty__description">Choose a row to inspect ownership, status, and recommended actions.</p>
              </div>
            </div>
          </aside>
        </section>
      </div>
    </main>
  </div>

  <div popover class="c-drawer" id="queue-filters" data-side="end">
    <div class="c-drawer__header">
      <h2 class="c-drawer__title">Queue filters</h2>
      <button class="c-button" data-variant="ghost" data-size="sm" type="button" popovertarget="queue-filters" aria-label="Close filters">Close</button>
    </div>
    <div class="c-drawer__body l-stack">
      <label class="c-field">
        <span class="c-field__label">Team</span>
        <select class="c-field__control">
          <option>All teams</option>
          <option>Finance</option>
          <option>IT Ops</option>
          <option>Legal</option>
        </select>
      </label>
      <label class="c-field">
        <span class="c-field__label">Due window</span>
        <select class="c-field__control">
          <option>Any time</option>
          <option>Today</option>
          <option>This week</option>
        </select>
      </label>
      <label class="c-field">
        <span class="c-field__label">Status</span>
        <select class="c-field__control">
          <option>Any status</option>
          <option>Active</option>
          <option>Blocked</option>
          <option>Review</option>
        </select>
      </label>
    </div>
    <div class="c-drawer__footer">
      <button class="c-button" data-variant="ghost" type="button" popovertarget="queue-filters">Reset</button>
      <button class="c-button" data-variant="primary" type="button" popovertarget="queue-filters">Apply</button>
    </div>
  </div>

  <div popover class="c-command" id="workspace-command" role="dialog" aria-label="Command palette">
    <input class="c-command__search" placeholder="Search commands" aria-label="Search commands" />
    <div class="c-command__body" role="listbox">
      <div class="c-command__group">
        <h3 class="c-command__heading">Queue</h3>
        <button class="c-command__item" type="button" data-selected><span>Assign selected request</span><kbd class="c-command__shortcut">A</kbd></button>
        <button class="c-command__item" type="button"><span>Open filters</span><kbd class="c-command__shortcut">F</kbd></button>
        <button class="c-command__item" type="button"><span>Create request</span><kbd class="c-command__shortcut">N</kbd></button>
      </div>
    </div>
    <footer class="c-command__footer"><span>Esc closes</span><span>Enter runs</span></footer>
  </div>

  <script>
    const required = (selector: string) => {
      const element = document.querySelector(selector);
      if (!(element instanceof HTMLElement)) {
        throw new Error(`Missing ${selector}`);
      }
      return element;
    };

    const rows = Array.from(document.querySelectorAll('[data-request-row]')).filter(
      (row): row is HTMLTableRowElement => row instanceof HTMLTableRowElement,
    );
    const search = required('[data-request-search]');
    const emptyRow = required('[data-empty-row]');
    const count = required('[data-result-count]');
    const detailContent = required('[data-detail-content]');
    const detailEmpty = required('[data-detail-empty]');

    const fields = {
      title: required('[data-detail-title]'),
      subtitle: required('[data-detail-subtitle]'),
      status: required('[data-detail-status]'),
      priority: required('[data-detail-priority]'),
      owner: required('[data-detail-owner]'),
      team: required('[data-detail-team]'),
      due: required('[data-detail-due]'),
      age: required('[data-detail-age]'),
      summary: required('[data-detail-summary]'),
      next: required('[data-detail-next]'),
    };

    function selectRow(row: HTMLTableRowElement) {
      const data = row.dataset;
      rows.forEach((candidate) => candidate.removeAttribute('aria-selected'));
      row.setAttribute('aria-selected', 'true');
      fields.title.textContent = data.requestId ?? '';
      fields.subtitle.textContent = data.requestTitle ?? '';
      fields.status.textContent = data.requestStatus ?? '';
      fields.status.setAttribute('data-tone', data.requestTone ?? 'accent');
      fields.priority.textContent = data.requestPriority ?? '';
      fields.owner.textContent = data.requestOwner ?? '';
      fields.team.textContent = data.requestTeam ?? '';
      fields.due.textContent = data.requestDue ?? '';
      fields.age.textContent = data.requestAge ?? '';
      fields.summary.textContent = data.requestSummary ?? '';
      fields.next.textContent = data.requestNext ?? '';
      detailContent.hidden = false;
      detailEmpty.hidden = true;
    }

    rows.forEach((row) => {
      row.querySelector('[data-select-request]')?.addEventListener('click', () => selectRow(row));
    });

    search?.addEventListener('input', () => {
      const query = search instanceof HTMLInputElement ? search.value.trim().toLowerCase() : '';
      let visible = 0;

      rows.forEach((row) => {
        const text = [
          row.dataset.requestId,
          row.dataset.requestTitle,
          row.dataset.requestOwner,
          row.dataset.requestTeam,
          row.dataset.requestStatus,
        ].join(' ').toLowerCase();
        const match = text.includes(query);
        row.hidden = !match;
        if (match) visible += 1;
      });

      emptyRow.hidden = visible > 0;
      count.textContent = `${visible} open ${visible === 1 ? 'request' : 'requests'}`;

      const selectedVisible = rows.some((row) => row.getAttribute('aria-selected') === 'true' && !row.hidden);
      detailContent.hidden = !selectedVisible;
      detailEmpty.hidden = selectedVisible;
    });

    document.addEventListener('keydown', (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
        event.preventDefault();
        document.getElementById('workspace-command')?.showPopover();
      }
    });
  </script>
</BaseLayout>

<style>
  .list-detail-shell > .l-app-shell__topbar {
    position: static;
    z-index: auto;
  }

  .list-detail-workspace {
    --l-container-max: 104rem;
    --l-container-pad: clamp(var(--pl-space-4), 2vi, var(--pl-space-6));
    --l-stack-gap: var(--pl-space-5);

    padding-block: var(--pl-space-5);
  }

  .list-detail-icon {
    inline-size: 1.125rem;
    block-size: 1.125rem;
  }

  .list-detail-split {
    --c-split-pane-start-size: minmax(38rem, 1.45fr);
    --c-split-pane-end-size: minmax(20rem, 0.8fr);
    --c-split-pane-min-block-size: 38rem;
    --c-split-pane-pane-padding: var(--pl-space-5);
  }

  .list-detail-split > .c-split-pane__pane {
    overflow: visible;
    overscroll-behavior: auto;
    scrollbar-gutter: auto;
  }

  .list-detail-list-body {
    display: grid;
    gap: var(--pl-space-3);
  }

  .list-detail-list-body > .c-toolbar {
    padding: 0;
  }

  .list-detail-table {
    --c-table-min: 40rem;
  }

  .list-detail-content-stack {
    --l-stack-gap: var(--pl-space-4);
  }

  .list-detail-skeleton-check {
    inline-size: 1rem;
    block-size: 1rem;
  }

  .list-detail-skeleton-request {
    inline-size: 11rem;
  }

  .list-detail-skeleton-owner {
    inline-size: 7rem;
  }

  .list-detail-skeleton-status {
    inline-size: 5rem;
  }

  .list-detail-skeleton-priority {
    inline-size: 4rem;
  }

  .list-detail-skeleton-due {
    inline-size: 3rem;
  }

  @container c-table-wrap (inline-size < 48rem) {
    .list-detail-table .c-table :where(th, td):nth-child(6) {
      display: none;
    }
  }

  @container (inline-size < 60rem) {
    .list-detail-split {
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows:
        minmax(16rem, auto)
        var(--c-split-pane-separator-size)
        minmax(20rem, 1fr);
      overflow: visible;
    }

    .list-detail-split > .c-split-pane__pane--start {
      grid-area: 1 / 1;
    }

    .list-detail-split > .c-split-pane__pane--end {
      grid-area: 3 / 1;
    }

    .list-detail-split > .c-split-pane__separator {
      grid-area: 2 / 1;
      cursor: row-resize;
    }

    .list-detail-split > .c-split-pane__separator::before {
      inline-size: 100%;
      block-size: var(--c-split-pane-separator-line-size);
    }

    .list-detail-split > .c-split-pane__separator::after {
      inline-size: 2rem;
      block-size: 0.1875rem;
    }
  }

  @media (width < 42rem) {
    .list-detail-workspace {
      --l-container-pad: var(--pl-space-3);
      --l-stack-gap: var(--pl-space-4);

      padding-block: var(--pl-space-3);
    }

    .list-detail-split {
      --c-split-pane-min-block-size: 0;
      --c-split-pane-pane-padding: var(--pl-space-4);
    }

    .list-detail-table {
      --c-table-min: 100%;
    }
  }
</style>
