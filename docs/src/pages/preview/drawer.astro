---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Drawer · Porchlight">
  <h1>Drawer</h1>
  <p>
    An off-canvas slide-over panel using the Popover API (top-layer,
    light-dismiss) with <code>@starting-style</code> for smooth enter/exit.
    Slides from <code>[data-side="start"]</code> (left in LTR) or
    <code>[data-side="end"]</code> (right in LTR).
  </p>

  <h2>End side (default)</h2>
  <button class="pl-c-button" data-variant="primary" popovertarget="drawer-end">
    Open end drawer
  </button>

  <div popover class="pl-c-drawer" id="drawer-end" data-side="end">
    <div class="pl-c-drawer__header">
      <h2 class="pl-c-drawer__title">Filters</h2>
      <button class="pl-c-button" data-variant="ghost" data-size="sm" popovertarget="drawer-end" aria-label="Close">
        <svg class="drawer-demo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false"><path d="M18 6 6 18M6 6l12 12" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="pl-c-drawer__body">
      <div class="pl-l-stack">
        <label class="pl-c-field">
          <span class="pl-c-field__label">Status</span>
          <select class="pl-c-field__control">
            <option>All</option>
            <option>Open</option>
            <option>Closed</option>
          </select>
        </label>
        <label class="pl-c-field">
          <span class="pl-c-field__label">Assignee</span>
          <select class="pl-c-field__control">
            <option>Anyone</option>
            <option>Me</option>
            <option>My team</option>
          </select>
        </label>
        <label class="pl-c-switch">
          <input type="checkbox" role="switch" class="pl-c-switch__input" />
          <span class="pl-c-switch__track"><span class="pl-c-switch__thumb"></span></span>
          <span class="pl-c-switch__label">Has attachments</span>
        </label>
      </div>
    </div>
    <div class="pl-c-drawer__footer">
      <button class="pl-c-button" data-variant="ghost" popovertarget="drawer-end">Cancel</button>
      <button class="pl-c-button" data-variant="primary" popovertarget="drawer-end">Apply</button>
    </div>
  </div>

  <h2>Start side</h2>
  <button class="pl-c-button" data-variant="secondary" popovertarget="drawer-start">
    Open start drawer
  </button>

  <div popover class="pl-c-drawer" id="drawer-start" data-side="start">
    <div class="pl-c-drawer__header">
      <h2 class="pl-c-drawer__title">Navigation</h2>
      <button class="pl-c-button" data-variant="ghost" data-size="sm" popovertarget="drawer-start" aria-label="Close">
        <svg class="drawer-demo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false"><path d="M18 6 6 18M6 6l12 12" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="pl-c-drawer__body">
      <nav class="drawer-demo-nav" aria-label="Sections">
        <a class="drawer-demo-nav-link is-active" href="#">Dashboard</a>
        <a class="drawer-demo-nav-link" href="#">Projects</a>
        <a class="drawer-demo-nav-link" href="#">Team</a>
        <a class="drawer-demo-nav-link" href="#">Settings</a>
      </nav>
    </div>
  </div>
</BaseLayout>

<style>
  .drawer-demo-icon {
    inline-size: 1rem;
    block-size: 1rem;
  }

  .drawer-demo-nav {
    display: flex;
    flex-direction: column;
    gap: var(--pl-space-2);
  }

  .drawer-demo-nav-link {
    padding: var(--pl-space-2) var(--pl-space-3);
    color: var(--pl-color-text-muted);
    text-decoration: none;
  }

  .drawer-demo-nav-link.is-active {
    color: var(--pl-color-accent);
    font-weight: 600;
  }
</style>
