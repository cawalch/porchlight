---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Tag Input · Porchlight">
  <h1>Tag input</h1>
  <p>
    A text input that converts typed values into removable chips. The CSS
    handles the layout (wrapping chips + inline input); JS handles
    tokenization. Auto-grows via <code>field-sizing: content</code> where
    supported.
  </p>

  <h2>Basic</h2>
  <div class="pl-c-field">
    <label class="pl-c-field__label" for="skills">Skills</label>
    <div class="pl-c-tag-input">
      <span class="pl-c-chip" data-tone="success">TypeScript <button class="pl-c-chip__remove" aria-label="Remove TypeScript">x</button></span>
      <span class="pl-c-chip" data-tone="success">React <button class="pl-c-chip__remove" aria-label="Remove React">x</button></span>
      <span class="pl-c-chip" data-tone="success">CSS <button class="pl-c-chip__remove" aria-label="Remove CSS">x</button></span>
      <input id="skills" class="pl-c-tag-input__field" placeholder="Add a skill..." />
    </div>
  </div>

  <h2>Empty</h2>
  <div class="pl-c-field">
    <label class="pl-c-field__label" for="email-recipients">Email recipients</label>
    <div class="pl-c-tag-input">
      <input id="email-recipients" class="pl-c-tag-input__field" type="email" placeholder="Type an email and press Enter..." />
    </div>
  </div>

  <h2>In a form</h2>
  <div class="pl-l-stack" style="--pl-l-stack-gap: var(--pl-space-3); max-inline-size: 30rem;">
    <div class="pl-c-field">
      <label class="pl-c-field__label" for="product-tags">Product tags</label>
      <div class="pl-c-tag-input">
        <span class="pl-c-chip">featured <button class="pl-c-chip__remove" aria-label="Remove featured">x</button></span>
        <span class="pl-c-chip">new <button class="pl-c-chip__remove" aria-label="Remove new">x</button></span>
        <span class="pl-c-chip" data-tone="warning">limited <button class="pl-c-chip__remove" aria-label="Remove limited">x</button></span>
        <input id="product-tags" class="pl-c-tag-input__field" placeholder="Add tag..." aria-describedby="product-tags-help" />
      </div>
      <span class="pl-c-field__hint" id="product-tags-help">Press Enter or comma to add a tag.</span>
    </div>
  </div>
</BaseLayout>
