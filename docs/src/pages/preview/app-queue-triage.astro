---
import BaseLayout from '../../layouts/BaseLayout.astro';

type QueueTone = 'danger' | 'warning' | 'accent' | 'success' | 'default';

type QueueItem = {
  id: string;
  account: string;
  title: string;
  channel: string;
  priority: string;
  priorityTone: QueueTone;
  sla: string;
  slaTone: QueueTone;
  status: string;
  statusTone: QueueTone;
  owner: string;
  wait: string;
  selected?: boolean;
};

type Lane = {
  title: string;
  count: number;
  wip: string;
  state?: 'warning' | 'danger';
  cards: QueueItem[];
};

const queueItems: QueueItem[] = [
  {
    id: 'Q-4182',
    account: 'Northstar Bank',
    title: 'Wire transfer blocked by sanctions review',
    channel: 'Treasury',
    priority: 'P0',
    priorityTone: 'danger',
    sla: '12m left',
    slaTone: 'danger',
    status: 'Triage',
    statusTone: 'warning',
    owner: 'AR',
    wait: '43m',
    selected: true,
  },
  {
    id: 'Q-4179',
    account: 'Ridge Health',
    title: 'Clinical export stalled after nightly job',
    channel: 'Data ops',
    priority: 'P1',
    priorityTone: 'warning',
    sla: '28m left',
    slaTone: 'warning',
    status: 'Investigating',
    statusTone: 'accent',
    owner: 'MC',
    wait: '31m',
  },
  {
    id: 'Q-4176',
    account: 'Metro Transit',
    title: 'Fare dispute queue above capacity',
    channel: 'Support',
    priority: 'P2',
    priorityTone: 'accent',
    sla: '1h 10m',
    slaTone: 'accent',
    status: 'Assigned',
    statusTone: 'accent',
    owner: 'JP',
    wait: '24m',
  },
  {
    id: 'Q-4168',
    account: 'Atlas Retail',
    title: 'Refund approval requires supervisor review',
    channel: 'Payments',
    priority: 'P2',
    priorityTone: 'accent',
    sla: '2h',
    slaTone: 'default',
    status: 'Waiting',
    statusTone: 'default',
    owner: 'SO',
    wait: '18m',
  },
  {
    id: 'Q-4159',
    account: 'Greenline Logistics',
    title: 'Address verification mismatch',
    channel: 'Onboarding',
    priority: 'P3',
    priorityTone: 'default',
    sla: 'Today',
    slaTone: 'success',
    status: 'Ready',
    statusTone: 'success',
    owner: 'TN',
    wait: '12m',
  },
];

const lanes: Lane[] = [
  { title: 'Intake', count: 9, wip: '9 / 12', state: 'warning', cards: [queueItems[0], queueItems[3]] },
  { title: 'Investigate', count: 6, wip: '6 / 8', cards: [queueItems[1], queueItems[2]] },
  { title: 'Ready', count: 4, wip: '4 / 10', cards: [queueItems[4]] },
];

const views = [
  { label: 'My queue', count: 18, current: true },
  { label: 'SLA risk', count: 7 },
  { label: 'Unassigned', count: 12 },
  { label: 'Escalated', count: 4 },
];

const timeline = [
  {
    tone: 'danger',
    title: 'SLA risk detected',
    time: '12m ago',
    body: 'The item crossed the P0 review threshold and moved to the top of triage.',
  },
  {
    tone: 'warning',
    title: 'Compliance note added',
    time: '19m ago',
    body: 'Sanctions screening returned a partial match that requires human review.',
  },
  {
    tone: 'accent',
    title: 'Assigned to A. Rivera',
    time: '31m ago',
    body: 'Auto-assigned from treasury queue ownership rules.',
  },
  {
    tone: '',
    title: 'Item created',
    time: '43m ago',
    body: 'Created from transaction monitoring alert TM-8831.',
  },
];

const selectedItem = queueItems[0];
---

<BaseLayout title="Queue triage · Porchlight">
  <div class="pl-l-app-shell" data-pl-density="compact">
    <header class="pl-l-app-shell__topbar">
      <div class="pl-c-toolbar">
        <div class="pl-c-toolbar__group">
          <button class="pl-c-button pl-c-button--icon" data-variant="ghost" aria-label="Toggle queue navigation">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"></path>
            </svg>
          </button>
          <strong>Ops queue</strong>
          <span class="pl-c-badge" data-tone="danger">3 breached</span>
          <span class="pl-c-badge" data-tone="warning">7 SLA risk</span>
        </div>
        <div class="pl-c-toolbar__group">
          <label class="pl-c-field pl-c-field--inline">
            <span class="pl-u-sr-only">Search queue</span>
            <input class="pl-c-field__control" type="search" value="priority:P0 OR sla:<30m" />
          </label>
          <button class="pl-c-button" data-variant="secondary">Refresh</button>
          <button class="pl-c-button" data-variant="primary">Assign next</button>
        </div>
      </div>
    </header>

    <aside class="pl-l-app-shell__sidebar">
      <nav class="pl-c-nav" aria-label="Queue navigation">
        <a href="#" class="pl-c-nav__item" aria-current="page">
          <svg class="pl-c-nav__icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 12h-6l-2 3h-4l-2-3H2"></path>
            <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"></path>
          </svg>
          <span class="pl-c-nav__label">Triage</span>
          <span class="pl-c-badge pl-c-nav__badge" data-tone="danger">18</span>
        </a>
        <a href="#" class="pl-c-nav__item">
          <svg class="pl-c-nav__icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 11l3 3L22 4"></path>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
          </svg>
          <span class="pl-c-nav__label">Assigned to me</span>
          <span class="pl-c-badge pl-c-nav__badge">6</span>
        </a>
        <a href="#" class="pl-c-nav__item">
          <svg class="pl-c-nav__icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <path d="M12 9v4M12 17h.01"></path>
          </svg>
          <span class="pl-c-nav__label">Escalations</span>
          <span class="pl-c-badge pl-c-nav__badge" data-tone="warning">4</span>
        </a>
        <details class="pl-c-nav__section" open>
          <summary class="pl-c-nav__section-trigger">
            <svg class="pl-c-nav__icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 3v18h18"></path>
              <rect x="7" y="13" width="3" height="5"></rect>
              <rect x="12" y="9" width="3" height="9"></rect>
              <rect x="17" y="5" width="3" height="13"></rect>
            </svg>
            <span>Channels</span>
            <svg class="pl-c-nav__chevron" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </summary>
          <a href="#" class="pl-c-nav__item pl-c-nav__item--child">
            <span class="pl-c-nav__label">Treasury</span>
            <span class="pl-c-badge pl-c-nav__badge" data-tone="danger">3</span>
          </a>
          <a href="#" class="pl-c-nav__item pl-c-nav__item--child">
            <span class="pl-c-nav__label">Data ops</span>
            <span class="pl-c-badge pl-c-nav__badge">5</span>
          </a>
          <a href="#" class="pl-c-nav__item pl-c-nav__item--child">
            <span class="pl-c-nav__label">Payments</span>
            <span class="pl-c-badge pl-c-nav__badge">8</span>
          </a>
        </details>
      </nav>
    </aside>

    <main class="pl-l-app-shell__main" aria-labelledby="queue-title">
      <div
        class="pl-c-split-pane"
        data-layout="fixed-end"
        data-collapse="stack"
        style="--pl-c-split-pane-fixed-size: 28rem;"
      >
        <section class="pl-c-split-pane__pane pl-c-split-pane__pane--start" aria-labelledby="queue-title">
          <div class="pl-c-split-pane__header">
            <div>
              <h1 class="pl-c-split-pane__title" id="queue-title">Queue triage</h1>
              <p class="pl-c-split-pane__description">43 open items · 12 unassigned · median wait 31m</p>
            </div>
          </div>
          <div class="pl-c-split-pane__pane-inner">
            <nav class="pl-c-saved-views" aria-label="Saved queue views">
              <span class="pl-c-saved-views__label">Views</span>
              <ul class="pl-c-saved-views__list">
                {views.map((view) => (
                  <li class="pl-c-saved-views__item">
                    <button class="pl-c-saved-views__button" aria-current={view.current ? 'true' : undefined}>
                      {view.label} <span class="pl-c-saved-views__count">{view.count}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </nav>

            <div class="pl-c-query-bar" role="search" aria-label="Active queue filters">
              <span class="pl-c-query-bar__label">Filters</span>
              <div class="pl-c-query-bar__chips">
                <span class="pl-c-query-chip">
                  <span class="pl-c-query-chip__field">Priority</span>
                  <span class="pl-c-query-chip__operator">is</span>
                  <span class="pl-c-query-chip__value">P0-P2</span>
                  <button class="pl-c-query-chip__remove" aria-label="Remove priority filter">x</button>
                </span>
                <span class="pl-c-query-chip">
                  <span class="pl-c-query-chip__field">SLA</span>
                  <span class="pl-c-query-chip__operator">under</span>
                  <span class="pl-c-query-chip__value">30m</span>
                  <button class="pl-c-query-chip__remove" aria-label="Remove SLA filter">x</button>
                </span>
                <span class="pl-c-query-chip">
                  <span class="pl-c-query-chip__field">Status</span>
                  <span class="pl-c-query-chip__operator">not</span>
                  <span class="pl-c-query-chip__value">Done</span>
                  <button class="pl-c-query-chip__remove" aria-label="Remove status filter">x</button>
                </span>
              </div>
              <div class="pl-c-query-bar__actions">
                <button class="pl-c-button" data-variant="ghost">Save view</button>
                <button class="pl-c-button" data-variant="secondary">Add filter</button>
              </div>
            </div>

            <div class="pl-c-toolbar" data-surface="panel">
              <div class="pl-c-toolbar__group">
                <button class="pl-c-button" data-variant="ghost" aria-pressed="true">All</button>
                <button class="pl-c-button" data-variant="ghost">P0</button>
                <button class="pl-c-button" data-variant="ghost">Breached</button>
                <button class="pl-c-button" data-variant="ghost">Unowned</button>
              </div>
              <div class="pl-c-toolbar__group">
                <div class="pl-c-toolbar__divider"></div>
                <button class="pl-c-button" data-variant="secondary">Bulk assign</button>
                <button class="pl-c-button" data-variant="secondary">Snooze</button>
                <button class="pl-c-button" data-variant="primary">Start triage</button>
              </div>
            </div>

            <section class="pl-c-workflow-board" aria-labelledby="lanes-title">
              <div class="pl-c-workflow-board__header">
                <div>
                  <h2 class="pl-c-workflow-board__title" id="lanes-title">SLA swimlanes</h2>
                  <p class="pl-c-workflow-board__meta">Drag state is app-owned; Porchlight supplies the lane and card contract.</p>
                </div>
                <div class="pl-c-workflow-board__tools">
                  <span class="pl-c-badge" data-tone="danger">1 P0 selected</span>
                  <span class="pl-c-badge" data-tone="warning">2 nearing breach</span>
                </div>
              </div>

              <section class="pl-c-workflow-board__swimlane" aria-labelledby="today-swimlane">
                <div class="pl-c-workflow-board__swimlane-header">
                  <h3 class="pl-c-workflow-board__swimlane-title" id="today-swimlane">Today</h3>
                  <span class="pl-c-workflow-board__swimlane-meta">Operational queue by current handling state</span>
                </div>
                <div class="pl-c-workflow-board__lanes" data-scroll="inline" tabindex="0" aria-label="SLA queue lanes">
                  {lanes.map((lane) => (
                    <section class="pl-c-workflow-lane" aria-labelledby={`lane-${lane.title.toLowerCase()}`}>
                      <header class="pl-c-workflow-lane__header">
                        <div class="pl-c-workflow-lane__heading">
                          <h4 class="pl-c-workflow-lane__title" id={`lane-${lane.title.toLowerCase()}`}>{lane.title}</h4>
                          <span class="pl-c-workflow-lane__count">{lane.count}</span>
                        </div>
                        <span class="pl-c-workflow-lane__wip" data-state={lane.state}>WIP {lane.wip}</span>
                      </header>
                      <div class="pl-c-workflow-lane__body">
                        {lane.cards.map((item) => (
                          <article class="pl-c-workflow-card" data-selected={item.selected ? '' : undefined} data-priority={item.priority === 'P0' ? 'high' : undefined}>
                            <div class="pl-c-workflow-card__header">
                              <h5 class="pl-c-workflow-card__title">{item.title}</h5>
                              <span class="pl-c-badge" data-tone={item.slaTone}>{item.sla}</span>
                            </div>
                            <p class="pl-c-workflow-card__body">{item.account} · {item.channel}</p>
                            <div class="pl-c-workflow-card__footer">
                              <div class="pl-c-workflow-card__meta">
                                <span>{item.id}</span>
                                <time datetime="2026-06-29T14:17:00-05:00">{item.wait} wait</time>
                              </div>
                              <div class="pl-c-workflow-card__assignees" aria-label="Assignee">
                                <span class="pl-c-avatar" data-size="sm">{item.owner}</span>
                              </div>
                            </div>
                          </article>
                        ))}
                      </div>
                    </section>
                  ))}
                </div>
              </section>
            </section>

            <section class="pl-c-card" data-surface="app" aria-labelledby="queue-list-title">
              <header class="pl-c-card__header">
                <h2 class="pl-c-card__title" id="queue-list-title">Priority list</h2>
                <span class="pl-c-badge" data-tone="accent">{queueItems.length} shown</span>
              </header>
              <div class="pl-c-card__body">
                <div class="pl-c-table-wrap" data-pl-density="compact" data-overflow="truncate">
                  <table class="pl-c-table">
                    <thead>
                      <tr>
                        <th class="pl-c-table__check"><input type="checkbox" aria-label="Select all queue items" /></th>
                        <th class="pl-c-table__sticky-col" data-sort="asc">Item <span class="pl-c-table__sort-icon"></span></th>
                        <th>Account</th>
                        <th>Priority</th>
                        <th>SLA</th>
                        <th>Status</th>
                        <th data-align="end">Wait</th>
                      </tr>
                    </thead>
                    <tbody>
                      {queueItems.map((item) => (
                        <tr aria-selected={item.selected ? 'true' : undefined}>
                          <td class="pl-c-table__check"><input type="checkbox" checked={item.selected} aria-label={`Select ${item.id}`} /></td>
                          <td class="pl-c-table__sticky-col">
                            <a href="#selected-item">{item.id}</a>
                          </td>
                          <td>{item.account}</td>
                          <td><span class="pl-c-badge" data-tone={item.priorityTone}>{item.priority}</span></td>
                          <td><span class="pl-c-badge" data-tone={item.slaTone}>{item.sla}</span></td>
                          <td><span class="pl-c-badge" data-tone={item.statusTone}>{item.status}</span></td>
                          <td data-align="end">{item.wait}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </section>
          </div>
        </section>

        <div class="pl-c-split-pane__separator" aria-hidden="true"></div>

        <aside class="pl-c-split-pane__pane pl-c-split-pane__pane--end" aria-labelledby="selected-item">
          <div class="pl-c-split-pane__header">
            <div>
              <h2 class="pl-c-split-pane__title" id="selected-item">{selectedItem.id}</h2>
              <p class="pl-c-split-pane__description">{selectedItem.account}</p>
            </div>
          </div>
          <div class="pl-c-split-pane__pane-inner">
            <article class="pl-c-card" data-surface="app">
              <header class="pl-c-card__header">
                <h3 class="pl-c-card__title">{selectedItem.title}</h3>
              </header>
              <div class="pl-c-card__body">
                <div class="pl-c-badge-group" aria-label="Selected item urgency">
                  <span class="pl-c-badge" data-tone={selectedItem.priorityTone}>{selectedItem.priority}</span>
                  <span class="pl-c-badge" data-tone={selectedItem.slaTone}>{selectedItem.sla}</span>
                </div>
                <dl class="pl-l-grid">
                  <div>
                    <dt class="pl-u-muted-sm">SLA</dt>
                    <dd><span class="pl-c-badge" data-tone={selectedItem.slaTone}>{selectedItem.sla}</span></dd>
                  </div>
                  <div>
                    <dt class="pl-u-muted-sm">Status</dt>
                    <dd><span class="pl-c-badge" data-tone={selectedItem.statusTone}>{selectedItem.status}</span></dd>
                  </div>
                  <div>
                    <dt class="pl-u-muted-sm">Channel</dt>
                    <dd>{selectedItem.channel}</dd>
                  </div>
                  <div>
                    <dt class="pl-u-muted-sm">Owner</dt>
                    <dd><span class="pl-c-avatar" data-size="sm">{selectedItem.owner}</span></dd>
                  </div>
                </dl>
              </div>
              <footer class="pl-c-card__footer pl-l-cluster">
                <button class="pl-c-button" data-variant="secondary">Reassign</button>
                <button class="pl-c-button" data-variant="secondary">Escalate</button>
                <button class="pl-c-button" data-variant="primary">Approve</button>
              </footer>
            </article>

            <form class="pl-c-filter-builder" data-pl-density="compact" aria-labelledby="decision-title">
              <header class="pl-c-filter-builder__header">
                <div>
                  <h3 class="pl-c-filter-builder__title" id="decision-title">Decision fields</h3>
                  <p class="pl-c-filter-builder__description">Capture the minimum disposition before closing.</p>
                </div>
              </header>
              <div class="pl-c-filter-builder__body">
                <section class="pl-c-filter-builder__group" data-operator="and" aria-labelledby="decision-group">
                  <header class="pl-c-filter-builder__group-header">
                    <h4 class="pl-c-filter-builder__group-title" id="decision-group">
                      <span class="pl-c-filter-builder__joiner">AND</span>
                      Required checks
                    </h4>
                  </header>
                  <div class="pl-c-filter-builder__rows">
                    <div class="pl-c-filter-builder__row">
                      <div class="pl-c-filter-builder__field">
                        <label class="pl-u-sr-only" for="decision-outcome">Outcome</label>
                        <select class="pl-c-field__control pl-c-filter-builder__control" id="decision-outcome">
                          <option>Needs compliance approval</option>
                          <option>Clear to release</option>
                        </select>
                      </div>
                      <div class="pl-c-filter-builder__value">
                        <label class="pl-u-sr-only" for="decision-note">Note</label>
                        <input class="pl-c-field__control pl-c-filter-builder__control" id="decision-note" value="Partial match requires secondary review" />
                      </div>
                    </div>
                  </div>
                </section>
              </div>
            </form>

            <section class="pl-c-card" data-surface="app" aria-labelledby="activity-title">
              <header class="pl-c-card__header">
                <h3 class="pl-c-card__title" id="activity-title">Activity</h3>
              </header>
              <div class="pl-c-card__body">
                <ol class="pl-c-timeline">
                  {timeline.map((event) => (
                    <li class="pl-c-timeline__item" data-tone={event.tone || undefined}>
                      <span class="pl-c-timeline__dot"></span>
                      <div class="pl-c-timeline__content">
                        <div class="pl-c-timeline__header">
                          <span class="pl-c-timeline__title">{event.title}</span>
                          <time class="pl-c-timeline__time">{event.time}</time>
                        </div>
                        <p class="pl-c-timeline__body">{event.body}</p>
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
            </section>
          </div>
        </aside>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .pl-l-app-shell__main > .pl-c-split-pane {
    overflow: visible;
  }

  .pl-l-app-shell__main > .pl-c-split-pane > .pl-c-split-pane__pane {
    overflow: visible;
    overscroll-behavior: auto;
    scrollbar-gutter: auto;
  }
</style>
