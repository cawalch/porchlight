---
import BaseLayout from '../../layouts/BaseLayout.astro';

const stats = [
  { label: 'Monthly revenue', value: '$48,200', unit: '/mo', direction: 'up', trend: '12.4%', spark: 'M0 32 L10 28 L20 30 L30 22 L40 24 L50 14 L60 10 L70 4' },
  { label: 'Active accounts', value: '247', unit: '', direction: 'up', trend: '8 new', spark: 'M0 28 L10 26 L20 24 L30 20 L40 18 L50 14 L60 12 L70 6' },
  { label: 'Churn rate', value: '2.1', unit: '%', direction: 'down', trend: '-0.4%', spark: 'M0 8 L10 12 L20 10 L30 18 L40 16 L50 22 L60 28 L70 32' },
  { label: 'Response time', value: '142', unit: 'ms', direction: 'flat', trend: 'stable', spark: 'M0 18 L10 16 L20 20 L30 18 L40 16 L50 18 L60 20 L70 18' },
];

const accounts = [
  { name: 'Acme Ops', plan: 'Enterprise', status: 'Active', mrr: '$2,400', seats: 48 },
  { name: 'Northwind', plan: 'Pro', status: 'Trialing', mrr: '$980', seats: 12 },
  { name: 'Globex', plan: 'Pro', status: 'Active', mrr: '$980', seats: 8 },
  { name: 'Initech', plan: 'Team', status: 'Past due', mrr: '$420', seats: 5 },
  { name: 'Umbrella', plan: 'Enterprise', status: 'Active', mrr: '$2,400', seats: 60 },
];

const toneFor = (s: string) =>
  ({ Active: 'success', Trialing: 'accent', 'Past due': 'danger' }[s] ?? 'accent');
---
<BaseLayout title="Responsive dashboard · Porchlight">
  <div class="l-app-shell">
    <!-- Topbar -->
    <header class="l-app-shell__topbar app-topbar">
      <div class="app-topbar__left">
        <button class="c-button" data-variant="ghost" data-size="sm" aria-label="Toggle sidebar" data-toggle="sidebar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="inline-size: 1.25rem; block-size: 1.25rem;"><path d="M3 12h18M3 6h18M3 18h18" stroke-linecap="round"/></svg>
        </button>
        <strong>Porchlight</strong>
      </div>
      <div class="app-topbar__right">
        <button class="c-button" data-variant="ghost" data-size="sm" popovertarget="cmdk-demo" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="inline-size: 1.25rem; block-size: 1.25rem;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <span class="u-muted" style="font-size: var(--pl-text-xs);">Cmd+K</span>
        </button>
        <div class="c-avatar" data-size="sm" style="background: var(--pl-color-accent);">JD</div>
      </div>
    </header>

    <!-- Sidebar nav -->
    <aside class="l-app-shell__sidebar" id="app-sidebar">
      <nav class="c-nav" aria-label="Main navigation">
        <a href="#" class="c-nav__item" aria-current="page">
          <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
          <span class="c-nav__label">Dashboard</span>
        </a>
        <a href="#" class="c-nav__item">
          <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
          <span class="c-nav__label">Accounts</span>
          <span class="c-badge c-nav__badge" data-tone="accent">3</span>
        </a>
        <a href="#" class="c-nav__item">
          <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
          <span class="c-nav__label">Billing</span>
        </a>
        <a href="#" class="c-nav__item">
          <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m7 14 4-4 4 4 5-6"/></svg>
          <span class="c-nav__label">Analytics</span>
        </a>
        <details class="c-nav__section" open>
          <summary class="c-nav__section-trigger">
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <span>Projects</span>
            <svg class="c-nav__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <a href="#" class="c-nav__item c-nav__item--child"><span class="c-nav__label">Active</span></a>
          <a href="#" class="c-nav__item c-nav__item--child"><span class="c-nav__label">Archived</span></a>
        </details>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="l-app-shell__main">
      <div class="l-container" style="--l-container-max: 80rem; padding-block: var(--pl-space-6);">
        <div class="l-stack" style="--l-stack-gap: var(--pl-space-6);">
          <!-- Heading + segmented view toggle -->
          <div class="dash-header">
            <div>
              <h1>Dashboard</h1>
              <p class="u-muted">Overview of your workspace activity</p>
            </div>
            <div class="c-segmented" role="radiogroup" aria-label="Time range">
              <label class="c-segmented__item"><input type="radio" name="range" /><span>Day</span></label>
              <label class="c-segmented__item"><input type="radio" name="range" checked /><span>Week</span></label>
              <label class="c-segmented__item"><input type="radio" name="range" /><span>Month</span></label>
            </div>
          </div>

          <!-- KPI grid: auto-fits from 4 columns down to 1 -->
          <div class="l-grid" style="--l-grid-min: 14rem;">
            {stats.map((s) => (
              <div class="c-card">
                <div class="c-card__body">
                  <div class="c-stat">
                    <span class="c-stat__label">{s.label}</span>
                    <div class="c-stat__value">{s.value}<span class="c-stat__unit">{s.unit}</span></div>
                    <span class="c-stat__trend" data-direction={s.direction}>{s.trend}</span>
                    <div class="c-stat__spark">
                      <svg viewBox="0 0 70 36" width="100%" height="36" preserveAspectRatio="none" aria-hidden="true">
                        <path d={s.spark} fill="none" stroke={s.direction === 'up' ? 'var(--pl-color-success)' : s.direction === 'down' ? 'var(--pl-color-danger)' : 'var(--pl-color-text-muted)'} stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Data table with toolbar -->
          <div class="c-card">
            <div class="c-toolbar">
              <div class="c-toolbar__group">
                <span class="u-muted" style="font-size: var(--pl-text-sm);">5 accounts</span>
              </div>
              <div class="c-toolbar__group">
                <div class="c-segmented" role="radiogroup" aria-label="View">
                  <label class="c-segmented__item"><input type="radio" name="view" checked /><span>Table</span></label>
                  <label class="c-segmented__item"><input type="radio" name="view" /><span>Cards</span></label>
                </div>
                <button class="c-button" data-variant="secondary" data-size="sm">Export</button>
              </div>
            </div>
            <div class="c-table-wrap" style="border: 0; border-radius: 0;">
              <table class="c-table" style="--c-table-min: 36rem;">
                <thead>
                  <tr>
                    <th class="c-table__check"><input type="checkbox" aria-label="Select all"/></th>
                    <th class="c-table__sticky-col" data-sort="asc">Account <span class="c-table__sort-icon"></span></th>
                    <th>Plan</th>
                    <th>Status</th>
                    <th data-align="end" data-sort>Seats <span class="c-table__sort-icon"></span></th>
                    <th data-align="end" data-sort="desc">MRR <span class="c-table__sort-icon"></span></th>
                  </tr>
                </thead>
                <tbody>
                  {accounts.map((a, i) => (
                    <tr aria-selected={i === 0 ? 'true' : undefined}>
                      <td class="c-table__check"><input type="checkbox" checked={i === 0} aria-label={`Select ${a.name}`}/></td>
                      <td class="c-table__sticky-col">{a.name}</td>
                      <td>{a.plan}</td>
                      <td><span class="c-badge" data-tone={toneFor(a.status)}>{a.status}</span></td>
                      <td data-align="end">{a.seats}</td>
                      <td data-align="end">{a.mrr}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="c-toolbar" style="border-block-end: 0; border-block-start: 1px solid var(--pl-color-border);">
              <div class="c-toolbar__group">
                <span class="u-muted" style="font-size: var(--pl-text-sm);">Page 1 of 12</span>
              </div>
              <div class="c-toolbar__group">
                <nav class="c-pagination" aria-label="Pagination">
                  <button class="c-pagination__nav" disabled>Prev</button>
                  <button class="c-pagination__page" aria-current="page">1</button>
                  <button class="c-pagination__page">2</button>
                  <button class="c-pagination__page">3</button>
                  <button class="c-pagination__nav">Next</button>
                </nav>
              </div>
            </div>
          </div>

          <!-- Activity timeline -->
          <div class="c-card">
            <div class="c-card__header"><h2 class="c-card__title">Recent activity</h2></div>
            <div class="c-card__body">
              <ol class="c-timeline">
                <li class="c-timeline__item" data-tone="success">
                  <span class="c-timeline__dot"></span>
                  <div class="c-timeline__content">
                    <div class="c-timeline__header"><span class="c-timeline__title">New account created</span><time class="c-timeline__time">2m ago</time></div>
                    <p class="c-timeline__body">Umbrella Corp signed up for Enterprise plan.</p>
                  </div>
                </li>
                <li class="c-timeline__item">
                  <span class="c-timeline__dot"></span>
                  <div class="c-timeline__content">
                    <div class="c-timeline__header"><span class="c-timeline__title">API key rotated</span><time class="c-timeline__time">1h ago</time></div>
                    <p class="c-timeline__body">Acme Ops generated a new production API key.</p>
                  </div>
                </li>
                <li class="c-timeline__item" data-tone="warning">
                  <span class="c-timeline__dot"></span>
                  <div class="c-timeline__content">
                    <div class="c-timeline__header"><span class="c-timeline__title">Payment failed</span><time class="c-timeline__time">3h ago</time></div>
                    <p class="c-timeline__body">Initech's payment method was declined.</p>
                  </div>
                </li>
              </ol>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Command palette demo -->
  <div popover class="c-command" id="cmdk-demo">
    <input class="c-command__search" placeholder="Search..." aria-label="Search"/>
    <div class="c-command__body">
      <div class="c-command__group">
        <h3 class="c-command__heading">Pages</h3>
        <button class="c-command__item" data-selected><span>Go to Dashboard</span></button>
        <button class="c-command__item"><span>Go to Accounts</span></button>
        <button class="c-command__item"><span>Go to Settings</span></button>
      </div>
    </div>
    <footer class="c-command__footer"><span>esc to close</span></footer>
  </div>

  <script>
    // Docs-only: toggle sidebar collapse.
    document.querySelector('[data-toggle="sidebar"]')?.addEventListener('click', () => {
      const sidebar = document.getElementById('app-sidebar');
      const collapsed = sidebar?.getAttribute('data-sidebar') === 'collapsed';
      sidebar?.setAttribute('data-sidebar', collapsed ? 'expanded' : 'collapsed');
    });
    // Cmd+K shortcut.
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('cmdk-demo')?.showPopover();
      }
    });
  </script>

  <style>
    .app-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--pl-space-3);
      padding: var(--pl-space-2) var(--pl-space-4);
      background: color-mix(in oklab, var(--pl-color-surface), transparent 12%);
      backdrop-filter: blur(8px);
      border-block-end: 1px solid var(--pl-color-border);
    }
    .app-topbar__left, .app-topbar__right {
      display: flex;
      align-items: center;
      gap: var(--pl-space-2);
    }
    .dash-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--pl-space-4);
      flex-wrap: wrap;
    }
    /* The app shell needs to break out of main's width constraint */
    :global(main:has(.l-app-shell)) {
      inline-size: 100%;
      max-inline-size: none;
      margin-inline: 0;
      padding-block: 0;
    }
  </style>
</BaseLayout>
