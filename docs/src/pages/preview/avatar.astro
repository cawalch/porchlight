---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Avatar · Porchlight">
  <h1>Avatar</h1>
  <p>
    A user identity chip — initials on a colored circle, or an image. Three
    sizes via <code>[data-size]</code>. Group stacking via
    <code>.pl-c-avatar-group</code>.
  </p>

  <h2>Sizes</h2>
  <div class="pl-l-cluster">
    <div class="pl-c-avatar" data-size="sm">JD</div>
    <div class="pl-c-avatar">JD</div>
    <div class="pl-c-avatar" data-size="lg">JD</div>
  </div>

  <h2>With image</h2>
  <div class="pl-l-cluster">
    <div class="pl-c-avatar"><img class="pl-c-avatar__img" src="https://i.pravatar.cc/100?img=1" alt="Jane Doe" /></div>
    <div class="pl-c-avatar"><img class="pl-c-avatar__img" src="https://i.pravatar.cc/100?img=2" alt="John Smith" /></div>
    <div class="pl-c-avatar" data-size="lg"><img class="pl-c-avatar__img" src="https://i.pravatar.cc/100?img=3" alt="Alice Wong" /></div>
  </div>

  <h2>Initials with different tones</h2>
  <div class="pl-l-cluster">
    <div class="pl-c-avatar" style="background: var(--pl-color-accent);">AB</div>
    <div class="pl-c-avatar" style="background: var(--pl-color-success);">CD</div>
    <div class="pl-c-avatar" style="background: var(--pl-color-warning);">EF</div>
    <div class="pl-c-avatar" style="background: var(--pl-color-danger);">GH</div>
  </div>

  <h2>Group</h2>
  <div class="pl-c-avatar-group" data-size="sm">
    <div class="pl-c-avatar">JD</div>
    <div class="pl-c-avatar">AB</div>
    <div class="pl-c-avatar">CD</div>
    <div class="pl-c-avatar">EF</div>
    <div class="pl-c-avatar-group__more">+8</div>
  </div>
</BaseLayout>
