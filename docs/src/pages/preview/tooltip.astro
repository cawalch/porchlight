---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Tooltip · Porchlight">
  <h1>Tooltip</h1>
  <p>
    A hover/focus tooltip using CSS Anchor Positioning. Zero JavaScript for
    positioning. Auto-flips when near viewport edges. Falls back to hidden
    in browsers without anchor support.
  </p>

  <h2>Basic</h2>
  <div class="pl-l-cluster tooltip-demo-row">
    <span class="pl-c-tooltip tooltip-anchor-1">
      <span class="pl-c-tooltip__trigger">
        <button class="pl-c-button" data-variant="ghost" aria-describedby="tip-1">Hover me</button>
      </span>
      <span class="pl-c-tooltip__body" role="tooltip" id="tip-1">This is a tooltip with helpful context.</span>
    </span>

    <span class="pl-c-tooltip tooltip-anchor-2">
      <span class="pl-c-tooltip__trigger">
        <button class="pl-c-button" data-variant="ghost" aria-describedby="tip-2">Long text</button>
      </span>
      <span class="pl-c-tooltip__body" role="tooltip" id="tip-2">Tooltips can contain longer text that wraps to multiple lines when the content exceeds the maximum inline size.</span>
    </span>
  </div>

  <h2>On an icon</h2>
  <div class="tooltip-demo-row">
    <span class="pl-c-tooltip tooltip-anchor-3">
      <span class="pl-c-tooltip__trigger">
        <button class="pl-c-button" data-variant="ghost" aria-describedby="tip-3" aria-label="What does this mean?">
          <svg class="tooltip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 16v-4M12 8h.01" stroke-linecap="round" />
          </svg>
        </button>
      </span>
      <span class="pl-c-tooltip__body" role="tooltip" id="tip-3">This metric measures weekly active users.</span>
    </span>
  </div>

  <h2>Keyboard accessible</h2>
  <p class="pl-u-muted">Tab to the button and focus it to show the tooltip.</p>
  <div class="tooltip-demo-row">
    <span class="pl-c-tooltip tooltip-anchor-4">
      <span class="pl-c-tooltip__trigger">
        <button class="pl-c-button" data-variant="primary" aria-describedby="tip-4">Focus me</button>
      </span>
      <span class="pl-c-tooltip__body" role="tooltip" id="tip-4">Tooltips appear on focus too, for keyboard users.</span>
    </span>
  </div>
</BaseLayout>

<style>
  .tooltip-demo-row {
    margin-block-start: var(--pl-space-4);
  }

  .tooltip-anchor-1 {
    --pl-c-tooltip-anchor: --tip-1;
  }

  .tooltip-anchor-2 {
    --pl-c-tooltip-anchor: --tip-2;
  }

  .tooltip-anchor-3 {
    --pl-c-tooltip-anchor: --tip-3;
  }

  .tooltip-anchor-4 {
    --pl-c-tooltip-anchor: --tip-4;
  }

  .tooltip-icon {
    inline-size: 1.25rem;
    block-size: 1.25rem;
  }
</style>
