---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Tooltip · Porchlight">
  <h1>Tooltip</h1>
  <p>
    A hover/focus tooltip using CSS Anchor Positioning. Zero JavaScript for
    positioning. Auto-flips when near viewport edges. Falls back to hidden
    in browsers without anchor support.
  </p>

  <h2>Basic</h2>
  <div class="l-cluster" style="margin-block-start: var(--pl-space-4);">
    <span class="c-tooltip" style="--c-tooltip-anchor: --tip-1;">
      <span class="c-tooltip__trigger">
        <button class="c-button" data-variant="ghost" aria-describedby="tip-1">Hover me</button>
      </span>
      <span class="c-tooltip__body" role="tooltip" id="tip-1">This is a tooltip with helpful context.</span>
    </span>

    <span class="c-tooltip" style="--c-tooltip-anchor: --tip-2;">
      <span class="c-tooltip__trigger">
        <button class="c-button" data-variant="ghost" aria-describedby="tip-2">Long text</button>
      </span>
      <span class="c-tooltip__body" role="tooltip" id="tip-2">Tooltips can contain longer text that wraps to multiple lines when the content exceeds the maximum inline size.</span>
    </span>
  </div>

  <h2>On an icon</h2>
  <div style="margin-block-start: var(--pl-space-4);">
    <span class="c-tooltip" style="--c-tooltip-anchor: --tip-3;">
      <span class="c-tooltip__trigger">
        <button class="c-button" data-variant="ghost" aria-describedby="tip-3" aria-label="What does this mean?">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="inline-size: 1.25rem; block-size: 1.25rem;">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 16v-4M12 8h.01" stroke-linecap="round" />
          </svg>
        </button>
      </span>
      <span class="c-tooltip__body" role="tooltip" id="tip-3">This metric measures weekly active users.</span>
    </span>
  </div>

  <h2>Keyboard accessible</h2>
  <p class="u-muted">Tab to the button and focus it to show the tooltip.</p>
  <div style="margin-block-start: var(--pl-space-4);">
    <span class="c-tooltip" style="--c-tooltip-anchor: --tip-4;">
      <span class="c-tooltip__trigger">
        <button class="c-button" data-variant="primary" aria-describedby="tip-4">Focus me</button>
      </span>
      <span class="c-tooltip__body" role="tooltip" id="tip-4">Tooltips appear on focus too, for keyboard users.</span>
    </span>
  </div>
</BaseLayout>
