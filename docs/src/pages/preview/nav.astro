---
import BaseLayout from '../../layouts/BaseLayout.astro';

const navItems = [
  { label: 'Dashboard', icon: '<rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/>', active: true },
  { label: 'Accounts', icon: '<circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>', badge: '3' },
  { label: 'Billing', icon: '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>' },
  { label: 'Analytics', icon: '<path d="M3 3v18h18"/><path d="m7 14 4-4 4 4 5-6"/>' },
];
---
<BaseLayout title="Nav · Porchlight">
  <h1>Nav</h1>
  <p>
    A vertical sidebar navigation list. Icon + label items with active state
    via <code>aria-current</code>. Collapsible sections via native
    <code>&lt;details&gt;</code>. Icons-only variant for collapsed sidebars.
  </p>

  <div class="nav-demo">
    <!-- Full nav in a sidebar-like container -->
    <div class="nav-sidebar">
      <nav class="c-nav" aria-label="Main navigation">
        <div class="c-nav__group">
          <span class="c-nav__group-label">Workspace</span>
        </div>
        {navItems.map((item) => (
          <a href="#" class="c-nav__item" aria-current={item.active ? 'page' : undefined}>
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={item.icon} />
            <span class="c-nav__label">{item.label}</span>
            {item.badge && <span class="c-badge c-nav__badge" data-tone="accent">{item.badge}</span>}
          </a>
        ))}

        <div class="c-menu c-nav__menu" data-placement="inline-end" style="--c-menu-anchor: --nav-reports-menu;">
          <button class="c-menu__trigger" type="button" popovertarget="nav-reports-menu" aria-haspopup="menu" data-preview-nav-menu-trigger>
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 3v18h18"/><path d="M7 15l4-4 4 4 5-7"/></svg>
            <span class="c-nav__label">Reports</span>
            <svg class="c-nav__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="c-menu__popover" id="nav-reports-menu" popover data-preview-nav-menu>
            <a class="c-menu__item" href="#" aria-current="page">
              <svg class="c-menu__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 3v18h18"/><path d="m7 14 4-4 4 4 5-6"/></svg>
              <span class="c-menu__item-body">
                <span class="c-menu__item-label">Overview</span>
                <span class="c-menu__item-description">Executive KPI rollup</span>
              </span>
              <kbd class="c-menu__item-shortcut">R</kbd>
            </a>
            <a class="c-menu__item" href="#">
              <svg class="c-menu__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 19V5"/><path d="M8 19V9"/><path d="M12 19V7"/><path d="M16 19v-4"/><path d="M20 19V11"/></svg>
              <span class="c-menu__item-body">
                <span class="c-menu__item-label">Pipeline</span>
                <span class="c-menu__item-description">Forecast and trend detail</span>
              </span>
            </a>
            <hr class="c-menu__divider" />
            <button class="c-menu__item" type="button">
              <svg class="c-menu__item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
              <span class="c-menu__item-label">Export CSV</span>
            </button>
          </div>
        </div>

        <hr class="c-nav__divider" />

        <details class="c-nav__section" open>
          <summary class="c-nav__section-trigger">
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            <span>Projects</span>
            <svg class="c-nav__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <a href="#" class="c-nav__item c-nav__item--child">
            <span class="c-nav__label">Active</span>
          </a>
          <a href="#" class="c-nav__item c-nav__item--child">
            <span class="c-nav__label">Archived</span>
            <span class="c-badge c-nav__badge">12</span>
          </a>
        </details>

        <details class="c-nav__section">
          <summary class="c-nav__section-trigger">
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            <span>Settings</span>
            <svg class="c-nav__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
        </details>

        <div class="c-nav__footer">
          <div class="c-nav__meta" data-preview-nav-meta>
            <span class="c-nav__meta-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
            </span>
            <span class="c-nav__meta-body">
              <span class="c-nav__meta-label">avery.long.account.email@example-company.test</span>
              <span class="c-nav__meta-description">
                <span class="c-badge" data-tone="success">Admin</span>
                Online
              </span>
            </span>
          </div>
          <div class="c-nav__actions">
            <a class="c-nav__action" href="#" data-preview-nav-action>
              <svg class="c-nav__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M16 3h5v5"/><path d="M21 3 10 14"/><path d="M15 21H5a2 2 0 0 1-2-2V9"/></svg>
              <span class="c-nav__action-label">Switch user</span>
            </a>
            <button class="c-nav__action" type="button" data-preview-nav-action>
              <svg class="c-nav__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
              <span class="c-nav__action-label">Sign out</span>
            </button>
          </div>
        </div>
      </nav>
    </div>

    <!-- Icons-only variant -->
    <div class="nav-sidebar nav-sidebar--collapsed">
      <nav class="c-nav" aria-label="Quick nav" data-variant="icons">
        <div class="c-nav__group">
          <span class="c-nav__group-label">Workspace</span>
        </div>
        {navItems.map((item) => (
          <a href="#" class="c-nav__item" aria-current={item.active ? 'page' : undefined} aria-label={item.label}>
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={item.icon} />
          </a>
        ))}
        <div class="c-menu c-nav__menu" data-placement="inline-end" style="--c-menu-anchor: --nav-rail-reports-menu;">
          <button class="c-menu__trigger" type="button" popovertarget="nav-rail-reports-menu" aria-haspopup="menu" aria-label="Reports">
            <svg class="c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 3v18h18"/><path d="M7 15l4-4 4 4 5-7"/></svg>
            <span class="c-nav__label">Reports</span>
            <svg class="c-nav__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="c-menu__popover" id="nav-rail-reports-menu" popover>
            <a class="c-menu__item" href="#" aria-current="page">Overview</a>
            <a class="c-menu__item" href="#">Pipeline</a>
            <button class="c-menu__item" type="button">Export CSV</button>
          </div>
        </div>
        <hr class="c-nav__divider" />
        <div class="c-nav__footer">
          <div class="c-nav__meta" title="avery.long.account.email@example-company.test">
            <span class="c-nav__meta-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
            </span>
            <span class="c-nav__meta-body">
              <span class="c-nav__meta-label">avery.long.account.email@example-company.test</span>
              <span class="c-nav__meta-description">Admin</span>
            </span>
          </div>
          <div class="c-nav__actions">
            <button class="c-nav__action" type="button" aria-label="Sign out">
              <svg class="c-nav__action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
              <span class="c-nav__action-label">Sign out</span>
            </button>
          </div>
        </div>
      </nav>
    </div>
  </div>
</BaseLayout>

<style>
  .nav-demo {
    display: flex;
    column-gap: clamp(var(--pl-space-5), 18vi, 14rem);
    row-gap: var(--pl-space-5);
    flex-wrap: wrap;
    margin-block-start: var(--pl-space-5);
  }
  .nav-sidebar {
    inline-size: 14rem;
    padding-block: var(--pl-space-3);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
    background: var(--pl-color-surface);
  }
  .nav-sidebar--collapsed {
    inline-size: 3.5rem;
  }
</style>
