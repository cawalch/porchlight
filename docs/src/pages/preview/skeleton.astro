---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Skeleton · Porchlight">
  <h1>Skeleton</h1>
  <p>
    Loading placeholders that mimic real content shapes. A CSS-only opacity
    pulse communicates "loading" without a spinner. Three shapes:
    <code>text</code> (default), <code>circle</code> (avatar), and
    <code>rect</code> (block). Under reduced motion the pulse stops; the
    placeholder stays as a static grey block.
  </p>

  <h2>Text lines</h2>
  <div class="pl-c-skeleton-group skeleton-text-demo">
    <div class="pl-c-skeleton skeleton-w-40" data-shape="text"></div>
    <div class="pl-c-skeleton" data-shape="text"></div>
    <div class="pl-c-skeleton skeleton-w-90" data-shape="text"></div>
    <div class="pl-c-skeleton skeleton-w-60" data-shape="text" data-line="sm"></div>
  </div>

  <h2>Card skeleton</h2>
  <div class="pl-l-grid skeleton-card-grid">
    <div class="pl-c-card">
      <div class="pl-c-card__header">
        <div class="pl-c-skeleton skeleton-w-avatar" data-shape="circle"></div>
        <div class="pl-c-skeleton-group skeleton-flex-fill">
          <div class="pl-c-skeleton skeleton-w-50" data-shape="text"></div>
          <div class="pl-c-skeleton skeleton-w-30" data-shape="text" data-line="sm"></div>
        </div>
      </div>
      <div class="pl-c-skeleton-group">
        <div class="pl-c-skeleton" data-shape="text"></div>
        <div class="pl-c-skeleton skeleton-w-80" data-shape="text"></div>
      </div>
    </div>
  </div>

  <h2>Rect + circle</h2>
  <div class="pl-l-cluster">
    <div class="pl-c-skeleton skeleton-w-rect" data-shape="rect"></div>
    <div class="pl-c-skeleton skeleton-w-circle-lg" data-shape="circle"></div>
    <div class="pl-c-skeleton skeleton-w-circle-sm" data-shape="circle"></div>
  </div>
</BaseLayout>

<style>
  .skeleton-text-demo {
    max-inline-size: 30rem;
  }

  .skeleton-card-grid {
    max-inline-size: 40rem;
  }

  .skeleton-flex-fill {
    flex: 1;
  }

  .skeleton-w-30 {
    --pl-c-skeleton-w: 30%;
  }

  .skeleton-w-40 {
    --pl-c-skeleton-w: 40%;
  }

  .skeleton-w-50 {
    --pl-c-skeleton-w: 50%;
  }

  .skeleton-w-60 {
    --pl-c-skeleton-w: 60%;
  }

  .skeleton-w-80 {
    --pl-c-skeleton-w: 80%;
  }

  .skeleton-w-90 {
    --pl-c-skeleton-w: 90%;
  }

  .skeleton-w-avatar {
    --pl-c-skeleton-w: 2.5rem;
  }

  .skeleton-w-rect {
    --pl-c-skeleton-w: 8rem;
  }

  .skeleton-w-circle-lg {
    --pl-c-skeleton-w: 3rem;
  }

  .skeleton-w-circle-sm {
    --pl-c-skeleton-w: 2rem;
  }
</style>
