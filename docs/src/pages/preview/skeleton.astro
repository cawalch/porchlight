---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Skeleton · Porchlight">
  <h1>Skeleton</h1>
  <p>
    Loading placeholders that mimic real content shapes. A CSS-only opacity
    pulse communicates "loading" without a spinner. Three shapes:
    <code>text</code> (default), <code>circle</code> (avatar), and
    <code>rect</code> (block). Under reduced motion the pulse stops; the
    placeholder stays as a static grey block.
  </p>

  <h2>Text lines</h2>
  <div class="c-skeleton-group" style="max-inline-size: 30rem;">
    <div class="c-skeleton" data-shape="text" style="--c-skeleton-w: 40%;"></div>
    <div class="c-skeleton" data-shape="text"></div>
    <div class="c-skeleton" data-shape="text" style="--c-skeleton-w: 90%;"></div>
    <div class="c-skeleton" data-shape="text" data-line="sm" style="--c-skeleton-w: 60%;"></div>
  </div>

  <h2>Card skeleton</h2>
  <div class="l-grid" style="max-inline-size: 40rem;">
    <div class="c-card">
      <div class="c-card__header">
        <div class="c-skeleton" data-shape="circle" style="--c-skeleton-w: 2.5rem;"></div>
        <div class="c-skeleton-group" style="flex: 1;">
          <div class="c-skeleton" data-shape="text" style="--c-skeleton-w: 50%;"></div>
          <div class="c-skeleton" data-shape="text" data-line="sm" style="--c-skeleton-w: 30%;"></div>
        </div>
      </div>
      <div class="c-skeleton-group">
        <div class="c-skeleton" data-shape="text"></div>
        <div class="c-skeleton" data-shape="text" style="--c-skeleton-w: 80%;"></div>
      </div>
    </div>
  </div>

  <h2>Rect + circle</h2>
  <div class="l-cluster">
    <div class="c-skeleton" data-shape="rect" style="--c-skeleton-w: 8rem;"></div>
    <div class="c-skeleton" data-shape="circle" style="--c-skeleton-w: 3rem;"></div>
    <div class="c-skeleton" data-shape="circle" style="--c-skeleton-w: 2rem;"></div>
  </div>
</BaseLayout>
