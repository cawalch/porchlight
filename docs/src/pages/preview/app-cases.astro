---
import BaseLayout from '../../layouts/BaseLayout.astro';

// --- Mock data: Case/Ticket Review ----------------------------------------

type Priority = 'urgent' | 'high' | 'medium' | 'low';
type CaseStatus = 'triage' | 'in-progress' | 'review' | 'done' | 'blocked';

interface Case {
  id: string;
  title: string;
  assignee: string;
  initials: string;
  priority: Priority;
  status: CaseStatus;
  tags: string[];
  updated: string;
  comments: number;
}

const cases: Case[] = [
  { id: 'CASE-3042', title: 'Production DB connection pool exhaustion', assignee: 'A. Rivera', initials: 'AR', priority: 'urgent', status: 'in-progress', tags: ['database', 'incident'], updated: '5m ago', comments: 12 },
  { id: 'CASE-3041', title: 'OAuth token refresh failing intermittently', assignee: 'J. Park', initials: 'JP', priority: 'high', status: 'triage', tags: ['auth', 'api'], updated: '18m ago', comments: 4 },
  { id: 'CASE-3040', title: 'Webhook delivery backlog growing on EU cluster', assignee: 'M. Chen', initials: 'MC', priority: 'high', status: 'in-progress', tags: ['webhooks', 'infra'], updated: '32m ago', comments: 7 },
  { id: 'CASE-3039', title: 'Rate limiter allowing 2x threshold on /v2/search', assignee: 'A. Rivera', initials: 'AR', priority: 'medium', status: 'review', tags: ['api', 'rate-limit'], updated: '1h ago', comments: 3 },
  { id: 'CASE-3038', title: 'CSS regression: drawer overlaps footer on Safari 17', assignee: 'S. Okafor', initials: 'SO', priority: 'medium', status: 'in-progress', tags: ['css', 'safari'], updated: '2h ago', comments: 5 },
  { id: 'CASE-3037', title: 'Audit log retention policy enforcement gap', assignee: 'J. Park', initials: 'JP', priority: 'high', status: 'blocked', tags: ['compliance', 'logging'], updated: '3h ago', comments: 9 },
  { id: 'CASE-3036', title: 'Upgrade Redis to 7.2 across cache tier', assignee: 'M. Chen', initials: 'MC', priority: 'low', status: 'review', tags: ['infra', 'redis'], updated: '4h ago', comments: 2 },
  { id: 'CASE-3035', title: 'Customer export CSV truncates at 10k rows', assignee: 'S. Okafor', initials: 'SO', priority: 'medium', status: 'in-progress', tags: ['export', 'bug'], updated: '5h ago', comments: 6 },
  { id: 'CASE-3034', title: 'On-call rotation calendar not syncing holidays', assignee: 'A. Rivera', initials: 'AR', priority: 'low', status: 'done', tags: ['ops', 'tooling'], updated: '6h ago', comments: 1 },
  { id: 'CASE-3033', title: 'Migration script fails on nullable FK columns', assignee: 'J. Park', initials: 'JP', priority: 'high', status: 'blocked', tags: ['migration', 'database'], updated: '8h ago', comments: 11 },
  { id: 'CASE-3032', title: 'Add SAML SSO provider configuration UI', assignee: 'S. Okafor', initials: 'SO', priority: 'medium', status: 'review', tags: ['feature', 'auth'], updated: '12h ago', comments: 4 },
  { id: 'CASE-3031', title: 'Memory leak in event stream processor', assignee: 'M. Chen', initials: 'MC', priority: 'urgent', status: 'in-progress', tags: ['performance', 'backend'], updated: '14h ago', comments: 8 },
];

const priorityTone = (p: Priority) =>
  ({ urgent: 'danger', high: 'warning', medium: 'accent', low: 'default' }[p] ?? 'default');

const statusLabel = (s: CaseStatus) =>
  ({ 'triage': 'Triage', 'in-progress': 'In Progress', 'review': 'In Review', 'done': 'Done', 'blocked': 'Blocked' }[s] ?? s);

const statusTone = (s: CaseStatus) =>
  ({ 'triage': 'danger', 'in-progress': 'accent', 'review': 'warning', 'done': 'success', 'blocked': 'default' }[s] ?? 'default');

const assignees = [
  { name: 'A. Rivera', initials: 'AR', open: cases.filter(c => c.assignee === 'A. Rivera').length },
  { name: 'J. Park', initials: 'JP', open: cases.filter(c => c.assignee === 'J. Park').length },
  { name: 'M. Chen', initials: 'MC', open: cases.filter(c => c.assignee === 'M. Chen').length },
  { name: 'S. Okafor', initials: 'SO', open: cases.filter(c => c.assignee === 'S. Okafor').length },
];

const detailCase = cases[0];

const activity = [
  { tone: 'accent', title: 'Status changed to In Progress', time: '5m ago', body: 'A. Rivera updated the status.' },
  { tone: 'accent', title: 'Assigned to A. Rivera', time: '20m ago', body: 'Escalated from Tier 1 triage.' },
  { tone: 'warning', title: 'Priority raised to Urgent', time: '35m ago', body: 'Customer impact: all write operations blocked.' },
  { tone: '', title: 'Comment by M. Chen', time: '45m ago', body: 'Pool exhaustion confirmed. Connection count spiked to 200 (limit 100). Reviewing pg_bouncer config.' },
  { tone: 'danger', title: 'Case created', time: '1h ago', body: 'Auto-created from PagerDuty incident #PD-8932.' },
];
---

<BaseLayout title="Case Review · Porchlight">
  <div class="pl-l-app-shell">
    <!-- Topbar -->
    <header class="pl-l-app-shell__topbar cases-topbar">
      <div class="cases-topbar__left">
        <button class="pl-c-button" data-variant="ghost" data-size="sm" aria-label="Toggle sidebar" data-toggle="sidebar">
          <svg class="cases-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18" stroke-linecap="round"/></svg>
        </button>
        <strong>Helix</strong>
        <span class="pl-u-muted cases-team-label">/ Platform Team</span>
      </div>
      <div class="cases-topbar__right">
        <button class="pl-c-button" data-variant="ghost" data-size="sm" popovertarget="cases-cmdk" aria-label="Search">
          <svg class="cases-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <kbd class="cases-kbd">⌘K</kbd>
        </button>
        <span class="pl-c-badge" data-tone="accent">{cases.filter(c => c.status !== 'done').length} open</span>
        <div class="pl-c-avatar cases-avatar-accent" data-size="sm">AR</div>
      </div>
    </header>

    <!-- Sidebar -->
    <aside class="pl-l-app-shell__sidebar" id="cases-sidebar">
      <nav class="pl-c-nav" aria-label="Case navigation">
        <a href="#" class="pl-c-nav__item">
          <svg class="pl-c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
          <span class="pl-c-nav__label">Inbox</span>
          <span class="pl-c-badge pl-c-nav__badge" data-tone="accent">3</span>
        </a>
        <a href="#" class="pl-c-nav__item" aria-current="page">
          <svg class="pl-c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          <span class="pl-c-nav__label">My Cases</span>
          <span class="pl-c-badge pl-c-nav__badge">{cases.filter(c => c.assignee === 'A. Rivera' && c.status !== 'done').length}</span>
        </a>
        <a href="#" class="pl-c-nav__item">
          <svg class="pl-c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span class="pl-c-nav__label">All Cases</span>
        </a>
        <details class="pl-c-nav__section" open>
          <summary class="pl-c-nav__section-trigger">
            <svg class="pl-c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>Teams</span>
            <svg class="pl-c-nav__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <a href="#" class="pl-c-nav__item pl-c-nav__item--child"><span class="pl-c-nav__label">Platform</span></a>
          <a href="#" class="pl-c-nav__item pl-c-nav__item--child"><span class="pl-c-nav__label">Frontend</span></a>
          <a href="#" class="pl-c-nav__item pl-c-nav__item--child"><span class="pl-c-nav__label">Security</span></a>
        </details>
        <a href="#" class="pl-c-nav__item">
          <svg class="pl-c-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><rect x="7" y="13" width="3" height="5"/><rect x="12" y="9" width="3" height="9"/><rect x="17" y="5" width="3" height="13"/></svg>
          <span class="pl-c-nav__label">Reports</span>
        </a>

        <!-- Assignee workload -->
        <div class="cases-workload">
          <h3 class="cases-workload__title">Team Workload</h3>
          {assignees.map((a) => (
            <div class="cases-workload__item">
              <div class="pl-c-avatar cases-workload-avatar" data-size="sm">{a.initials}</div>
              <span class="cases-workload__name">{a.name}</span>
              <span class="pl-c-badge" data-tone={a.open > 3 ? 'warning' : 'default'}>{a.open}</span>
            </div>
          ))}
        </div>
      </nav>
    </aside>

    <!-- Main -->
    <main class="pl-l-app-shell__main">
      <div class="cases-main">
        <!-- Header + view toggle -->
        <div class="cases-header">
          <div>
            <h1>Cases</h1>
            <p class="pl-u-muted">{cases.length} cases · {cases.filter(c => c.priority === 'urgent').length} urgent</p>
          </div>
          <div class="pl-l-cluster">
            <div class="pl-c-segmented" role="radiogroup" aria-label="View mode">
              <label class="pl-c-segmented__item"><input type="radio" name="view" checked/><span>
                <svg class="cases-segment-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                List
              </span></label>
              <label class="pl-c-segmented__item"><input type="radio" name="view"/><span>
                <svg class="cases-segment-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
                Board
              </span></label>
            </div>
            <button class="pl-c-button" data-variant="primary" data-size="sm">
              <svg class="cases-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
              New Case
            </button>
          </div>
        </div>

        <!-- Filter bar -->
        <div class="pl-c-card cases-filters" data-surface="app">
          <div class="pl-c-toolbar cases-toolbar-flat">
            <div class="pl-c-toolbar__group">
              <span class="pl-c-chip" data-tone="accent">Platform</span>
              <span class="pl-c-chip">P0-P2</span>
              <button class="pl-c-chip cases-chip-button" data-tone="ghost">
                <svg class="cases-segment-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
                Add filter
              </button>
            </div>
            <div class="pl-c-toolbar__group">
              <!-- Avatar group -->
              <div class="pl-c-avatar-group cases-avatar-group">
                {assignees.map((a) => (
                  <div class="pl-c-avatar cases-avatar-xs">{a.initials}</div>
                ))}
              </div>
              <div class="pl-c-field cases-inline-field">
                <input type="search" class="pl-c-field__control cases-search-input" placeholder="Search cases…" aria-label="Search cases"/>
              </div>
              <button class="pl-c-button" data-variant="secondary" data-size="sm">
                <svg class="cases-icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Export
              </button>
            </div>
          </div>
        </div>

        <!-- Case list (data table) -->
        <div class="pl-c-card cases-table-card" data-surface="app">
          <div class="pl-c-table-wrap cases-table-wrap">
            <table class="pl-c-table">
              <thead>
                <tr>
                  <th class="pl-c-table__check"><input type="checkbox" aria-label="Select all"/></th>
                  <th class="pl-c-table__sticky-col" data-sort="asc">ID <span class="pl-c-table__sort-icon"></span></th>
                  <th>Title</th>
                  <th>Assignee</th>
                  <th>Priority</th>
                  <th>Status</th>
                  <th>Tags</th>
                  <th data-align="end" data-sort>Updated <span class="pl-c-table__sort-icon"></span></th>
                  <th data-align="center" data-sort>💬 <span class="pl-c-table__sort-icon"></span></th>
                </tr>
              </thead>
              <tbody>
                {cases.map((c, i) => (
                  <tr class="cases-row-action" aria-selected={i === 0 ? 'true' : undefined} data-popover-target="case-detail">
                    <td class="pl-c-table__check"><input type="checkbox" checked={i === 0} aria-label={`Select ${c.id}`}/></td>
                    <td class="pl-c-table__sticky-col"><code class="cases-code">{c.id}</code></td>
                    <td><strong class="cases-case-title">{c.title}</strong></td>
                    <td>
                      <div class="cases-assignee">
                        <div class="pl-c-avatar cases-avatar-compact" data-size="sm">{c.initials}</div>
                        <span class="cases-text-sm">{c.assignee}</span>
                      </div>
                    </td>
                    <td>
                      <span class="pl-c-badge cases-capitalize" data-tone={priorityTone(c.priority)}>{c.priority}</span>
                    </td>
                    <td>
                      <span class="pl-c-badge" data-tone={statusTone(c.status)}>{statusLabel(c.status)}</span>
                    </td>
                    <td>
                      <div class="cases-tag-list">
                        {c.tags.map((t) => <span class="pl-c-chip cases-tag">{t}</span>)}
                      </div>
                    </td>
                    <td data-align="end"><span class="pl-u-muted cases-text-xs">{c.updated}</span></td>
                    <td data-align="center"><span class="pl-u-muted cases-text-sm">{c.comments}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="pl-c-toolbar cases-pagination-toolbar">
            <div class="pl-c-toolbar__group">
              <span class="pl-u-muted cases-text-sm">{cases.length} cases</span>
            </div>
            <div class="pl-c-toolbar__group">
              <nav class="pl-c-pagination" aria-label="Case pagination">
                <button class="pl-c-pagination__nav" disabled>Prev</button>
                <button class="pl-c-pagination__page" aria-current="page">1</button>
                <button class="pl-c-pagination__page">2</button>
                <button class="pl-c-pagination__page">3</button>
                <button class="pl-c-pagination__nav">Next</button>
              </nav>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Case detail drawer -->
  <div popover="manual" class="pl-c-drawer pl-c-drawer--end" id="case-detail">
    <div class="pl-c-drawer__header">
      <div>
        <p class="cases-detail-id">{detailCase.id}</p>
        <h2 class="cases-detail-title">{detailCase.title}</h2>
      </div>
      <button class="pl-c-button" data-variant="ghost" data-size="sm" popovertarget="case-detail" popovertargetaction="hide" aria-label="Close drawer">
        <svg class="cases-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12" stroke-linecap="round"/></svg>
      </button>
    </div>
    <div class="pl-c-drawer__body">
      <!-- Metadata grid -->
      <div class="pl-l-grid cases-detail-meta">
        <div>
          <span class="pl-u-muted cases-text-xs">Priority</span>
          <div class="cases-detail-value"><span class="pl-c-badge cases-capitalize" data-tone={priorityTone(detailCase.priority)}>{detailCase.priority}</span></div>
        </div>
        <div>
          <span class="pl-u-muted cases-text-xs">Status</span>
          <div class="cases-detail-value"><span class="pl-c-badge" data-tone={statusTone(detailCase.status)}>{statusLabel(detailCase.status)}</span></div>
        </div>
        <div>
          <span class="pl-u-muted cases-text-xs">Assignee</span>
          <div class="cases-assignee cases-detail-value">
            <div class="pl-c-avatar cases-avatar-compact cases-avatar-accent" data-size="sm">{detailCase.initials}</div>
            <span class="cases-text-sm">{detailCase.assignee}</span>
          </div>
        </div>
        <div>
          <span class="pl-u-muted cases-text-xs">Updated</span>
          <div class="cases-detail-value cases-text-sm">{detailCase.updated}</div>
        </div>
      </div>

      <!-- Tags -->
      <div class="cases-detail-tags">
        {detailCase.tags.map((t) => <span class="pl-c-chip">{t}</span>)}
      </div>

      <!-- Description -->
      <div class="cases-detail-section">
        <h3 class="cases-section-title">Description</h3>
        <p class="cases-detail-copy">
          The production database connection pool is exhausting all available connections (limit: 100) within minutes of a deploy. Write operations are queued indefinitely, causing cascading timeouts across the API layer. Initial investigation points to a missing pool-size override in the deploy config.
        </p>
      </div>

      <!-- Activity timeline -->
      <div class="cases-detail-section">
        <h3 class="cases-section-title cases-section-title-spacious">Activity</h3>
        <ol class="pl-c-timeline">
          {activity.map((e) => (
            <li class="pl-c-timeline__item" data-tone={e.tone || undefined}>
              <span class="pl-c-timeline__dot"></span>
              <div class="pl-c-timeline__content">
                <div class="pl-c-timeline__header">
                  <span class="pl-c-timeline__title cases-text-sm">{e.title}</span>
                  <time class="pl-c-timeline__time cases-text-xs">{e.time}</time>
                </div>
                <p class="pl-c-timeline__body cases-text-xs">{e.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
    <div class="pl-c-drawer__footer">
      <div class="pl-l-cluster cases-footer-actions">
        <button class="pl-c-button" data-variant="secondary" data-size="sm">Reassign</button>
        <button class="pl-c-button" data-variant="secondary" data-size="sm">Escalate</button>
        <button class="pl-c-button" data-variant="primary" data-size="sm">Mark Resolved</button>
      </div>
    </div>
  </div>

  <!-- Command Palette -->
  <div popover class="pl-c-command" id="cases-cmdk">
    <input class="pl-c-command__search" placeholder="Search cases, people, tags…" aria-label="Search"/>
    <div class="pl-c-command__body">
      <div class="pl-c-command__group">
        <h3 class="pl-c-command__heading">Quick Actions</h3>
        <button class="pl-c-command__item" data-selected><span>Create New Case</span></button>
        <button class="pl-c-command__item"><span>View My Cases</span></button>
        <button class="pl-c-command__item"><span>Switch to Board View</span></button>
      </div>
    </div>
    <footer class="pl-c-command__footer"><span>esc to close</span></footer>
  </div>

  <script>
    document.querySelector('[data-toggle="sidebar"]')?.addEventListener('click', () => {
      const sidebar = document.getElementById('cases-sidebar');
      const collapsed = sidebar?.getAttribute('data-sidebar') === 'collapsed';
      sidebar?.setAttribute('data-sidebar', collapsed ? 'expanded' : 'collapsed');
    });
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('cases-cmdk')?.showPopover();
      }
    });
  </script>

  <style>
    /* Layout override handled centrally in global.css. */

    .cases-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--pl-space-3);
      padding: var(--pl-space-2) var(--pl-space-4);
      background: color-mix(in oklab, var(--pl-color-surface), transparent 12%);
      backdrop-filter: blur(8px);
      border-block-end: 1px solid var(--pl-color-border);
    }
    .cases-topbar__left { display: flex; align-items: center; gap: var(--pl-space-2); }
    .cases-topbar__right { display: flex; align-items: center; justify-content: flex-end; gap: var(--pl-space-2); }
    .cases-topbar__left,
    .cases-topbar__right {
      min-inline-size: 0;
    }
    .cases-icon {
      inline-size: 1.25rem;
      block-size: 1.25rem;
      flex-shrink: 0;
    }
    .cases-icon-sm {
      inline-size: 1rem;
      block-size: 1rem;
      flex-shrink: 0;
    }
    .cases-segment-icon {
      inline-size: 0.875rem;
      block-size: 0.875rem;
      vertical-align: middle;
    }
    .cases-team-label,
    .cases-text-sm {
      font-size: var(--pl-text-sm);
    }
    .cases-team-label {
      white-space: nowrap;
    }
    .cases-text-xs,
    .cases-code {
      font-size: var(--pl-text-xs);
    }
    .cases-kbd {
      font-family: var(--pl-font-mono);
      font-size: var(--pl-text-xs);
      padding: 0.1rem 0.3rem;
      border: 1px solid var(--pl-color-border);
      border-radius: var(--pl-radius-xs);
      background: var(--pl-color-surface-2);
      color: var(--pl-color-text-muted);
    }
    @media (width < 40rem) {
      .cases-team-label,
      .cases-kbd {
        display: none;
      }
      .cases-topbar__right {
        gap: var(--pl-space-1);
      }
    }
    .cases-avatar-accent {
      background: var(--pl-color-accent);
      color: var(--pl-color-accent-text);
    }
    .cases-workload-avatar {
      inline-size: 1.75rem;
      block-size: 1.75rem;
      font-size: var(--pl-text-xs);
    }

    .cases-main {
      padding: var(--pl-space-6);
      display: flex;
      flex-direction: column;
      gap: var(--pl-space-4);
    }
    .cases-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--pl-space-4);
      flex-wrap: wrap;
    }
    .cases-filters { padding: 0; overflow: hidden; }
    .cases-toolbar-flat {
