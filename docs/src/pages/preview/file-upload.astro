---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="File Upload · Porchlight">
  <h1>File upload</h1>
  <p>
    A drag-and-drop file upload zone. The native <code>&lt;input type="file"&gt;</code>
    is visually hidden; the zone is the click target. Uses <code>:has()</code>
    for drag-over and disabled states.
  </p>

  <h2>Basic</h2>
  <label class="c-file-upload" style="max-inline-size: 30rem;">
    <input type="file" class="c-file-upload__input" multiple />
    <span class="c-file-upload__zone">
      <svg class="c-file-upload__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="c-file-upload__text">
        <strong>Drag files here</strong> or click to browse
      </span>
    </span>
  </label>

  <h2>Single file</h2>
  <label class="c-file-upload" style="max-inline-size: 30rem;">
    <input type="file" class="c-file-upload__input" accept=".png,.jpg,.svg" />
    <span class="c-file-upload__zone">
      <svg class="c-file-upload__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="9" cy="9" r="2" />
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
      </svg>
      <span class="c-file-upload__text">
        <strong>Upload an image</strong><br />PNG, JPG, or SVG
      </span>
    </span>
  </label>

  <h2>Disabled</h2>
  <label class="c-file-upload" style="max-inline-size: 30rem;">
    <input type="file" class="c-file-upload__input" disabled />
    <span class="c-file-upload__zone">
      <svg class="c-file-upload__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="c-file-upload__text">Upload disabled</span>
    </span>
  </label>
</BaseLayout>
