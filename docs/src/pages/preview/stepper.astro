---
import BaseLayout from '../../layouts/BaseLayout.astro';

const steps = [
  { num: '1', label: 'Account', state: 'completed' },
  { num: '2', label: 'Profile', state: 'current' },
  { num: '3', label: 'Preferences', state: 'upcoming' },
  { num: '4', label: 'Confirm', state: 'upcoming' },
];
---
<BaseLayout title="Stepper · Porchlight">
  <h1>Stepper</h1>
  <p>
    A horizontal multi-step indicator with CSS-only connectors. States:
    completed, current, upcoming. Collapses to vertical below 36rem via
    container queries.
  </p>

  <h2>Horizontal (default)</h2>
  <ol class="c-stepper">
    {steps.map((s) => (
      <li class="c-stepper__step" data-state={s.state}>
        <span class="c-stepper__marker">{s.num}</span>
        <span class="c-stepper__label">{s.label}</span>
      </li>
    ))}
  </ol>

  <h2>All completed</h2>
  <ol class="c-stepper" style="margin-block-start: var(--pl-space-6);">
    <li class="c-stepper__step" data-state="completed">
      <span class="c-stepper__marker">1</span>
      <span class="c-stepper__label">Step one</span>
    </li>
    <li class="c-stepper__step" data-state="completed">
      <span class="c-stepper__marker">2</span>
      <span class="c-stepper__label">Step two</span>
    </li>
    <li class="c-stepper__step" data-state="completed">
      <span class="c-stepper__marker">3</span>
      <span class="c-stepper__label">Step three</span>
    </li>
  </ol>

  <h2>In a narrow container (vertical collapse)</h2>
  <div style="max-inline-size: 20rem; margin-block-start: var(--pl-space-6);">
    <ol class="c-stepper">
      <li class="c-stepper__step" data-state="completed">
        <span class="c-stepper__marker">1</span>
        <span class="c-stepper__label">Account created</span>
      </li>
      <li class="c-stepper__step" data-state="current">
        <span class="c-stepper__marker">2</span>
        <span class="c-stepper__label">Verify email</span>
      </li>
      <li class="c-stepper__step" data-state="upcoming">
        <span class="c-stepper__marker">3</span>
        <span class="c-stepper__label">Setup workspace</span>
      </li>
    </ol>
  </div>
</BaseLayout>
