    </li>
    <li>
      <a class="placeholder" href="page-header">
        <strong>Page header</strong><br />
        Title + actions row for use inside containers (no chrome).
      </a>
    </li>
    <li>
      <a class="placeholder" href="pagination">
        <strong>Pagination</strong><br />
