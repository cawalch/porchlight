---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Preview · Porchlight">
  <h1>Preview gallery</h1>
  <p>
    Each Porchlight component ships with a kitchen-sink preview page linked
    here. These pages double as the Playwright visual-regression fixtures.
  </p>
  <ul class="preview-grid">
    <li>
      <a class="placeholder" href="reset">
        <strong>Reset</strong><br />
        Layer order and minimal browser normalization.
      </a>
    </li>
    <li>
      <a class="placeholder" href="tokens">
        <strong>Tokens</strong><br />
        Primitive scales parsed live from source.
      </a>
    </li>
    <li>
      <a class="placeholder" href="themes">
        <strong>Themes &amp; density</strong><br />
        Live light/dark and compact/comfortable/touch playground.
      </a>
    </li>
    <li>
      <a class="placeholder" href="base">
        <strong>Base</strong><br />
        Element defaults and the fluid type scale.
      </a>
    </li>
    <li>
      <a class="placeholder" href="layout">
        <strong>Layout</strong><br />
        SaaS layout primitives: grid, cluster, sidebar, scroll area.
      </a>
    </li>
    <li>
      <a class="placeholder" href="app-shell">
        <strong>App shell</strong><br />
        Desktop SaaS topbar / sidebar / main grid.
      </a>
    </li>
    <li>
      <a class="placeholder" href="button">
        <strong>Button</strong><br />
        The canonical action control: variants, states, density.
      </a>
    </li>
    <li>
      <a class="placeholder" href="split-button">
        <strong>Split button</strong><br />
        Primary action + dropdown toggle with alternative actions.
      </a>
    </li>
    <li>
      <a class="placeholder" href="field">
        <strong>Field</strong><br />
        Native input wrapper: stacked, inline, grouped, states.
      </a>
    </li>
    <li>
      <a class="placeholder" href="form">
        <strong>Form</strong><br />
        SaaS form layouts: grids, choices, filters, billing, actions.
      </a>
    </li>
    <li>
      <a class="placeholder" href="card">
        <strong>Card</strong><br />
        Raised surface: container-query header, interactive variant.
      </a>
    </li>
    <li>
      <a class="placeholder" href="badge">
        <strong>Badge</strong><br />
        Status/count labels: tones via data-tone, WCAG-AA.
      </a>
    </li>
    <li>
      <a class="placeholder" href="popover-menu">
        <strong>Popover menu</strong><br />
        Native Popover API + anchor positioning + @starting-style.
      </a>
    </li>
    <li>
      <a class="placeholder" href="dialog">
        <strong>Dialog</strong><br />
        Native modal dialog: scrim, focus trap, entry/exit animation.
      </a>
    </li>
    <li>
      <a class="placeholder" href="data-table">
        <strong>Data table</strong><br />
        Sticky headers, scroll gutter, row hover, numeric columns.
      </a>
    </li>
    <li>
      <a class="placeholder" href="utilities">
        <strong>Utilities</strong><br />
        Visually-hidden, truncate, flow, surface, muted, full-bleed.
      </a>
    </li>
    <li>
      <a class="placeholder" href="enhancements">
        <strong>Enhancements</strong><br />
        @supports-gated Tier B: sticky-shadow, dividers, text-box.
      </a>
    </li>
    <li>
      <a class="placeholder" href="dashboard">
        <strong>Dashboard</strong><br />
