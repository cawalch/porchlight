---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const b = import.meta.env.BASE_URL;

const previewModules = import.meta.glob('./*.astro');
const previewSlugs = Object.keys(previewModules)
  .map((path) => path.replace('./', '').replace(/\.astro$/, ''))
  .filter((slug) => slug !== 'index')
  .sort((a, z) => a.localeCompare(z));
const previewSlugSet = new Set(previewSlugs);

const documentedEntries = (await getCollection('components')).sort((a, z) =>
  a.data.title.localeCompare(z.data.title),
);
const components = documentedEntries.filter((entry) => entry.data.kind === 'component');
const patterns = documentedEntries.filter((entry) => entry.data.kind === 'pattern');
const documentedSlugSet = new Set(documentedEntries.map((entry) => entry.id));

const foundations = [
  {
    slug: 'reset',
    title: 'Reset',
    description: 'Layer order and minimal browser normalization.',
  },
  {
    slug: 'tokens',
    title: 'Tokens',
    description: 'Primitive scales parsed live from source.',
  },
  {
    slug: 'themes',
    title: 'Themes and density',
    description: 'Light, dark, compact, comfortable, and touch modes.',
  },
  {
    slug: 'base',
    title: 'Base',
    description: 'Element defaults and the fluid type scale.',
  },
  {
    slug: 'layout',
    title: 'Layout',
    description: 'Grid, cluster, sidebar, scroll area, and app shell primitives.',
  },
  {
    slug: 'utilities',
    title: 'Utilities',
    description: 'Screen-reader, truncate, wrapping, flow, surface, and full-bleed helpers.',
  },
  {
    slug: 'enhancements',
    title: 'Enhancements',
    description: '@supports-gated progressive CSS features.',
  },
].filter((item) => previewSlugSet.has(item.slug));
const foundationSlugSet = new Set(foundations.map((item) => item.slug));

const missingDocumentedPreviews = documentedEntries
  .filter((entry) => !previewSlugSet.has(entry.id))
  .map((entry) => entry.id);

if (missingDocumentedPreviews.length > 0) {
  throw new Error(
    `Missing preview pages for documented components or patterns: ${missingDocumentedPreviews.join(', ')}`,
  );
}

const titleize = (slug: string) =>
  slug
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');

const standalonePreviewMeta: Record<string, { title: string; description: string }> = {
  'app-cases': {
    title: 'Case Review',
    description: 'Case-management workspace with dense review surfaces.',
  },
  'app-dashboard': {
    title: 'Responsive dashboard',
    description: 'Full app shell with sidebar navigation, KPI grid, and data table.',
  },
  'app-inbox': {
    title: 'Responsive inbox',
    description: 'Master-detail layout with container-query collapse.',
  },
  'app-marketing': {
    title: 'Marketing page',
    description: 'Full-bleed hero, masonry cards, and scroll animation.',
  },
  'app-shell': {
    title: 'App shell',
    description: 'Desktop SaaS topbar, sidebar, and main work area.',
  },
  'app-siem': {
    title: 'Security SIEM',
    description: 'Security operations console with dense data regions.',
  },
  dashboard: {
    title: 'Dashboard',
    description: 'Enterprise SaaS dashboard composed from Porchlight components.',
  },
  settings: {
    title: 'Settings',
    description: 'SaaS settings page with sidebar navigation, forms, and tabs.',
  },
};

const standalonePreviews = previewSlugs
  .filter((slug) => !documentedSlugSet.has(slug) && !foundationSlugSet.has(slug))
  .map((slug) => ({
    slug,
    title: standalonePreviewMeta[slug]?.title ?? titleize(slug),
    description: standalonePreviewMeta[slug]?.description ?? 'Standalone preview fixture.',
  }))
  .sort((a, z) => a.title.localeCompare(z.title));

const previewTotal = foundations.length + documentedEntries.length + standalonePreviews.length;
const stableCount = components.filter((component) => component.data.status === 'stable').length;
const experimentalCount = components.filter((component) => component.data.status === 'experimental').length;
const plannedCount = components.filter((component) => component.data.status === 'planned').length;
---
<BaseLayout title="Preview · Porchlight">
  <section class="preview-hero" aria-labelledby="preview-title">
    <div>
      <p class="preview-eyebrow">Live QA surface</p>
      <h1 id="preview-title">Preview index</h1>
      <p>
        Searchable live pages for component QA, CSS regression checks, and composed app
        fixtures. Component and pattern entries are generated from the docs collection,
        so missing previews fail the build.
      </p>
    </div>

    <aside class="preview-search-panel" aria-label="Preview search and counts">
      <label class="preview-search">
        <span>Search previews</span>
        <input
          class="pl-c-field__control"
          type="search"
          placeholder="Search preview pages..."
          data-preview-filter
        />
      </label>
      <dl class="preview-stats">
        <div>
          <dt>Total</dt>
          <dd>{previewTotal}</dd>
        </div>
        <div>
          <dt>Components</dt>
          <dd>{components.length}</dd>
        </div>
        <div>
          <dt>Patterns</dt>
          <dd>{patterns.length}</dd>
        </div>
      </dl>
    </aside>
  </section>

  <p class="preview-empty" data-preview-empty hidden>No preview pages match that search.</p>

  <section class="preview-section" aria-labelledby="preview-foundations" data-preview-section>
    <header class="preview-section__header">
      <div>
        <p class="preview-eyebrow">Framework layer</p>
        <h2 id="preview-foundations">Foundations</h2>
      </div>
      <span>{foundations.length} pages</span>
    </header>
    <ul class="preview-grid">
      {foundations.map((item) => (
        <li data-preview-card data-preview-search={`${item.title} ${item.description} ${item.slug}`}>
          <article class="preview-card">
            <a class="preview-card__main" href={`${b}preview/${item.slug}`}>
              <strong>{item.title}</strong>
              <span>{item.description}</span>
            </a>
            <p class="preview-card__meta">
              <span>CSS foundation</span>
              <a href={`${b}preview/${item.slug}`}>Preview</a>
            </p>
          </article>
        </li>
      ))}
    </ul>
  </section>

  <section class="preview-section" aria-labelledby="preview-components" data-preview-section>
    <header class="preview-section__header">
      <div>
        <p class="preview-eyebrow">Generated from docs</p>
        <h2 id="preview-components">Components</h2>
      </div>
      <span>{stableCount} stable / {experimentalCount} experimental / {plannedCount} planned</span>
    </header>
    <ul class="preview-grid">
      {components.map((component) => (
        <li
          data-preview-card
          data-preview-search={`${component.data.title} ${component.data.description ?? ''} ${component.data.status} ${component.id}`}
        >
          <article class="preview-card">
            <a class="preview-card__main" href={`${b}preview/${component.id}`}>
              <strong>{component.data.title}</strong>
              <span>{component.data.description ?? 'Component preview page.'}</span>
            </a>
            <p class="preview-card__meta">
              <span class="preview-card__status" data-status={component.data.status}>{component.data.status}</span>
              <span class="preview-card__links">
                <a href={`${b}preview/${component.id}`}>Preview</a>
                <a href={`${b}components/${component.id}`}>Docs</a>
              </span>
            </p>
          </article>
        </li>
      ))}
    </ul>
  </section>

  <section class="preview-section" aria-labelledby="preview-patterns" data-preview-section>
    <header class="preview-section__header">
      <div>
        <p class="preview-eyebrow">Application recipes</p>
        <h2 id="preview-patterns">SaaS patterns</h2>
      </div>
      <span>{patterns.length} documented patterns</span>
    </header>
    <ul class="preview-grid">
      {patterns.map((pattern) => (
        <li
          data-preview-card
          data-preview-search={`${pattern.data.title} ${pattern.data.description ?? ''} ${pattern.data.status} pattern ${pattern.id}`}
        >
          <article class="preview-card">
            <a class="preview-card__main" href={`${b}preview/${pattern.id}`}>
              <strong>{pattern.data.title}</strong>
              <span>{pattern.data.description ?? 'Application composition pattern.'}</span>
            </a>
            <p class="preview-card__meta">
              <span class="preview-card__status" data-status={pattern.data.status}>{pattern.data.status}</span>
              <span class="preview-card__links">
                <a href={`${b}preview/${pattern.id}`}>Preview</a>
                <a href={`${b}components/${pattern.id}`}>Docs</a>
              </span>
            </p>
          </article>
        </li>
      ))}
    </ul>
  </section>

  {standalonePreviews.length > 0 && (
    <section class="preview-section" aria-labelledby="preview-examples" data-preview-section>
      <header class="preview-section__header">
        <div>
          <p class="preview-eyebrow">Composed screens</p>
          <h2 id="preview-examples">Examples and fixtures</h2>
        </div>
        <span>{standalonePreviews.length} pages</span>
      </header>
      <ul class="preview-grid">
        {standalonePreviews.map((item) => (
          <li data-preview-card data-preview-search={`${item.title} ${item.description} ${item.slug}`}>
            <article class="preview-card">
              <a class="preview-card__main" href={`${b}preview/${item.slug}`}>
                <strong>{item.title}</strong>
                <span>{item.description}</span>
              </a>
              <p class="preview-card__meta">
                <span>Fixture</span>
                <a href={`${b}preview/${item.slug}`}>Preview</a>
              </p>
            </article>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<script>
  const input = document.querySelector<HTMLInputElement>('[data-preview-filter]');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-preview-card]'));
  const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-preview-section]'));
  const empty = document.querySelector<HTMLElement>('[data-preview-empty]');

  const applyFilter = () => {
    const query = input?.value.trim().toLowerCase() ?? '';
    let visibleCount = 0;

    for (const card of cards) {
      const text = card.dataset.previewSearch?.toLowerCase() ?? '';
      const isVisible = query.length === 0 || text.includes(query);
      card.hidden = !isVisible;
      if (isVisible) visibleCount += 1;
    }

    for (const section of sections) {
      section.hidden = !section.querySelector('[data-preview-card]:not([hidden])');
    }

    if (empty) empty.hidden = visibleCount !== 0;
  };

  input?.addEventListener('input', applyFilter);
</script>

<style>
  .preview-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 25rem);
    gap: var(--pl-space-4);
    align-items: stretch;
    padding: var(--pl-space-4);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-2xl);
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--pl-color-surface), var(--pl-color-accent) 5%),
        color-mix(in oklab, var(--pl-color-surface-2), transparent 18%)
      );
    box-shadow: var(--pl-shadow-2);
  }

  .preview-hero > div {
    display: grid;
    align-content: end;
    padding: var(--pl-space-6);
    border-radius: var(--pl-radius-xl);
    background:
      linear-gradient(
        90deg,
        color-mix(in oklab, var(--pl-color-surface), transparent 12%),
        transparent
      );
  }

  .preview-eyebrow {
    margin-block-end: var(--pl-space-2);
    color: var(--pl-color-accent);
    font-size: var(--pl-text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .preview-hero h1 {
    margin-block-end: var(--pl-space-3);
    font-size: var(--pl-text-3xl);
    line-height: var(--pl-leading-tight);
  }

  .preview-hero p:not(.preview-eyebrow) {
    max-inline-size: 58rem;
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-lg);
    line-height: var(--pl-leading-normal);
  }

  .preview-search-panel {
    display: grid;
    gap: var(--pl-space-4);
    align-content: center;
    padding: var(--pl-space-4);
    border: 1px solid color-mix(in oklab, var(--pl-color-accent), transparent 62%);
    border-radius: var(--pl-radius-xl);
    background: color-mix(in oklab, var(--pl-color-surface), transparent 6%);
  }

  .preview-search {
    display: grid;
    gap: var(--pl-space-2);
    margin: 0;
    color: var(--pl-color-text);
    font-size: var(--pl-text-sm);
    font-weight: 700;
  }

  .preview-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--pl-space-3);
    margin: 0;
  }

  .preview-stats div {
    min-inline-size: 0;
    padding: var(--pl-space-3);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
    background: color-mix(in oklab, var(--pl-color-surface), transparent 10%);
  }

  .preview-stats dt {
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-xs);
  }

  .preview-stats dd {
    margin: 0;
    color: var(--pl-color-text);
    font-size: var(--pl-text-xl);
    font-weight: 800;
    line-height: 1;
  }

  .preview-section {
    margin-block-start: var(--pl-space-8);
    padding-block-start: var(--pl-space-5);
    border-block-start: 1px solid var(--pl-color-border);
  }

  .preview-section__header {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-3);
    align-items: end;
    justify-content: space-between;
    margin-block-end: var(--pl-space-3);
  }

  .preview-section__header h2,
  .preview-section__header p {
    margin-block: 0;
  }

  .preview-section__header > span {
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-sm);
  }

  .preview-empty {
    margin-block-start: var(--pl-space-6);
    color: var(--pl-color-text-muted);
  }

  .preview-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--pl-space-3);
    block-size: 100%;
    padding: var(--pl-space-4);
    color: var(--pl-color-text-muted);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--pl-color-surface), transparent 3%),
        color-mix(in oklab, var(--pl-color-surface), var(--pl-color-surface-2) 18%)
      );
    box-shadow: var(--pl-shadow-1);
    text-decoration: none;
  }

  .preview-card::before {
    content: "";
    position: absolute;
    inset-block-start: var(--pl-space-3);
    inset-inline-start: 0;
    inline-size: 3px;
    block-size: 2rem;
    border-radius: var(--pl-radius-pill);
    background: color-mix(in oklab, var(--pl-color-accent), transparent 20%);
  }

  .preview-card:hover {
    border-color: color-mix(in oklab, var(--pl-color-accent), var(--pl-color-border) 55%);
    color: var(--pl-color-text);
    transform: translateY(-1px);
  }

  .preview-card strong {
    display: block;
    color: var(--pl-color-text);
    font-size: var(--pl-text-md);
    line-height: 1.25;
  }

  .preview-card span {
    display: block;
    line-height: 1.45;
  }

  .preview-card__main {
    display: grid;
    gap: var(--pl-space-2);
    color: inherit;
    text-decoration: none;
  }

  .preview-card__main:hover strong {
    color: var(--pl-color-accent);
  }

  .preview-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-2);
    align-items: center;
    justify-content: space-between;
    margin-block: auto 0;
    padding-block-start: var(--pl-space-2);
    border-block-start: 1px solid var(--pl-color-border);
    font-size: var(--pl-text-sm);
  }

  .preview-card__status {
    display: inline-flex;
    align-items: center;
    min-block-size: 1.5rem;
    padding-inline: var(--pl-space-2);
    border-radius: var(--pl-radius-sm);
    background: var(--pl-color-surface-2);
    color: var(--pl-color-text-muted);
    font-weight: 600;
  }

  .preview-card__status[data-status='stable'] {
    color: var(--pl-color-success);
  }

  .preview-card__status[data-status='experimental'] {
    color: var(--pl-color-warning);
  }

  .preview-card__links {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--pl-space-2);
  }

  .preview-card__meta a {
    font-weight: 700;
  }

  @media (width < 46rem) {
    .preview-hero {
      grid-template-columns: 1fr;
    }

    .preview-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
