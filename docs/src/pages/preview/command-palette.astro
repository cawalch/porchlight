---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Command Palette · Porchlight">
  <h1>Command palette</h1>
  <p>
    A Cmd+K quick-action search overlay using the Popover API for top-layer
    rendering. Search input, grouped action list, keyboard navigation hints.
  </p>

  <h2>Open the palette</h2>
  <p>
    <button
      class="c-button"
      data-variant="primary"
      popovertarget="cmdk"
      aria-haspopup="dialog"
      aria-controls="cmdk"
      aria-expanded="false"
    >
      Open command palette
    </button>
  </p>
  <p class="u-muted">Or press Cmd+K / Ctrl+K when focused on this page.</p>

  <div popover class="c-command" id="cmdk" role="dialog" aria-labelledby="cmdk-title">
    <h2 id="cmdk-title" class="u-sr-only">Command palette</h2>
    <input
      class="c-command__search"
      role="combobox"
      aria-expanded="true"
      aria-controls="cmdk-list"
      aria-activedescendant="cmdk-create"
      aria-label="Search commands"
      placeholder="Type a command or search..."
    />
    <div class="c-command__body" id="cmdk-list" role="listbox" aria-label="Commands">
      <div class="c-command__group">
        <h3 class="c-command__heading">Actions</h3>
        <button class="c-command__item" id="cmdk-create" type="button" role="option" aria-selected="true" data-selected>
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round" /></svg>
          <span>Create new project</span>
          <span class="c-command__shortcut">C</span>
        </button>
        <button class="c-command__item" id="cmdk-import" type="button" role="option" aria-selected="false">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round" /></svg>
          <span>Import data</span>
        </button>
        <button class="c-command__item" id="cmdk-invite" type="button" role="option" aria-selected="false">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 8v8M8 12h8" stroke-linecap="round" /></svg>
          <span>Invite team member</span>
        </button>
      </div>
      <div class="c-command__group">
        <h3 class="c-command__heading">Navigate</h3>
        <button class="c-command__item" id="cmdk-dashboard" type="button" role="option" aria-selected="false">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9 12 2l9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke-linecap="round" stroke-linejoin="round" /></svg>
          <span>Go to dashboard</span>
        </button>
        <button class="c-command__item" id="cmdk-settings" type="button" role="option" aria-selected="false">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
          <span>Go to settings</span>
        </button>
      </div>
      <div class="c-command__group">
        <h3 class="c-command__heading">Theme</h3>
        <button class="c-command__item" id="cmdk-light" type="button" role="option" aria-selected="false">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2" stroke-linecap="round" /></svg>
          <span>Switch to light theme</span>
        </button>
        <button class="c-command__item" id="cmdk-dark" type="button" role="option" aria-selected="false">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-linecap="round" stroke-linejoin="round" /></svg>
          <span>Switch to dark theme</span>
        </button>
      </div>
    </div>
    <footer class="c-command__footer">
      <span>↑↓ to navigate</span>
      <span>↵ to select</span>
      <span>esc to close</span>
    </footer>
  </div>

  <script>
    const palette = document.getElementById('cmdk');
    const search = palette?.querySelector('.c-command__search');
    const opener = document.querySelector('[popovertarget="cmdk"]');
    const items = (): HTMLElement[] =>
      Array.from(palette?.querySelectorAll('.c-command__item') ?? []).filter(
        (item): item is HTMLElement => item instanceof HTMLElement,
      );
    let selectedIndex = 0;

    function setSelected(index: number) {
      const commands = items();
      if (!(search instanceof HTMLInputElement) || commands.length === 0) return;
      selectedIndex = (index + commands.length) % commands.length;

      commands.forEach((item, itemIndex) => {
        const selected = itemIndex === selectedIndex;
        item.toggleAttribute('data-selected', selected);
        item.setAttribute('aria-selected', String(selected));
      });

      const selected = commands[selectedIndex];
      search.setAttribute('aria-activedescendant', selected.id);
      selected.scrollIntoView({ block: 'nearest' });
    }

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        palette?.showPopover();
      }
    });

    palette?.addEventListener('toggle', () => {
      const open = palette.matches(':popover-open');
      if (opener instanceof HTMLButtonElement) {
        opener.setAttribute('aria-expanded', String(open));
      }
      if (!(search instanceof HTMLInputElement) || !open) return;
      setSelected(selectedIndex);
      search.focus();
    });

    search?.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;

      const e = event;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setSelected(selectedIndex + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setSelected(selectedIndex - 1);
      } else if (e.key === 'Home') {
        e.preventDefault();
        setSelected(0);
      } else if (e.key === 'End') {
        e.preventDefault();
        setSelected(items().length - 1);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        items()[selectedIndex]?.click();
      } else if (e.key === 'Escape') {
        palette?.hidePopover();
      }
    });

    for (const [index, item] of items().entries()) {
      item.addEventListener('pointerenter', () => setSelected(index));
    }
  </script>
</BaseLayout>
