---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Command Palette · Porchlight">
  <h1>Command palette</h1>
  <p>
    A Cmd+K quick-action search overlay using the Popover API for top-layer
    rendering. Search input, grouped action list, keyboard navigation hints.
  </p>

  <h2>Open the palette</h2>
  <p>
    <button class="c-button" data-variant="primary" popovertarget="cmdk">
      Open command palette
    </button>
  </p>
  <p class="u-muted">Or press Cmd+K / Ctrl+K when focused on this page.</p>

  <div popover class="c-command" id="cmdk">
    <input class="c-command__search" placeholder="Type a command or search..." aria-label="Search commands" />
    <div class="c-command__body">
      <div class="c-command__group">
        <h3 class="c-command__heading">Actions</h3>
        <button class="c-command__item" data-selected>
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round" /></svg>
          <span>Create new project</span>
          <span class="c-command__shortcut">C</span>
        </button>
        <button class="c-command__item">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round" /></svg>
          <span>Import data</span>
        </button>
        <button class="c-command__item">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 8v8M8 12h8" stroke-linecap="round" /></svg>
          <span>Invite team member</span>
        </button>
      </div>
      <div class="c-command__group">
        <h3 class="c-command__heading">Navigate</h3>
        <button class="c-command__item">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9 12 2l9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke-linecap="round" stroke-linejoin="round" /></svg>
          <span>Go to dashboard</span>
        </button>
        <button class="c-command__item">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
          <span>Go to settings</span>
        </button>
      </div>
      <div class="c-command__group">
        <h3 class="c-command__heading">Theme</h3>
        <button class="c-command__item">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2" stroke-linecap="round" /></svg>
          <span>Switch to light theme</span>
        </button>
        <button class="c-command__item">
          <svg class="c-command__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-linecap="round" stroke-linejoin="round" /></svg>
          <span>Switch to dark theme</span>
        </button>
      </div>
    </div>
    <footer class="c-command__footer">
      <span>↑↓ to navigate</span>
      <span>↵ to select</span>
      <span>esc to close</span>
    </footer>
  </div>

  <script>
    // Docs-only: Cmd+K keyboard shortcut.
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        const palette = document.getElementById('cmdk');
        palette?.showPopover();
      }
    });
  </script>
</BaseLayout>
