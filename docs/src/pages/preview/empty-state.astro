---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
---
<BaseLayout title="Empty state · Porchlight">
  <h1>Empty state</h1>
  <p>
    The "no data yet" placeholder — turns a blank screen into an invitation.
    Centered media, title, description, and optional call-to-action. Tone
    variants via <code>[data-tone]</code>.
  </p>

  <h2>Default (no data)</h2>
  <div class="pl-c-card">
    <div class="pl-c-empty">
      <div class="pl-c-empty__media">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <path d="M3 9h18M9 3v18" />
        </svg>
      </div>
      <h2 class="pl-c-empty__title">No accounts yet</h2>
      <p class="pl-c-empty__description">Get started by creating your first account. You can invite team members and configure billing once it's set up.</p>
      <div class="pl-c-empty__actions">
        <button class="pl-c-button" data-variant="primary"><Icon name="plus" /> New account</button>
        <button class="pl-c-button" data-variant="ghost">Import from CSV</button>
      </div>
    </div>
  </div>

  <h2>Search (no results)</h2>
  <div class="pl-c-card">
    <div class="pl-c-empty">
      <div class="pl-c-empty__media">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="7" />
          <path d="m21 21-4.3-4.3" stroke-linecap="round" />
        </svg>
      </div>
      <h2 class="pl-c-empty__title">No results found</h2>
      <p class="pl-c-empty__description">Try adjusting your search or filters to find what you're looking for.</p>
      <div class="pl-c-empty__actions">
        <button class="pl-c-button" data-variant="secondary">Clear filters</button>
      </div>
    </div>
  </div>

  <h2>Error tone</h2>
  <div class="pl-c-card">
    <div class="pl-c-empty" data-tone="danger">
      <div class="pl-c-empty__media">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" stroke-linejoin="round" />
        </svg>
      </div>
      <h2 class="pl-c-empty__title">Failed to load data</h2>
      <p class="pl-c-empty__description">We couldn't reach the server. Check your connection and try again.</p>
      <div class="pl-c-empty__actions">
        <button class="pl-c-button" data-variant="primary">Retry</button>
      </div>
    </div>
  </div>
</BaseLayout>
