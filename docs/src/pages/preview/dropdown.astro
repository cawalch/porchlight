---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Dropdown · Porchlight">
  <h1>Dropdown</h1>
  <p>
    A custom select replacement using the Popover API + anchor positioning.
    Supports icons, descriptions, and fully custom option rendering.
  </p>

  <h2>Basic</h2>
  <div style="max-inline-size: 20rem;">
    <div class="c-dropdown" style="--c-dropdown-anchor: --dd-1;">
      <button class="c-dropdown__trigger" popovertarget="dd-1">
        Select a project
        <svg class="c-dropdown__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </button>
      <div popover class="c-dropdown__menu" id="dd-1">
        <button class="c-dropdown__option" aria-selected="true">Project Alpha</button>
        <button class="c-dropdown__option">Project Beta</button>
        <button class="c-dropdown__option">Project Gamma</button>
        <hr class="c-menu__divider" />
        <button class="c-dropdown__option" data-tone="danger">Delete project</button>
      </div>
    </div>
  </div>

  <h2>With icons</h2>
  <div style="max-inline-size: 20rem;">
    <div class="c-dropdown" style="--c-dropdown-anchor: --dd-2;">
      <button class="c-dropdown__trigger" popovertarget="dd-2">
        Sort by: Name
        <svg class="c-dropdown__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </button>
      <div popover class="c-dropdown__menu" id="dd-2">
        <button class="c-dropdown__option" aria-selected="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="inline-size: 1rem; block-size: 1rem;"><path d="M3 6h18M3 12h12M3 18h6" stroke-linecap="round" /></svg>
          Name (A-Z)
        </button>
        <button class="c-dropdown__option">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="inline-size: 1rem; block-size: 1rem;"><path d="M15 18V6M9 6l6-3 6 3M3 18h12" stroke-linecap="round" /></svg>
          Date created
        </button>
        <button class="c-dropdown__option">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="inline-size: 1rem; block-size: 1rem;"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" stroke-linecap="round" /></svg>
          Last modified
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
