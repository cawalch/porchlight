---
import BaseLayout from '../../layouts/BaseLayout.astro';

type WorkflowCard = {
  id: string;
  title: string;
  body: string;
  badge: string;
  tone: string;
  owner?: string;
  selected?: boolean;
  dragging?: boolean;
  high?: boolean;
};

type WorkflowLane = {
  title: string;
  count: number;
  wip: string;
  state?: string;
  drop?: boolean;
  cards: WorkflowCard[];
};

const lanes: WorkflowLane[] = [
  {
    title: 'Intake',
    count: 7,
    wip: '7 / 10',
    state: 'warning',
    cards: [
      { id: 'REQ-2418', title: 'Vendor onboarding', body: 'Security review waiting on SOC 2 packet.', badge: 'SLA', tone: 'warning', owner: 'MS', selected: true },
      { id: 'REQ-2406', title: 'Policy exception', body: 'Finance approval needed for spend cap override.', badge: 'Risk', tone: 'danger' },
    ],
  },
  {
    title: 'Review',
    count: 5,
    wip: '5 / 8',
    drop: true,
    cards: [
      { id: 'REQ-2399', title: 'Access recertification', body: 'Manager attestation complete; IT review open.', badge: 'IT', tone: 'accent', dragging: true },
      { id: 'REQ-2391', title: 'Renewal approval', body: 'Contract value changed after legal redline.', badge: 'Legal', tone: 'accent' },
    ],
  },
  {
    title: 'Decision',
    count: 3,
    wip: '3 / 6',
    cards: [
      { id: 'REQ-2388', title: 'High-value refund', body: 'Requires director approval before payout.', badge: 'Urgent', tone: 'danger', high: true },
      { id: 'REQ-2375', title: 'Partner exception', body: 'Compliance sign-off added to request trail.', badge: 'OK', tone: 'success' },
    ],
  },
  {
    title: 'Done',
    count: 12,
    wip: '12',
    cards: [
      { id: 'REQ-2364', title: 'Address change', body: 'Verified and synced to billing workspace.', badge: 'Done', tone: 'success' },
    ],
  },
];
---
<BaseLayout title="Workflow board · Porchlight">
  <section class="workflow-preview">
    <header class="workflow-preview__header">
      <div>
        <h1>Workflow board</h1>
        <p>CSS-only lanes, swimlanes, cards, counts, WIP status, and app-owned drag/drop states.</p>
      </div>
      <div class="pl-c-segmented" role="radiogroup" aria-label="Queue scope">
        <label class="pl-c-segmented__item"><input type="radio" name="scope" checked /><span>Team</span></label>
        <label class="pl-c-segmented__item"><input type="radio" name="scope" /><span>Mine</span></label>
        <label class="pl-c-segmented__item"><input type="radio" name="scope" /><span>Escalated</span></label>
      </div>
    </header>

    <section class="pl-c-workflow-board" aria-labelledby="claims-board-title">
      <div class="pl-c-workflow-board__header">
        <div>
          <h2 class="pl-c-workflow-board__title" id="claims-board-title">Operations work queue</h2>
          <p class="pl-c-workflow-board__meta">27 open requests across onboarding, approvals, and exceptions</p>
        </div>
        <div class="pl-c-workflow-board__tools">
          <span class="pl-c-badge" data-tone="warning">4 SLA risks</span>
          <button class="pl-c-button" data-variant="secondary" data-size="sm">Export</button>
          <button class="pl-c-button" data-variant="primary" data-size="sm">New request</button>
        </div>
      </div>

      <section class="pl-c-workflow-board__swimlane" aria-labelledby="enterprise-lane">
        <div class="pl-c-workflow-board__swimlane-header">
          <h3 class="pl-c-workflow-board__swimlane-title" id="enterprise-lane">Enterprise accounts</h3>
          <span class="pl-c-workflow-board__swimlane-meta">12 accounts affected</span>
        </div>
        <div class="pl-c-workflow-board__lanes" data-scroll="inline">
          {lanes.map((lane) => (
            <section class="pl-c-workflow-lane" aria-labelledby={`lane-${lane.title.toLowerCase()}`} data-drop-target={lane.drop ? '' : undefined}>
              <header class="pl-c-workflow-lane__header">
                <div class="pl-c-workflow-lane__heading">
                  <h4 class="pl-c-workflow-lane__title" id={`lane-${lane.title.toLowerCase()}`}>{lane.title}</h4>
                  <span class="pl-c-workflow-lane__count">{lane.count}</span>
                </div>
                <span class="pl-c-workflow-lane__wip" data-state={lane.state}>{lane.wip.includes('/') ? `WIP ${lane.wip}` : `${lane.wip} completed`}</span>
              </header>
              <div class="pl-c-workflow-lane__body">
                {lane.cards.map((card) => (
                  <article
                    class="pl-c-workflow-card"
                    data-selected={card.selected ? '' : undefined}
                    data-dragging={card.dragging ? '' : undefined}
                    data-priority={card.high ? 'high' : undefined}
                  >
                    <div class="pl-c-workflow-card__header">
                      <h5 class="pl-c-workflow-card__title">{card.title}</h5>
                      <span class="pl-c-badge" data-tone={card.tone}>{card.badge}</span>
                    </div>
                    <p class="pl-c-workflow-card__body">{card.body}</p>
                    <div class="pl-c-workflow-card__footer">
                      <div class="pl-c-workflow-card__meta">
                        <span>{card.id}</span>
                        <time datetime="2026-06-29">Today</time>
                      </div>
                      <div class="pl-c-workflow-card__assignees" aria-label="Assignees">
                        <span class="pl-c-avatar" data-size="sm">{card.owner ?? 'JD'}</span>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </section>

      <section class="pl-c-workflow-board__swimlane" aria-labelledby="regional-lane">
        <div class="pl-c-workflow-board__swimlane-header">
          <h3 class="pl-c-workflow-board__swimlane-title" id="regional-lane">Regional accounts</h3>
          <span class="pl-c-workflow-board__swimlane-meta">Lower-volume queue with empty lane state</span>
        </div>
        <div class="pl-c-workflow-board__lanes">
          <section class="pl-c-workflow-lane" aria-labelledby="regional-intake">
            <header class="pl-c-workflow-lane__header">
              <div class="pl-c-workflow-lane__heading">
                <h4 class="pl-c-workflow-lane__title" id="regional-intake">Intake</h4>
                <span class="pl-c-workflow-lane__count">0</span>
              </div>
            </header>
            <div class="pl-c-workflow-lane__body">
              <div class="pl-c-workflow-lane__empty">No intake work for this swimlane.</div>
            </div>
          </section>
          <section class="pl-c-workflow-lane" aria-labelledby="regional-review" aria-disabled="true">
            <header class="pl-c-workflow-lane__header">
              <div class="pl-c-workflow-lane__heading">
                <h4 class="pl-c-workflow-lane__title" id="regional-review">Review paused</h4>
                <span class="pl-c-workflow-lane__count">2</span>
              </div>
            </header>
            <div class="pl-c-workflow-lane__body">
              <article class="pl-c-workflow-card">
                <div class="pl-c-workflow-card__header">
                  <h5 class="pl-c-workflow-card__title">Manual address verification</h5>
                  <span class="pl-c-badge">Paused</span>
                </div>
                <p class="pl-c-workflow-card__body">Lane disabled while the source system is read-only.</p>
              </article>
            </div>
          </section>
        </div>
      </section>
    </section>
  </section>
</BaseLayout>

<style>
  .workflow-preview {
    display: grid;
    gap: var(--pl-space-6);
  }

  .workflow-preview__header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: var(--pl-space-4);
  }

  .workflow-preview__header p {
    max-inline-size: 62ch;
    color: var(--pl-color-text-muted);
  }
</style>
