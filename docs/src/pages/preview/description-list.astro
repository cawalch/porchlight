---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Description list · Porchlight">
  <h1>Description list</h1>
  <p>
    A key-value grid for detail panels, metadata displays, and summary cards.
    Wraps the native <code>&lt;dl&gt;</code> element. The most-rebuilt pattern
    in SaaS apps after page headers.
  </p>

  <h2>Account detail panel</h2>
  <div class="pl-l-grid description-grid-wide">
    <div class="pl-c-card">
      <div class="pl-c-card__header">
        <h2 class="pl-c-card__title">Acme Corporation</h2>
      </div>
      <div class="pl-c-card__body">
        <dl class="pl-c-description">
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Status</dt>
            <dd class="pl-c-description__detail"><span class="pl-c-badge" data-tone="success">Active</span></dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Plan</dt>
            <dd class="pl-c-description__detail">Enterprise</dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">MRR</dt>
            <dd class="pl-c-description__detail">$2,400/mo</dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Owner</dt>
            <dd class="pl-c-description__detail">Jane Smith</dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Created</dt>
            <dd class="pl-c-description__detail">Jan 15, 2024</dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="pl-c-card">
      <div class="pl-c-card__header">
        <h2 class="pl-c-card__title">With dividers</h2>
      </div>
      <div class="pl-c-card__body">
        <dl class="pl-c-description" data-dividers>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Case ID</dt>
            <dd class="pl-c-description__detail description-mono">CASE-2024-0815</dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Priority</dt>
            <dd class="pl-c-description__detail"><span class="pl-c-badge" data-tone="warning">High</span></dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Assignee</dt>
            <dd class="pl-c-description__detail">
              <div class="pl-c-avatar description-inline-avatar" data-size="sm">MK</div>
              Marcus Kane
            </dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Tags</dt>
            <dd class="pl-c-description__detail">
              <span class="pl-c-chip-group">
                <span class="pl-c-chip">fraud</span>
                <span class="pl-c-chip" data-tone="warning">escalated</span>
              </span>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <h2>Stacked layout</h2>
  <div class="pl-l-grid description-grid-compact">
    <div class="pl-c-card">
      <div class="pl-c-card__body">
        <dl class="pl-c-description" data-layout="stacked">
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Last login</dt>
            <dd class="pl-c-description__detail">2 hours ago from 192.168.1.42</dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Two-factor auth</dt>
            <dd class="pl-c-description__detail"><span class="pl-c-badge" data-tone="success">Enabled</span></dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Session count</dt>
            <dd class="pl-c-description__detail">3 active sessions</dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="pl-c-card">
      <div class="pl-c-card__body">
        <dl class="pl-c-description" data-layout="stacked" data-dividers>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Region</dt>
            <dd class="pl-c-description__detail">us-east-1</dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">API key</dt>
            <dd class="pl-c-description__detail description-mono">pk_live_••••••••4242</dd>
          </div>
          <div class="pl-c-description__row">
            <dt class="pl-c-description__term">Rate limit</dt>
            <dd class="pl-c-description__detail">1,000 req/min</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <h2>Uniform term width</h2>
  <p>
    Set <code>--pl-c-description-term-w</code> to a fixed width for a uniform
    label gutter across multiple cards.
  </p>
  <div class="pl-c-card">
    <div class="pl-c-card__body">
      <dl class="pl-c-description description-fixed-terms">
        <div class="pl-c-description__row">
          <dt class="pl-c-description__term">Total revenue</dt>
          <dd class="pl-c-description__detail">$148,200</dd>
        </div>
        <div class="pl-c-description__row">
          <dt class="pl-c-description__term">Active subscriptions</dt>
          <dd class="pl-c-description__detail">247</dd>
        </div>
        <div class="pl-c-description__row">
          <dt class="pl-c-description__term">Avg. contract value</dt>
          <dd class="pl-c-description__detail">$600/mo</dd>
        </div>
      </dl>
    </div>
  </div>

  <h2>Inside a drawer (container-query collapse)</h2>
  <p>
    The grid mode collapses to stacked below 32rem container width —
    simulating the panel width of a side drawer.
  </p>
  <div class="description-drawer-demo">
    <dl class="pl-c-description">
      <div class="pl-c-description__row">
        <dt class="pl-c-description__term">Subject</dt>
        <dd class="pl-c-description__detail">Quarterly review prep</dd>
      </div>
      <div class="pl-c-description__row">
        <dt class="pl-c-description__term">Priority</dt>
        <dd class="pl-c-description__detail"><span class="pl-c-badge" data-tone="danger">Urgent</span></dd>
      </div>
      <div class="pl-c-description__row">
        <dt class="pl-c-description__term">Due date</dt>
        <dd class="pl-c-description__detail">Jun 30, 2024</dd>
      </div>
    </dl>
  </div>
</BaseLayout>

<style>
  .description-grid-wide {
    --pl-l-grid-min: 24rem;
  }

  .description-grid-compact {
    --pl-l-grid-min: 16rem;
  }

  .description-mono {
    font-family: var(--pl-font-mono);
  }

  .description-inline-avatar {
    display: inline-flex;
    margin-inline-end: var(--pl-space-2);
    vertical-align: middle;
  }

  .description-fixed-terms {
    --pl-c-description-term-w: 10rem;
  }

  .description-drawer-demo {
    max-inline-size: 28rem;
    padding: var(--pl-space-5);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-xl);
  }
</style>
