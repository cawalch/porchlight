---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
---
<BaseLayout title="Dialog · Porchlight">
  <h1>Dialog</h1>
  <p>
    A modal dialog for confirmations, forms, and detail views. Uses the native
    <code>&lt;dialog&gt;</code> element with <code>showModal()</code> (top-layer,
    modal focus trap, Esc to close). The <code>::backdrop</code> pseudo-element
    provides the scrim. Enter/exit animation via <code>@starting-style</code>.
  </p>

  <h2>Confirmation dialog</h2>
  <p>The canonical SaaS pattern — a destructive confirmation.</p>
  <div class="demo-row">
    <button class="c-button" data-variant="danger" data-open="confirm-dialog">
      Delete account
    </button>
  </div>

  <h2>Form dialog</h2>
  <p>A modal form — create/edit flows that don't deserve a full page.</p>
  <div class="demo-row">
    <button class="c-button" data-variant="primary" data-open="form-dialog">
      <Icon name="plus" /> New workspace
    </button>
  </div>

  <dialog class="c-dialog" id="confirm-dialog">
    <header class="c-dialog__header">
      <h2 class="c-dialog__title">Delete account?</h2>
      <button class="c-dialog__close" type="button" aria-label="Close" data-close>✕</button>
    </header>
    <div class="c-dialog__body">
      <p>This will permanently delete the workspace and all its data. This action cannot be undone.</p>
    </div>
    <footer class="c-dialog__footer">
      <button class="c-button" data-variant="ghost" data-close>Cancel</button>
      <button class="c-button" data-variant="danger" data-close>Delete</button>
    </footer>
  </dialog>

  <dialog class="c-dialog" id="form-dialog" style="--c-dialog-size: 36rem;">
    <header class="c-dialog__header">
      <h2 class="c-dialog__title">New workspace</h2>
      <button class="c-dialog__close" type="button" aria-label="Close" data-close>✕</button>
    </header>
    <div class="c-dialog__body">
      <div class="l-stack">
        <label class="c-field">
          <span class="c-field__label">Workspace name</span>
          <input class="c-field__control" placeholder="Acme Ops" />
        </label>
        <label class="c-field">
          <span class="c-field__label">Workspace URL</span>
          <input class="c-field__control" type="url" placeholder="https://" />
        </label>
      </div>
    </div>
    <footer class="c-dialog__footer">
      <button class="c-button" data-variant="ghost" data-close>Cancel</button>
      <button class="c-button" data-variant="primary" data-close>Create</button>
    </footer>
  </dialog>

  <h2>Keyboard interaction</h2>
  <ul>
    <li><kbd>Tab</kbd> to the trigger, <kbd>Enter</kbd>/<kbd>Space</kbd> to open.</li>
    <li><kbd>Esc</kbd> closes the dialog (native behavior).</li>
    <li>Focus is trapped inside the dialog while open (native modal behavior).</li>
  </ul>
</BaseLayout>

<script>
  // Docs-only: wire triggers and close buttons. In a real app, use showModal()
  // from your app's event handler — the framework itself has no JS.
  document.querySelectorAll('[data-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-open');
      if (!id) return;
      const el = document.getElementById(id) as HTMLDialogElement | null;
      el?.showModal();
    });
  });
  document.querySelectorAll('[data-close]').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('dialog')?.close();
    });
  });
</script>

<style>
  .demo-row {
    display: flex;
    align-items: center;
    gap: var(--pl-space-4);
    margin-block-end: var(--pl-space-5);
  }
</style>
