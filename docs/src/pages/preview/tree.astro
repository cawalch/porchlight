---
import BaseLayout from '../../layouts/BaseLayout.astro';

const folderIcon = '<path d="M3 6.5A2.5 2.5 0 0 1 5.5 4H10l2 2.5h6.5A2.5 2.5 0 0 1 21 9v8.5A2.5 2.5 0 0 1 18.5 20h-13A2.5 2.5 0 0 1 3 17.5z" />';
const ruleIcon = '<path d="M8 6h13"/><path d="M8 12h13"/><path d="M8 18h13"/><path d="m3 6 1 1 2-2"/><path d="m3 12 1 1 2-2"/><path d="m3 18 1 1 2-2"/>';
const processIcon = '<rect x="3" y="4" width="7" height="6" rx="1.5"/><rect x="14" y="4" width="7" height="6" rx="1.5"/><rect x="8.5" y="14" width="7" height="6" rx="1.5"/><path d="M10 7h4"/><path d="M17.5 10v2a2 2 0 0 1-2 2h-7a2 2 0 0 0-2 2v1"/>';
const chevron = '<path d="m9 18 6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>';
---
<BaseLayout title="Tree view · Porchlight">
  <h1>Tree view</h1>
  <p>
    Role-first tree markup for object explorers, process folders, rule
    libraries, and nested SaaS navigation. CSS styles the rendered state; app
    code owns keyboard movement, selection, loading, and persistence.
  </p>

  <section class="tree-shell" aria-label="Process builder object explorer">
    <aside class="tree-shell__sidebar">
      <header class="tree-shell__header">
        <div>
          <p class="tree-shell__eyebrow">Workspace</p>
          <h2>Claims automation</h2>
        </div>
        <button class="tree-shell__icon-button" type="button" aria-label="Add folder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
        </button>
      </header>

      <div class="pl-c-tree" role="tree" aria-label="Claims automation library" data-actions="persistent">
        <div class="pl-c-tree__item" role="treeitem" aria-expanded="true" tabindex="0">
          <div class="pl-c-tree__item-row">
            <span class="pl-c-tree__expander" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={chevron} />
            </span>
            <span class="pl-c-tree__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={folderIcon} />
            </span>
            <span class="pl-c-tree__label">Intake processes</span>
            <span class="pl-c-tree__badge">8</span>
          </div>
          <div class="pl-c-tree__group" role="group">
            <div class="pl-c-tree__item" role="treeitem" aria-current="page" aria-selected="true" tabindex="-1">
              <div class="pl-c-tree__item-row">
                <span class="pl-c-tree__expander" aria-hidden="true"></span>
                <span class="pl-c-tree__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={processIcon} />
                </span>
                <span class="pl-c-tree__label">FNOL triage</span>
                <span class="pl-c-tree__meta">v18</span>
                <span class="pl-c-tree__actions">
                  <button class="pl-c-tree__action" type="button" aria-label="Open FNOL triage actions">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 12h.01"/><path d="M19 12h.01"/><path d="M5 12h.01"/></svg>
                  </button>
                </span>
              </div>
            </div>
            <div class="pl-c-tree__item" role="treeitem" tabindex="-1">
              <div class="pl-c-tree__item-row">
                <span class="pl-c-tree__expander" aria-hidden="true"></span>
                <span class="pl-c-tree__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={processIcon} />
                </span>
                <span class="pl-c-tree__label">Coverage verification</span>
                <span class="pl-c-tree__meta">draft</span>
              </div>
            </div>
          </div>
        </div>

        <div class="pl-c-tree__item" role="treeitem" aria-expanded="true" tabindex="-1">
          <div class="pl-c-tree__item-row">
            <span class="pl-c-tree__expander" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={chevron} />
            </span>
            <span class="pl-c-tree__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={folderIcon} />
            </span>
            <span class="pl-c-tree__label">Rule sets</span>
            <span class="pl-c-tree__badge">24</span>
          </div>
          <div class="pl-c-tree__group" role="group">
            <div class="pl-c-tree__item" role="treeitem" tabindex="-1">
              <div class="pl-c-tree__item-row">
                <span class="pl-c-tree__expander" aria-hidden="true"></span>
                <span class="pl-c-tree__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={ruleIcon} />
                </span>
                <span class="pl-c-tree__label">High-value loss routing</span>
                <span class="pl-c-tree__meta">3 changed</span>
              </div>
            </div>
            <div class="pl-c-tree__item" role="treeitem" aria-disabled="true" tabindex="-1">
              <div class="pl-c-tree__item-row">
                <span class="pl-c-tree__expander" aria-hidden="true"></span>
                <span class="pl-c-tree__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={ruleIcon} />
                </span>
                <span class="pl-c-tree__label">Regulatory hold rules</span>
                <span class="pl-c-tree__meta">locked</span>
              </div>
            </div>
          </div>
        </div>

        <div class="pl-c-tree__item" role="treeitem" aria-expanded="false" tabindex="-1">
          <div class="pl-c-tree__item-row">
            <span class="pl-c-tree__expander" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={chevron} />
            </span>
            <span class="pl-c-tree__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={folderIcon} />
            </span>
            <span class="pl-c-tree__label">Archived experiments</span>
            <span class="pl-c-tree__badge">6</span>
          </div>
          <div class="pl-c-tree__group" role="group">
            <div class="pl-c-tree__item" role="treeitem" tabindex="-1">
              <div class="pl-c-tree__item-row">
                <span class="pl-c-tree__label">Legacy routing pilot</span>
              </div>
            </div>
          </div>
        </div>

        <div class="pl-c-tree__item" role="treeitem" aria-busy="true" tabindex="-1">
          <div class="pl-c-tree__item-row">
            <span class="pl-c-tree__expander" aria-hidden="true"></span>
            <span class="pl-c-tree__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={folderIcon} />
            </span>
            <span class="pl-c-tree__label">Shared templates</span>
          </div>
        </div>
      </div>
    </aside>

    <main class="tree-shell__main">
      <header class="tree-shell__main-header">
        <div>
          <p class="tree-shell__eyebrow">Selected process</p>
          <h2>FNOL triage</h2>
        </div>
        <span class="pl-c-badge" data-tone="success">Published</span>
      </header>
      <div class="tree-shell__canvas" aria-label="Process summary">
        <div class="process-card">
          <span class="process-card__step">1</span>
          <div>
            <h3>Receive claim</h3>
            <p>Validate channel, jurisdiction, and coverage signals.</p>
          </div>
        </div>
        <div class="process-card">
          <span class="process-card__step">2</span>
          <div>
            <h3>Score urgency</h3>
            <p>Apply high-value loss routing and fraud-screening rules.</p>
          </div>
        </div>
        <div class="process-card">
          <span class="process-card__step">3</span>
          <div>
            <h3>Assign handler</h3>
            <p>Route to the right team with SLA and compliance metadata.</p>
          </div>
        </div>
      </div>
    </main>
  </section>
</BaseLayout>

<style>
  .tree-shell {
    display: grid;
    grid-template-columns: minmax(16rem, 20rem) minmax(0, 1fr);
    min-block-size: clamp(30rem, 68vh, 42rem);
    margin-block-start: var(--pl-space-5);
    overflow: hidden;
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-xl);
    background: var(--pl-color-bg);
  }

  .tree-shell__sidebar {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: var(--pl-space-3);
    min-inline-size: 0;
    padding: var(--pl-space-3);
    border-inline-end: 1px solid var(--pl-color-border);
    background: var(--pl-color-surface);
  }

  .tree-shell__header,
  .tree-shell__main-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--pl-space-3);
  }

  .tree-shell__header h2,
  .tree-shell__main-header h2 {
    margin: 0;
    font-size: var(--pl-text-lg);
    line-height: var(--pl-leading-tight);
  }

  .tree-shell__eyebrow {
    margin: 0;
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-xs);
    font-weight: var(--pl-font-weight-semibold);
    line-height: var(--pl-leading-tight);
    text-transform: uppercase;
  }

  .tree-shell__icon-button {
    display: inline-grid;
    place-items: center;
    inline-size: 2rem;
    block-size: 2rem;
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-md);
    background: var(--pl-color-surface);
    color: var(--pl-color-text-muted);
  }

  .tree-shell__icon-button svg {
    inline-size: 1rem;
    block-size: 1rem;
  }

  .tree-shell__main {
    min-inline-size: 0;
    padding: var(--pl-space-5);
    overflow: auto;
  }

  .tree-shell__canvas {
    display: grid;
    gap: var(--pl-space-3);
    max-inline-size: 42rem;
    margin-block-start: var(--pl-space-5);
  }

  .process-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--pl-space-3);
    padding: var(--pl-space-4);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
    background: var(--pl-color-surface);
  }

  .process-card h3,
  .process-card p {
    margin: 0;
  }

  .process-card p {
    color: var(--pl-color-text-muted);
  }

  .process-card__step {
    display: inline-grid;
    place-items: center;
    inline-size: 2rem;
    block-size: 2rem;
    border-radius: var(--pl-radius-md);
    background: color-mix(in oklab, var(--pl-color-accent), transparent 88%);
    color: var(--pl-color-accent);
    font-weight: var(--pl-font-weight-semibold);
  }

  @media (width < 48rem) {
    .tree-shell {
      grid-template-columns: 1fr;
    }

    .tree-shell__sidebar {
      border-inline-end: 0;
      border-block-end: 1px solid var(--pl-color-border);
    }
  }
</style>
