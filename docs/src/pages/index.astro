---
import BaseLayout from '../layouts/BaseLayout.astro';

const b = import.meta.env.BASE_URL;

const features = [
  {
    icon: 'CSS',
    title: 'Zero JavaScript',
    body: 'Every component is pure CSS. No runtime, no bundle, no hydration. Behavior (tab switching, toggles) is the app\u2019s job via data attributes.',
  },
  {
    icon: 'WCAG',
    title: 'WCAG-AA verified',
    body: 'Color pairs are tested for contrast in both light and dark themes. Forced-colors, reduced-motion, RTL, and 200% zoom are all covered.',
  },
  {
    icon: '@scope',
    title: 'Modern CSS first',
    body: '@scope, @layer, @property, OKLCH, light-dark(), color-mix(), :has(), container queries, Popover API, anchor positioning. Baseline 2025+.',
  },
  {
    icon: '--pl-*',
    title: 'Token-driven',
    body: 'Override one custom property to retheme the entire system. Primitive scales, semantic pairs, and per-component --c-* tokens.',
  },
];

const stats = [
  { label: 'Components', value: '34' },
  { label: 'Tests', value: '151' },
  { label: 'Dependencies', value: '0' },
  { label: 'Bundle size', value: '~27kb' },
];
---
<BaseLayout>
  <section class="hero">
    <h1>Porchlight</h1>
    <p class="hero__lede">A no-dependency, native-CSS framework for building accessible, themeable web applications.</p>
    <p class="hero__status">Pre-1.0, in active development.</p>
    <div class="hero__actions">
      <a class="hero__cta" href={`${b}guides/getting-started`}>Get started</a>
      <a class="hero__link" href={`${b}preview`}>View components</a>
    </div>
  </section>

  <section class="stats">
    {stats.map((s) => (
      <div class="stat">
        <span class="stat__value">{s.value}</span>
        <span class="stat__label">{s.label}</span>
      </div>
    ))}
  </section>

  <section class="features">
    {features.map((f) => (
      <div class="feature">
        <span class="feature__icon">{f.icon}</span>
        <h2 class="feature__title">{f.title}</h2>
        <p class="feature__body">{f.body}</p>
      </div>
    ))}
  </section>

  <section class="cta-section">
    <h2>Ready to build?</h2>
    <p>Install in one command and start using components in minutes.</p>
    <pre><code>pnpm add @cawalch/porchlight</code></pre>
    <div class="cta-section__actions">
      <a class="hero__cta" href={`${b}guides/getting-started`}>Read the guide</a>
      <a class="hero__link" href="https://github.com/cawalch/porchlight">Star on GitHub</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding-block: clamp(3rem, 2rem + 5vi, 6rem);
  }

  .hero h1 {
    margin-block-end: var(--pl-space-3);
    font-size: clamp(2.5rem, 1.5rem + 5vi, 4rem);
    line-height: 1.05;
    text-wrap: balance;
  }

  .hero__lede {
    max-inline-size: 40ch;
    margin-inline: auto;
    color: var(--pl-color-text-muted);
    font-size: clamp(1.125rem, 1rem + 0.5vi, 1.375rem);
  }

  .hero__status {
    margin-block-start: var(--pl-space-2);
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-sm);
  }

  .hero__actions {
    display: flex;
    gap: var(--pl-space-3);
    justify-content: center;
    margin-block-start: var(--pl-space-5);
  }

  .hero__cta {
    display: inline-block;
    padding: var(--pl-space-3) var(--pl-space-5);
    border-radius: var(--pl-radius-lg);
    background: var(--pl-color-accent);
    color: var(--pl-color-accent-text);
    font-weight: 600;
    text-decoration: none;
    transition: filter var(--pl-duration-1) var(--pl-ease-standard);
  }

  .hero__cta:hover {
    filter: brightness(1.08);
    color: var(--pl-color-accent-text);
  }

  .hero__link {
    display: inline-block;
    padding: var(--pl-space-3) var(--pl-space-5);
    color: var(--pl-color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .hero__link:hover {
    text-decoration: underline;
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-4);
    justify-content: center;
    padding-block: var(--pl-space-6);
    border-block: 1px solid var(--pl-color-border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pl-space-1);
  }

  .stat__value {
    font-size: var(--pl-text-xl);
    font-weight: 700;
    color: var(--pl-color-accent);
  }

  .stat__label {
    font-size: var(--pl-text-sm);
    color: var(--pl-color-text-muted);
  }

  .features {
    display: grid;
    gap: var(--pl-space-5);
    grid-template-columns: repeat(2, 1fr);
    padding-block: var(--pl-space-8);
  }

  @media (width < 36rem) {
    .features {
      grid-template-columns: 1fr;
    }
  }

  .feature {
    padding: var(--pl-space-5);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
    background: var(--pl-color-surface);
  }

  .feature__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: 2.5rem;
    block-size: 2.5rem;
    padding-inline: var(--pl-space-2);
    margin-block-end: var(--pl-space-3);
    border-radius: var(--pl-radius-md);
    background: color-mix(in oklab, var(--pl-color-accent), transparent 88%);
    color: var(--pl-color-accent);
    font-family: var(--pl-font-mono);
    font-size: var(--pl-text-xs);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .feature__title {
    margin-block-end: var(--pl-space-2);
    font-size: var(--pl-text-md);
    font-weight: 600;
  }

  .feature__body {
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-sm);
    line-height: var(--pl-leading-normal);
  }

  .cta-section {
    text-align: center;
    padding-block: var(--pl-space-8);
  }

  .cta-section h2 {
    font-size: var(--pl-text-xl);
    margin-block-end: var(--pl-space-2);
  }

  .cta-section p {
    color: var(--pl-color-text-muted);
    margin-block-end: var(--pl-space-4);
  }

  .cta-section pre {
    display: inline-block;
    margin-block-end: var(--pl-space-4);
    padding: var(--pl-space-3) var(--pl-space-5);
    border-radius: var(--pl-radius-lg);
    background: var(--pl-color-surface-2);
    font-size: var(--pl-text-sm);
    font-family: var(--pl-font-mono);
  }

  .cta-section__actions {
    display: flex;
    gap: var(--pl-space-3);
    justify-content: center;
  }
</style>
