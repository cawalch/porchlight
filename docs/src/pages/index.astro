---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const b = import.meta.env.BASE_URL;

const documentedEntries = (await getCollection('components')).sort((a, z) =>
  a.data.title.localeCompare(z.data.title),
);
const components = documentedEntries.filter((entry) => entry.data.kind === 'component');
const patterns = documentedEntries.filter((entry) => entry.data.kind === 'pattern');
const guides = (await getCollection('guides')).sort((a, z) =>
  (a.data.order ?? 0) - (z.data.order ?? 0),
);
const tokens = await getCollection('tokens');
const previewModules = import.meta.glob('./preview/*.astro');
const previewCount = Object.keys(previewModules).filter((path) => !path.endsWith('/index.astro')).length;

const stableCount = components.filter((component) => component.data.status === 'stable').length;

const startLinks = [
  {
    label: 'Install and wire CSS',
    href: `${b}guides/getting-started`,
    detail: 'Package entry, import order, and the first component.',
  },
  {
    label: 'Browse components',
    href: `${b}components/button`,
    detail: `${components.length} contracts with HTML, states, tokens, and accessibility notes.`,
  },
  {
    label: 'Open live previews',
    href: `${b}preview`,
    detail: `${previewCount} generated fixtures for visual QA and layout checks.`,
  },
  {
    label: 'Check tokens',
    href: `${b}tokens`,
    detail: `${tokens.length} token reference pages backed by the framework source.`,
  },
];

const guideGroups = [
  {
    title: 'Build',
    links: guides.filter((guide) => ['getting-started', 'theming', 'browser-support'].includes(guide.id)),
  },
  {
    title: 'Design system',
    links: guides.filter((guide) => ['architecture', 'layout', 'composition-recipes'].includes(guide.id)),
  },
  {
    title: 'CSS layer',
    links: guides.filter((guide) => ['utilities', 'enhancements'].includes(guide.id)),
  },
];

const entryHighlights = [
  'button',
  'field',
  'data-table',
  'nav',
  'dialog',
  'app-process-builder',
]
  .map((id) => documentedEntries.find((entry) => entry.id === id))
  .filter(Boolean);
---
<BaseLayout>
  <section class="home-dashboard" aria-labelledby="home-title">
    <div class="home-hero">
      <p class="home-eyebrow">Native CSS design system</p>
      <h1 id="home-title">Porchlight</h1>
      <p>
        Docs, component contracts, token references, and live preview fixtures for building
        accessible application UI without a JavaScript runtime dependency.
      </p>
      <div class="home-actions">
        <a class="home-action home-action--primary" href={`${b}guides/getting-started`}>Start</a>
        <a class="home-action" href={`${b}preview`}>Preview directory</a>
      </div>
    </div>

    <aside class="home-snapshot" aria-label="Project snapshot">
      <dl>
        <div>
          <dt>Components</dt>
          <dd>{components.length}</dd>
        </div>
        <div>
          <dt>Patterns</dt>
          <dd>{patterns.length}</dd>
        </div>
        <div>
          <dt>Stable components</dt>
          <dd>{stableCount}</dd>
        </div>
        <div>
          <dt>Previews</dt>
          <dd>{previewCount}</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="home-panel home-panel--start" aria-labelledby="home-start">
    <div>
      <p class="home-eyebrow">Start here</p>
      <h2 id="home-start">Choose the artifact you need</h2>
    </div>
    <div class="home-paths">
      {startLinks.map((item) => (
        <a class="home-path" href={item.href}>
          <span>{item.label}</span>
          <small>{item.detail}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="home-grid" aria-label="Documentation map">
    <article class="home-panel">
      <p class="home-eyebrow">Guides</p>
      <h2>Read by task</h2>
      <div class="home-guide-groups">
        {guideGroups.map((group) => (
          <div>
            <h3>{group.title}</h3>
            <ul>
              {group.links.map((guide) => (
                <li>
                  <a href={`${b}guides/${guide.id}`}>{guide.data.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </article>

    <article class="home-panel">
      <p class="home-eyebrow">Live QA</p>
      <h2>Preview before you ship</h2>
      <p>
        The preview directory is generated from source pages, component docs, and
        pattern docs, so missing previews fail the build instead of drifting quietly.
      </p>
      <pre><code>pnpm --filter ./docs test</code></pre>
      <a class="home-inline-link" href={`${b}preview`}>Search previews</a>
    </article>
  </section>

  <section class="home-panel" aria-labelledby="home-components">
    <div class="home-section-header">
      <div>
        <p class="home-eyebrow">Components and patterns</p>
        <h2 id="home-components">Common entry points</h2>
      </div>
      <a class="home-inline-link" href={`${b}components/button`}>Open component docs</a>
    </div>
    <ul class="home-components">
      {entryHighlights.map((component) => (
        <li>
          <a href={`${b}components/${component!.id}`}>
            <span>{component!.data.title}</span>
            <small>{component!.data.description ?? 'Component contract and examples.'}</small>
          </a>
          <a href={`${b}preview/${component!.id}`}>Preview</a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .home-dashboard {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(17rem, 25rem);
    gap: var(--pl-space-4);
    align-items: stretch;
    padding: var(--pl-space-4);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-2xl);
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--pl-color-accent), transparent 90%),
        color-mix(in oklab, var(--pl-color-surface), transparent 4%) 38%,
        color-mix(in oklab, var(--pl-color-surface-2), transparent 18%)
      );
    box-shadow: var(--pl-shadow-2);
  }

  .home-hero {
    display: grid;
    align-content: center;
    min-block-size: 24rem;
    padding: var(--pl-space-6);
    border-radius: var(--pl-radius-xl);
    background:
      linear-gradient(
        90deg,
        color-mix(in oklab, var(--pl-color-surface), transparent 12%),
        transparent
      );
  }

  .home-eyebrow {
    margin-block-end: var(--pl-space-2);
    color: var(--pl-color-accent);
    font-size: var(--pl-text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .home-hero h1 {
    margin-block: 0 var(--pl-space-3);
    font-size: clamp(2.75rem, 2.2rem + 2vi, 4rem);
    line-height: 1;
  }

  .home-hero p:not(.home-eyebrow) {
    max-inline-size: 48rem;
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-lg);
    line-height: var(--pl-leading-normal);
  }

  .home-actions,
  .home-section-header {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-3);
    align-items: center;
    justify-content: space-between;
  }

  .home-actions {
    justify-content: flex-start;
    margin-block-start: var(--pl-space-5);
  }

  .home-action,
  .home-inline-link {
    color: var(--pl-color-accent);
    font-weight: 700;
    text-decoration: none;
  }

  .home-action {
    display: inline-flex;
    align-items: center;
    min-block-size: var(--pl-control-block-size);
    padding-inline: var(--pl-space-4);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-pill);
    background: color-mix(in oklab, var(--pl-color-surface), transparent 8%);
  }

  .home-action:hover,
  .home-path:hover,
  .home-components a:hover,
  .home-inline-link:hover {
    text-decoration: underline;
  }

  .home-action--primary {
    border-color: var(--pl-color-accent);
    background: var(--pl-color-accent);
    color: var(--pl-color-accent-text);
  }

  .home-snapshot {
    display: grid;
    align-content: center;
    min-block-size: 100%;
    padding: var(--pl-space-5);
    border: 1px solid color-mix(in oklab, var(--pl-color-accent), transparent 62%);
    border-radius: var(--pl-radius-xl);
    background:
      linear-gradient(
        180deg,
        color-mix(in oklab, var(--pl-color-text), transparent 95%),
        color-mix(in oklab, var(--pl-color-surface), transparent 4%)
      );
  }

  .home-snapshot dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--pl-space-3);
    margin: 0;
  }

  .home-snapshot div {
    min-inline-size: 0;
    padding: var(--pl-space-4);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
    background: color-mix(in oklab, var(--pl-color-surface), transparent 10%);
  }

  .home-snapshot dt {
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-sm);
  }

  .home-snapshot dd {
    margin: 0;
    color: var(--pl-color-text);
    font-size: var(--pl-text-2xl);
    font-weight: 800;
    line-height: 1;
  }

  .home-panel {
    margin-block-start: var(--pl-space-6);
    padding-block: var(--pl-space-6);
    border-block-start: 1px solid var(--pl-color-border);
  }

  .home-panel h2,
  .home-panel h3,
  .home-panel p,
  .home-panel ul {
    margin-block-start: 0;
  }

  .home-panel h2 {
    margin-block-end: var(--pl-space-3);
    font-size: var(--pl-text-xl);
    line-height: 1.2;
  }

  .home-panel h3 {
    margin-block-end: var(--pl-space-2);
    font-size: var(--pl-text-sm);
  }

  .home-panel p:not(.home-eyebrow) {
    color: var(--pl-color-text-muted);
  }

  .home-panel--start {
    display: grid;
    grid-template-columns: minmax(14rem, 0.32fr) minmax(0, 1fr);
    gap: var(--pl-space-5);
    align-items: start;
  }

  .home-paths,
  .home-grid,
  .home-components {
    display: grid;
    gap: var(--pl-space-3);
  }

  .home-paths {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .home-path,
  .home-components li {
    display: grid;
    gap: var(--pl-space-1);
    min-inline-size: 0;
    padding: var(--pl-space-4);
    border: 1px solid var(--pl-color-border);
    border-radius: var(--pl-radius-lg);
    background: color-mix(in oklab, var(--pl-color-surface), transparent 8%);
    color: var(--pl-color-text);
    text-decoration: none;
    box-shadow: var(--pl-shadow-1);
  }

  .home-path small,
  .home-components small {
    color: var(--pl-color-text-muted);
    font-size: var(--pl-text-sm);
    line-height: 1.45;
  }

  .home-grid {
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.78fr);
  }

  .home-guide-groups {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--pl-space-4);
  }

  .home-guide-groups ul,
  .home-components {
    padding: 0;
    list-style: none;
  }

  .home-guide-groups li + li {
    margin-block-start: var(--pl-space-2);
  }

  .home-components {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .home-components li {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
  }

  .home-components a {
    color: var(--pl-color-accent);
    font-weight: 700;
    text-decoration: none;
  }

  .home-components a:first-child {
    display: grid;
    gap: var(--pl-space-1);
    color: var(--pl-color-text);
  }

  @media (width < 54rem) {
    .home-dashboard,
    .home-panel--start,
    .home-grid,
    .home-guide-groups,
    .home-components {
      grid-template-columns: 1fr;
    }

    .home-hero {
      min-block-size: auto;
      padding-block: var(--pl-space-5);
    }

    .home-paths {
      grid-template-columns: 1fr;
    }
  }
</style>
