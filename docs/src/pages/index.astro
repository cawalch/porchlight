---
import BaseLayout from '../layouts/BaseLayout.astro';

const b = import.meta.env.BASE_URL;
---
<BaseLayout>
  <section class="hero">
    <h1>Porchlight</h1>
    <p class="hero__lede">
      A no-dependency, native-CSS design substrate for enterprise SaaS — token-driven,
      container-query-first, built for Chrome 149+ (June 2026) with progressive
      enhancement everywhere else.
    </p>
    <p class="hero__status">🚧 In active development — not yet 1.0.</p>
    <p>
      <a class="hero__cta" href={`${b}preview`}>View the preview gallery</a>
    </p>
  </section>
</BaseLayout>
