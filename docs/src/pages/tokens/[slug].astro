---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const entries = await getCollection('tokens');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const title = `${entry.data.title} · Porchlight`;
const b = import.meta.env.BASE_URL;
const repo = 'https://github.com/cawalch/porchlight';
---
<DocsLayout
  title={title}
  sectionLabel="Token reference"
  previewHref={`${b}preview/tokens`}
  sourceHref={`${repo}/blob/main/docs/src/content/tokens/${entry.id}.mdx`}
  styleHref={`${repo}/blob/main/packages/porchlight/src/02-tokens.css`}
>
  <article class="prose">
    <Content />
  </article>
</DocsLayout>
