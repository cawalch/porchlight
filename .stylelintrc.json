{
  "extends": ["stylelint-config-standard"],
  "plugins": [
    "stylelint-use-logical",
    "stylelint-declaration-strict-value",
    "stylelint-plugin-defensive-css"
  ],
  "ignoreFiles": ["node_modules/**", "dist/**", "**/dist/**", ".astro/**"],
  "rules": {
    "at-rule-no-unknown": null,
    "property-no-unknown": [
      true,
      {
        "ignoreProperties": ["rule", "rule-visibility-items"]
      }
    ],
    "no-descending-specificity": null,
    "selector-class-pattern": null,
    "custom-property-pattern": null,
    "keyframes-name-pattern": null,
    "value-keyword-case": null,
    "property-no-vendor-prefix": null,
    "import-notation": "string",

    "csstools/use-logical": [
      true,
      {
        "severity": "error"
      }
    ],

    "declaration-property-value-no-unknown": [
      true,
      {
        "ignoreProperties": {
          "transform-origin": ["/^inline-/", "/^block-/"]
        }
      }
    ],

    "scale-unlimited/declaration-strict-value": [
      ["/color/", "fill", "stroke"],
      {
        "ignoreValues": [
          "/^(inherit|initial|unset|revert)$/",
          "transparent",
          "currentColor",
          "none",
          "/^(light|dark)$/",
          "/^(ButtonBorder|ButtonText|Canvas|CanvasText|GrayText|Highlight|HighlightText|LinkText|Mark|SelectedItem|SelectedItemText|VisitedText)$/"
        ]
      }
    ],

    "defensive-css/require-forced-colors-focus": true,
    "defensive-css/require-focus-visible": true
  },
  "overrides": [
    {
      "files": [
        "packages/porchlight/src/**/*.css",
        "packages/porchlight/porchlight.css"
      ],
      "rules": {
        "selector-class-pattern": [
          "^(?:pl-(?:c|l|u)-[a-z0-9][a-z0-9_-]*|is-(?:active|disabled|dragging|drop-target|invalid|selected))$",
          {
            "message": "Porchlight package classes must use pl-c-, pl-l-, or pl-u- prefixes; is-* is reserved for documented compatibility aliases."
          }
        ],
        "custom-property-pattern": [
          "^_?pl-[a-z0-9][a-z0-9-]*$",
          {
            "message": "Porchlight package custom properties must use the --pl-* namespace."
          }
        ],
        "keyframes-name-pattern": [
          "^pl-[a-z0-9][a-z0-9-]*$",
          {
            "message": "Porchlight package keyframes must use the pl-* namespace."
          }
        ]
      }
    }
  ]
}
