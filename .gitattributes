# Default to LF; let git detect text vs binary
* text=auto eol=lf

# Normalize text source explicitly
*.css   text eol=lf
*.mjs   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.mdx   text eol=lf
*.html  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff2 binary
